// Firestore Security Rules — Permissions Engine
// Append the rules inside this file into your main firestore.rules.
//
// Core invariant enforced here:
//   permissions/{uid} is written ONLY by Cloud Functions (Admin SDK).
//   Clients may read their own document. No client may write or delete it.
//
// The hot-path fields (ageTier, canPostPublic, reachTier) are also synced into
// Auth custom claims by the resolver, so post/space rules can gate on
// request.auth.token.canPostPublic without an extra Firestore read.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // PERMISSIONS — resolved set, server-write only
    // =========================================================

    match /permissions/{uid} {
      // Any authenticated user may read their own permission set.
      // Admins may read any uid's document.
      allow read: if request.auth != null
                  && (request.auth.uid == uid || hasAdminClaim());

      // Clients NEVER write. Only Cloud Functions via the Admin SDK.
      allow write: if false;
    }

    // =========================================================
    // GUARDIAN LINKS
    // =========================================================

    match /guardianLinks/{linkId} {
      // The child account (childUid) may read the link they initiated.
      // The guardian who confirmed may also read it.
      // Admins may read any link.
      allow read: if request.auth != null
                  && (
                    resource.data.childUid    == request.auth.uid ||
                    resource.data.guardianUid == request.auth.uid ||
                    hasAdminClaim()
                  );

      // Links are created by the requestGuardianConsent callable (Admin SDK). No direct client writes.
      allow write: if false;
    }

    // =========================================================
    // POSTS — gate on custom claim so rules need no extra reads
    // =========================================================

    match /posts/{postId} {
      // Existing post rules stay as-is. Add this condition to allow create:
      //   && request.auth.token.canPostPublic == true
      //
      // Example (merge with your existing post rules):
      allow create: if request.auth != null
                    && request.auth.token.canPostPublic == true
                    && request.resource.data.authorId == request.auth.uid;

      // Reads and updates use your existing rules — no change needed here.
    }

    // =========================================================
    // USERS — guard mode writes through the setMode callable
    // =========================================================

    match /users/{uid} {
      // Existing rules stay as-is. Add this to prevent direct client mode writes:
      //
      // The mode field must only be changed via the setMode callable (which validates
      // the mode is allowed for the account's age tier before persisting).
      //
      // In your existing allow update rule, add:
      //   && (request.resource.data.mode == resource.data.mode
      //       || !request.resource.data.keys().hasAny(['mode']))
      //
      // This prevents a client from writing mode=social on a teen account directly.
      //
      // Permissions-related fields that only functions should write:
      //   ageTier, guardianConsentStatus, mentorApproved, accountState, csamFlag
      // Add these to your existing write deny-list for client updates.
    }

    // =========================================================
    // TRUST EDGES — read-only for clients, written by trust module
    // =========================================================

    match /trustEdges/{edgeId} {
      allow read: if request.auth != null
                  && (resource.data.fromUid == request.auth.uid
                      || resource.data.toUid == request.auth.uid);
      allow write: if false; // trust-graph module owns writes
    }


    // =========================================================
    // BEREAN CONVERSATIONS — owner-read-only; server-write only
    // Prevents enumeration: uid A cannot list or read uid B's
    // bereanConversations or their messages subcollection.
    // =========================================================

    match /users/{uid}/bereanConversations/{conversationId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Cloud Functions (Admin SDK) own all writes

      match /messages/{messageId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // =========================================================
    // CALM CONTROL + SPIRITUAL RHYTHM OS
    // All subcollections live under users/{userId}.
    // =========================================================

    // ---------------------------------------------------------
    // PRIVACY SETTINGS
    // Owner read/write only. No other user may read this document.
    // ---------------------------------------------------------
    match /users/{userId}/privacySettings/main {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // FEED CONTROLS
    // Owner read/write only.
    // ---------------------------------------------------------
    match /users/{userId}/feedControls/main {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // NOTIFICATION SETTINGS
    // Owner read only. Client write is allowed here so users can toggle
    // categories directly; the authoritative write path goes through
    // the updateNotificationSettings Cloud Function (Admin SDK).
    // ---------------------------------------------------------
    match /users/{userId}/notificationSettings/main {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // SPIRITUAL RHYTHM
    // Owner read/write only.
    // ---------------------------------------------------------
    match /users/{userId}/spiritualRhythm/main {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // STREAKS
    // Owner read only. Writes come exclusively from Cloud Functions
    // (recordSpiritualActivity, calculateStreakState). Client may not
    // write streak documents directly to prevent score spoofing.
    // ---------------------------------------------------------
    match /users/{userId}/streaks/{streakType} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Cloud Functions (Admin SDK) own all writes
    }

    // ---------------------------------------------------------
    // PRESENCE
    // Owner write. Other authenticated users may read this document.
    //
    // NOTE: Full presence visibility (quietProfileMode gate) is enforced
    // at the API/service layer, not here. Cross-collection reads in rules
    // are expensive and avoided for hot-path documents.
    // ---------------------------------------------------------
    match /users/{userId}/presence/main {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // AUDIENCE LAYERS
    // Owner read/write only. Maximum of 10 layers is enforced in
    // Cloud Functions (createAudienceLayer callable), not in rules.
    // ---------------------------------------------------------
    match /users/{userId}/audienceLayers/{layerId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // ACTIVITY LOG
    // Owner read only. Writes are via Cloud Functions only.
    // Client write is blocked to prevent activity spoofing.
    // ---------------------------------------------------------
    match /users/{userId}/activity/main {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Cloud Functions (Admin SDK) own all writes
    }

    // ---------------------------------------------------------
    // RATE LIMITS
    // No direct client read or write. Admin SDK only.
    // ---------------------------------------------------------
    match /users/{userId}/rateLimits/{limitType} {
      allow read:  if false;
      allow write: if false;
    }

    // =========================================================
    // HELPER FUNCTIONS
    // =========================================================

    function hasAdminClaim() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isAdultTier() {
      return request.auth != null && request.auth.token.ageTier == "adult";
    }

    function canPostPublicClaim() {
      return request.auth != null && request.auth.token.canPostPublic == true;
    }

    // Reads the resolved PermissionSet for an arbitrary uid.
    // Use sparingly — prefer custom claims for hot-path rules.
    function getPermissions(uid) {
      return get(/databases/$(database)/documents/permissions/$(uid)).data;
    }

    function canSendDM(uid) {
      let perms = getPermissions(uid);
      return perms != null && perms.sendDM != "none";
    }

    function canReceiveDM(uid) {
      let perms = getPermissions(uid);
      return perms != null && perms.receiveDM != "none";
    }
  }
}
