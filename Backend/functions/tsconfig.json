{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020"],
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "noEmitOnError": false
  },
  "compileOnSave": false,
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.static.test.ts",
    "src/**/__tests__/**"
  ]
}
