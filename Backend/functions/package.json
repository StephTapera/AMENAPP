{
  "name": "amen-backend-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "lint": "echo \"No lint configured\"",
    "deploy": "firebase deploy --only functions",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google-cloud/vision": "^4.3.2",
    "adm-zip": "^0.5.17",
    "axios": "^1.17.0",
    "csv-parse": "^6.2.1",
    "ffmpeg-static": "^5.2.0",
    "firebase-admin": "^12.2.0",
    "firebase-functions": "^4.5.0",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.0",
    "stripe": "^22.2.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.21",
    "@types/jest": "^29.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.json"
      }
    }
  }
}
