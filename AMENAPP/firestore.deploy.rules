rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.get('admin', false) == true;
    }
    function validLength(text, maxLength) {
      return text is string && text.size() <= maxLength;
    }
    function isValidLivingEntryType(value) {
      return value in ['note', 'reminder', 'churchNote', 'sermonInsight', 'prayer', 'followUp', 'reflection', 'task'];
    }
    function isValidLivingEntryIntent(value) {
      return value in ['spiritualGrowth', 'churchVisit', 'sermonReflection', 'prayerCare', 'relationship', 'work', 'rest', 'personal', 'unknown'];
    }
    function isValidLivingEntryState(value) {
      return value in ['active', 'completed', 'deferred', 'archived', 'needsReflection', 'expired'];
    }
    function isValidLivingEntryTriggerType(value) {
      return value in ['time', 'location', 'churchProximity', 'calendar', 'quietMoment', 'afterChurch', 'beforeService', 'userIdle', 'manual'];
    }
    function isValidLivingEntrySurface(value) {
      return value in ['church_notes', 'find_church', 'berean', 'home', 'feed'];
    }
    function livingEntryAIOwnedFields() {
      return ['priorityScore', 'gravityScore', 'regretRisk', 'aiSummary', 'suggestedNextAction', 'reflectionPrompt', 'evolutionVersion'];
    }
    function livingEntryAllowedClientFields() {
      return [
        'userId', 'type', 'intent', 'state', 'title', 'body',
        'churchId', 'churchName', 'sermonTitle', 'scriptureRefs', 'tags',
        'createdAt', 'updatedAt', 'dueAt', 'completedAt', 'deferredUntil',
        'emotionalWeight', 'spiritualWeight', 'lastSurfacedAt', 'triggerRules',
        'contextSnapshot', 'reflectionAnswer'
      ];
    }
    function validLivingEntryRule(rule) {
      return rule is map
        && isValidLivingEntryTriggerType(rule.type)
        && rule.enabled is bool;
    }
    function validLivingEntrySnapshot(snapshot) {
      return snapshot is map
        && snapshot.localHour is int
        && snapshot.dayOfWeek is int
        && snapshot.isSunday is bool
        && snapshot.isAtChurch is bool
        && snapshot.quietModeActive is bool
        && snapshot.focusModeActive is bool
        && isValidLivingEntrySurface(snapshot.sourceSurface);
    }
    function validLivingEntryData(data) {
      return data.userId == request.auth.uid
        && isValidLivingEntryType(data.type)
        && isValidLivingEntryIntent(data.intent)
        && isValidLivingEntryState(data.state)
        && validLength(data.title, 160)
        && validLength(data.body, 4000)
        && (!data.keys().hasAny(['scriptureRefs']) || data.scriptureRefs is list)
        && (!data.keys().hasAny(['tags']) || data.tags is list)
        && (!data.keys().hasAny(['triggerRules']) || data.triggerRules is list)
        && (!data.keys().hasAny(['triggerRules']) || data.triggerRules.size() <= 12)
        && validLivingEntrySnapshot(data.contextSnapshot);
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    // ── Church Notes helpers ──
    // Owner of the parent note (used by subcollection rules to avoid duplicating the get()).
    function isChurchNoteOwner(noteId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/churchNotes/$(noteId)).data.userId == request.auth.uid;
    }
    // Collaborator with any of the given roles.
    function isChurchNoteCollaboratorWithRole(noteId, roles) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/churchNotes/$(noteId)/collaborators/$(request.auth.uid))
        && roles.hasAny([
          get(/databases/$(database)/documents/churchNotes/$(noteId)/collaborators/$(request.auth.uid)).data.role
        ]);
    }
    // Client-editable note fields. Excludes AI/system fields (summaryDraft,
    // transcriptText, ocrText, studyGuideDraft, prayerPromptsDraft,
    // actionItemsDraft, scriptureReferencesDraft, translationDraft, etc.)
    // so clients can never write AI-generated content.
    function churchNoteAllowedUpdateFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'title', 'sermonTitle', 'sermonSpeaker', 'churchId', 'churchName',
          'serviceDate', 'date', 'journeyId', 'tags', 'scriptureReferences',
          'updatedAt', 'approvedBody', 'body', 'content', 'permission',
          'sharedWith', 'isFavorite', 'folderId', 'shareLinkId',
          'worshipSongs', 'visitPlanId', 'claudeTags', 'richContentJSON',
          'checklists', 'linkedNoteIds', 'attachmentCount', 'actionStepThisWeek',
          'prayerFromSermon', 'shouldRevisit', 'revisitDate', 'growthReflection',
          'formattingRanges', 'isPublic', 'pastor', 'keyPoints',
          'audioRecordingURL', 'hasTranscript',
          // Edit attribution for privacy audit trail.
          'lastUpdatedByUid', 'lastUpdatedAt',
          // Shared editing version guard.
          'version', 'lastKnownRevision'
        ]);
    }
    function isLivingEntryType(value) {
      return value in ['note', 'reminder', 'churchNote', 'sermonInsight', 'prayer', 'followUp', 'reflection', 'task'];
    }
    function isLivingEntryIntent(value) {
      return value in ['spiritualGrowth', 'churchVisit', 'sermonReflection', 'prayerCare', 'relationship', 'work', 'rest', 'personal', 'unknown'];
    }
    function isLivingEntryState(value) {
      return value in ['active', 'completed', 'deferred', 'archived', 'needsReflection', 'expired'];
    }
    function livingEntryClientFields() {
      return [
        'userId',
        'type',
        'intent',
        'state',
        'title',
        'body',
        'churchId',
        'churchName',
        'sermonTitle',
        'scriptureRefs',
        'tags',
        'createdAt',
        'updatedAt',
        'dueAt',
        'completedAt',
        'deferredUntil',
        'emotionalWeight',
        'spiritualWeight',
        'lastSurfacedAt',
        'triggerRules',
        'contextSnapshot',
        'reflectionAnswer',
        'deletedAt'
      ];
    }
    function validLivingEntryPayload() {
      return request.resource.data.userId == request.auth.uid
        && isLivingEntryType(request.resource.data.type)
        && isLivingEntryIntent(request.resource.data.intent)
        && isLivingEntryState(request.resource.data.state)
        && validLength(request.resource.data.title, 140)
        && validLength(request.resource.data.body, 4000)
        && request.resource.data.keys().hasOnly(livingEntryClientFields());
    }
    function isOnlyUpdating(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }
    function isCounterUpdate() {
      return (isOnlyUpdating(['followersCount', 'followingCount', 'updatedAt'])
        || isOnlyUpdating(['followersCount', 'updatedAt'])
        || isOnlyUpdating(['followingCount', 'updatedAt'])
        || isOnlyUpdating(['postsCount', 'updatedAt'])
        || isOnlyUpdating(['followersCount'])
        || isOnlyUpdating(['followingCount']))
        && (request.resource.data.get('followersCount', resource.data.get('followersCount', 0))
            - resource.data.get('followersCount', 0)) in [-1, 0, 1]
        && (request.resource.data.get('followingCount', resource.data.get('followingCount', 0))
            - resource.data.get('followingCount', 0)) in [-1, 0, 1]
        && (request.resource.data.get('postsCount', resource.data.get('postsCount', 0))
            - resource.data.get('postsCount', 0)) in [-1, 0, 1];
    }
    function postsCountIncrementIsValid(userId) {
      let delta = request.resource.data.get('postsCount', resource.data.get('postsCount', 0))
                  - resource.data.get('postsCount', 0);
      return delta <= 0
        || request.auth.uid == userId;
    }
    function validatePinnedPostWrite(userId) {
      let data = request.resource.data;
      let isPin = data.keys().hasAll(['pinnedPostId', 'profilePinnedPost']);
      return
        (!data.keys().hasAny(['pinnedPostId']) || data.pinnedPostId is string)
        && (!data.keys().hasAny(['pinnedAt']) || data.pinnedAt is timestamp)
        && (!data.keys().hasAny(['pinnedUntil']) || data.pinnedUntil is timestamp)
        && (!data.keys().hasAny(['profilePinnedPost']) || data.profilePinnedPost is map)
        && (!isPin || data.profilePinnedPost.get('postId', '') == data.pinnedPostId)
        && (!isPin
            || (get(/databases/$(database)/documents/posts/$(data.pinnedPostId)).data.authorId == userId
                && get(/databases/$(database)/documents/posts/$(data.pinnedPostId)).data.get('isRemoved', false) != true));
    }
    function callerAgeTier() {
      let tokenTier = request.auth.token.get('ageTier', '');
      return tokenTier != ''
        ? tokenTier
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('ageTier', 'tierD');
    }
    function callerIsAdult() {
      return callerAgeTier() == 'tierD';
    }
    function callerCanUseDMs() {
      let t = callerAgeTier();
      return t == 'tierC' || t == 'tierD';
    }
    function callerIsEmailVerified() {
      return request.auth.token.get('email_verified', false) == true
        || request.auth.token.firebase.sign_in_provider != 'password';
    }
    function caller2FASessionValid() {
      let expiry = request.auth.token.get('twoFaSessionExpiry', -1);
      return expiry <= 0 || expiry > request.time.toMillis();
    }
    function callerAccountActive() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('accountStatus', 'active') == 'active'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isDeactivated', false) != true
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isDeleting', false) != true
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('deletionStatus', 'none') == 'none';
    }
    function userDocPublicSafe() {
      return !resource.data.keys().hasAny([
        'email',
        'phoneNumber',
        'role',
        'isAdmin',
        'isModerator',
        'accountStatus',
        'isDeactivated',
        'deactivatedAt',
        'deactivationReason',
        'deletionStatus',
        'deletedAt',
        'isDeleting',
        'emailVerified',
        'phoneVerified',
        'ageVerified',
        'twoFactorEnabled',
        'twoFactorVerified',
        'twoFactorSession',
        'backupCodes',
        'birthYear',
        'ageTier'
      ]);
    }
    function isActiveMemberOf(covenantId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/covenants/$(covenantId)/members/$(request.auth.uid));
    }
    function isCreatorOf(covenantId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/covenants/$(covenantId)).data.get('creatorId', '') == request.auth.uid;
    }
    match /usernameLookup/{username} {
      // Only allow exact-match lookups, not enumeration queries.
      allow get: if isAuthenticated();
      allow list: if false;
      allow create, update, delete: if false;
    }
    match /users/{userId} {
      allow get: if isAuthenticated() && (isOwner(userId) || isAdmin() || userDocPublicSafe());
      allow list: if isAdmin();
      allow create: if false;
      allow update: if isAuthenticated()
        && (
          (isOwner(userId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'displayName',
              'displayNameLowercase',
              'bio',
              'profileImageURL',
              'photoURL',
              'isPrivate',
              'notificationsEnabled',
              'pushNotificationsEnabled',
              'emailNotificationsEnabled',
              'notifyOnLikes',
              'notifyOnComments',
              'notifyOnFollows',
              'notifyOnMentions',
              'notifyOnPrayerRequests',
              'allowMessagesFromEveryone',
              'showActivityStatus',
              'allowTagging',
              'updatedAt'
            ])
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'isVerified',
              'email',
              'backupCodes',
              'emailVerified',
              'phoneVerified',
              'ageVerified',
              'strikes',
              'accountStatus',
              'isDeactivated',
              'deactivatedAt',
              'deactivationExpiresAt',
              'deactivationReason',
              'deletionStatus',
              'deletedAt',
              'isDeleting',
              'deletionRequestedAt',
              'hasCompletedOnboarding',
              'onboardingStatus',
              'onboardingCompletedAt',
              'termsAcceptedAt',
              'privacyAcceptedAt',
              'twoFactorEnabled',
              'twoFactorVerified',
              'twoFactorSession',
              'twoFactorPhone',
              'twoFactorMaskedPhone',
              'twoFactorEnabledAt',
              'twoFactorDisabledAt',
              'username',
              'usernameLowercase',
              'createdAt',
              'suspiciousActivityScore',
              'ageTier',
              'birthYear',
              'isAdmin',
              'isModerator',
              'role'
            ])
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['username', 'pendingUsernameChange'])
              || !exists(/databases/$(database)/documents/userSafetyRecords/$(userId))
              || get(/databases/$(database)/documents/userSafetyRecords/$(userId)).data.canChangeUsername != false
            )
            && (
              !exists(/databases/$(database)/documents/userSafetyRecords/$(userId))
              || get(/databases/$(database)/documents/userSafetyRecords/$(userId)).data.accountStatus != 'frozen'
            )
            // M-03: Minors cannot reduce content filtering.
            && (callerAgeTier() != 'tierB' && callerAgeTier() != 'tierC'
                || request.resource.data.get('sensitiveContentLevel', 'restricted') == 'restricted'))
          ||
          (isCounterUpdate() && postsCountIncrementIsValid(userId))
          ||
          (isOwner(userId)
            && isOnlyUpdating([
              'pendingUsernameChange',
              'pendingDisplayNameChange',
              'usernameChangeRequestDate',
              'displayNameChangeRequestDate',
              'updatedAt'
            ]))
          ||
          (isOwner(userId)
            && isOnlyUpdating([
              'pinnedPostId',
              'pinnedAt',
              'profilePinnedPost',
              'pinnedUntil'
            ])
            && validatePinnedPostWrite(userId))
        );
      allow delete: if false;
      match /following/{followingId} {
        allow read: if isAuthenticated()
          && (isOwner(userId)
            || callerFollows(request.auth.uid, userId)
            || isPublicProfile(userId));
        allow create: if isAuthenticated()
          && (isOwner(userId) || followingId == request.auth.uid);
        allow delete: if isAuthenticated()
          && (isOwner(userId) || followingId == request.auth.uid);
        allow update: if isAuthenticated() && isOwner(userId);
      }
      match /followers/{followerId} {
        allow read: if isAuthenticated()
          && (isOwner(userId)
            || callerFollows(request.auth.uid, userId)
            || isPublicProfile(userId));
        allow create: if isAuthenticated()
          && (isOwner(userId) || followerId == request.auth.uid);
        allow delete: if isAuthenticated()
          && (isOwner(userId) || followerId == request.auth.uid);
        allow update: if isAuthenticated() && isOwner(userId);
      }
      match /savedPosts/{postId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      match /mediaGraph/{bucketId} {
        allow read, create, update, delete: if isAuthenticated() && isOwner(userId);
      }
      match /mediaGraph/{bucketId}/{docId} {
        allow read, create, update, delete: if isAuthenticated() && isOwner(userId);
      }
      match /blockedUsers/{blockedUserId} {
        allow read: if isAuthenticated()
          && (isOwner(userId) || blockedUserId == request.auth.uid);
        allow create: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if false;
        allow update: if isAuthenticated() && isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['read', 'seenAt', 'updatedAt']);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      match /notificationState/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated()
          && isOwner(userId)
          && !request.resource.data.keys().hasAny(['unseenCount', 'badgeVersion', 'lastDeliveredAt'])
          && request.resource.data.keys().hasOnly(['lastSeenAt', 'lastReadAt', 'updatedAt']);
        allow delete: if false;
      }
      match /preferences/{prefId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      match /smartSuggestions/{targetUserId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      match /communityStandards/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if false;
      }
      match /usageSessions/{sessionId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update, delete: if false;
      }
      match /wellnessEvents/{eventId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update, delete: if false;
      }
      match /scrollBudgetUsage/{date} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if false;
      }
      match /devices/{deviceId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      match /deviceTokens/{tokenId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      match /living_entries/{entryId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated()
          && isOwner(userId)
          && request.resource.data.keys().hasOnly(livingEntryAllowedClientFields())
          && !request.resource.data.keys().hasAny(livingEntryAIOwnedFields())
          && validLivingEntryData(request.resource.data);
        allow update: if isAuthenticated()
          && isOwner(userId)
          && !resource.data.get('isRemoved', false)
          && request.resource.data.userId == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(livingEntryAllowedClientFields())
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(livingEntryAIOwnedFields())
          && resource.data.state != 'archived'
          && validLivingEntryData(request.resource.data);
        allow delete: if false;
      }
      match /living_entry_reflections/{reflectionId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated()
          && isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.entryId is string
          && validLength(request.resource.data.answer, 2000)
          && request.resource.data.helpfulness in ['helpful', 'mistimed', 'not_needed', 'meaningful'];
        allow update, delete: if false;
      }
      match /living_entry_events/{eventId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated()
          && isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.entryId is string
          && validLength(request.resource.data.eventType, 80);
        allow update, delete: if false;
      }
      match /backupCodes/{codeId} {
        allow read: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
      match /twoFactorAuth/{settingsId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      match /moderation/{actionId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update, delete: if false;
      }
      match /loginAlerts/{alertId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update, delete: if false;
      }
      match /twoFactor/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      match /seenPosts/{postId} {
        allow read, create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if false;
      }
      match /savedBooks/{bookId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
      match /settings/{settingsId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      match /chatMemory/{chatId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
        match /items/{itemId} {
          allow read: if isAuthenticated() && isOwner(userId);
          allow create, update: if isAuthenticated() && isOwner(userId);
          allow delete: if isAuthenticated() && isOwner(userId);
        }
      }
      match /private/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if false;
      }

      // === PRAYERS SUBCOLLECTION (H-14 FIX) ===
      // Only the owning user may access their own private prayers.
      // This prevents any other authenticated user from reading another user's
      // prayer subcollection documents.
      match /prayers/{prayerId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
      }
    }
    function isPublicProfile(uid) {
      let doc = get(/databases/$(database)/documents/users/$(uid));
      return doc.data.get('isPrivate', false) == false
          && doc.data.get('isPrivateAccount', false) == false;
    }
    function callerFollows(callerUid, subjectUid) {
      return exists(/databases/$(database)/documents/follows_index/$(callerUid + '_' + subjectUid));
    }
    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.get('followerId', '') == request.auth.uid
        && request.resource.data.get('followerId', '') != request.resource.data.get('followingId', '');
      allow update: if isAuthenticated()
        && resource.data.get('followerId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource == null || resource.data.get('followerId', '') == request.auth.uid);
    }
    match /follows_index/{indexId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
        && request.resource.data.get('followerId', '') == request.auth.uid
        && request.resource.data.get('followerId', '') != request.resource.data.get('followingId', '');
      allow delete: if isAuthenticated()
        && resource.data.get('followerId', '') == request.auth.uid;
    }
    match /followRequests/{requestId} {
      allow get: if isAuthenticated()
        && (resource.data.toUserId == request.auth.uid
          || resource.data.fromUserId == request.auth.uid);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.toUserId == request.auth.uid
          || resource.data.fromUserId == request.auth.uid);
      allow delete: if isAuthenticated()
        && (resource.data.fromUserId == request.auth.uid
          || resource.data.toUserId == request.auth.uid);
    }
    match /blocks/{blockId} {
      allow get: if isAuthenticated()
        && (resource.data.blockerId == request.auth.uid
          || resource.data.blockedId == request.auth.uid);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.blockerId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.blockerId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.blockerId == request.auth.uid;
    }
    function postAuthorIsPrivate(authorId) {
      let authorDoc = get(/databases/$(database)/documents/users/$(authorId));
      return authorDoc.data.get('isPrivate', false) == true
        || authorDoc.data.get('isPrivateAccount', false) == true;
    }
    function callerIsBlockedByAuthor(authorId) {
      return exists(/databases/$(database)/documents/users/$(authorId)/blockedUsers/$(request.auth.uid));
    }
    function callerCanReadPost() {
      let post = resource.data;
      let authorId = post.authorId;
      let viewerId = request.auth.uid;
      let vis = post.get('visibility', 'everyone');
      let isTrustedCirclePost = post.keys().hasAny(['trustedCircle']) && post.trustedCircle != null;
      let canReadNonTrustedPost =
        (vis == 'everyone' && !callerIsBlockedByAuthor(authorId))
        || (vis == 'followers'
            && exists(/databases/$(database)/documents/follows_index/$(viewerId + '_' + authorId))
            && !callerIsBlockedByAuthor(authorId))
        || (!postAuthorIsPrivate(authorId)
            && vis != 'private'
            && !callerIsBlockedByAuthor(authorId));
      return viewerId == authorId
        || (!isTrustedCirclePost && canReadNonTrustedPost);
    }
    function callerCanReadPostById(postId) {
      let post = get(/databases/$(database)/documents/posts/$(postId)).data;
      let authorId = post.authorId;
      let viewerId = request.auth.uid;
      let vis = post.get('visibility', 'everyone');
      let isTrustedCirclePost = post.keys().hasAny(['trustedCircle']) && post.trustedCircle != null;
      let canReadNonTrustedPost =
        (vis == 'everyone' && !callerIsBlockedByAuthor(authorId))
        || (vis == 'followers'
            && exists(/databases/$(database)/documents/follows_index/$(viewerId + '_' + authorId))
            && !callerIsBlockedByAuthor(authorId))
        || (!postAuthorIsPrivate(authorId)
            && vis != 'private'
            && !callerIsBlockedByAuthor(authorId));
      return exists(/databases/$(database)/documents/posts/$(postId))
        && (viewerId == authorId || (!isTrustedCirclePost && canReadNonTrustedPost));
    }
    function callerCanComment(postId) {
      let post = get(/databases/$(database)/documents/posts/$(postId)).data;
      let authorId = post.authorId;
      let viewerId = request.auth.uid;
      let vis = post.get('visibility', 'everyone');
      let isTrustedCirclePost = post.keys().hasAny(['trustedCircle']) && post.trustedCircle != null;
      let canReadNonTrustedPost =
        (vis == 'everyone' && !callerIsBlockedByAuthor(authorId))
        || (vis == 'followers'
            && exists(/databases/$(database)/documents/follows_index/$(viewerId + '_' + authorId))
            && !callerIsBlockedByAuthor(authorId))
        || (!postAuthorIsPrivate(authorId)
            && vis != 'private'
            && !callerIsBlockedByAuthor(authorId));
      let canRead = viewerId == authorId
        || (!isTrustedCirclePost && canReadNonTrustedPost);
      let commentsAllowed = post.get('allowComments', true) == true;
      let commentPerms = post.get('commentPermissions', 'Everyone');
      let permittedByCommentPerms = viewerId == authorId
        || commentPerms == 'Everyone'
        || (commentPerms == 'People I follow'
            && exists(/databases/$(database)/documents/follows_index/$(authorId + '_' + viewerId)))
        || (commentPerms == 'Mentioned only'
            && post.get('taggedUserIds', []).hasAny([viewerId]));
      return canRead && commentsAllowed && permittedByCommentPerms;
    }
    function callerCanQuote(sourcePostId) {
      let post = get(/databases/$(database)/documents/posts/$(sourcePostId)).data;
      let sourceAuthorId = post.authorId;
      let quotePerms = post.get('quotesAllowed', 'everyone');
      let isTrustedCirclePost = post.keys().hasAny(['trustedCircle']) && post.trustedCircle != null;
      let permittedForNonTrustedPost =
        quotePerms == 'everyone'
        || (quotePerms == 'followers'
            && exists(/databases/$(database)/documents/follows_index/$(request.auth.uid + '_' + sourceAuthorId)));
      return sourceAuthorId == request.auth.uid
        || (!isTrustedCirclePost && permittedForNonTrustedPost);
    }
    match /posts/{postId} {
      allow get: if isAuthenticated() && (resource == null || callerCanReadPost());
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && callerAccountActive()
        && callerIsEmailVerified()
        && request.resource.data.authorId == request.auth.uid
        && hasRequiredFields(['content', 'authorId', 'authorName', 'category'])
        && validLength(request.resource.data.content, 5000)
        && request.resource.data.get('content', '').size() > 0
        && request.resource.data.category in ['openTable', 'testimonies', 'prayer', 'general', 'tip', 'funFact']
        && !request.resource.data.keys().hasAny(['trustedCircle'])
        && request.resource.data.get('amenCount', 0) == 0
        && request.resource.data.get('lightbulbCount', 0) == 0
        && request.resource.data.get('commentCount', 0) == 0
        && request.resource.data.get('repostCount', 0) == 0
        && !request.resource.data.keys().hasAny([
          'flaggedForReview', 'removed', 'verified',
          'moderationScore', 'appealStatus'
        ])
        && !request.resource.data.keys().hasAny(['communityHubPreview'])
        && (!request.resource.data.keys().hasAny(['createdAt'])
            || request.resource.data.createdAt == request.time)
        && request.resource.data.get('status', 'publishing') in ['publishing', 'draft']
        && (!request.resource.data.keys().hasAny(['quote'])
            || callerCanQuote(request.resource.data.quote.sourcePostId));
      allow update: if isAuthenticated()
        && callerAccountActive()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly([
               'content',
               'visibility',
               'allowComments',
               'commentPermissions',
               'replyPermission',
               'quotesAllowed',
               'updatedAt',
               'inlineContentTokens',
               'contentTokens',
               'editedAt',
               'title',
               'tags',
               'linkPreviewUrl',
               'linkPreviewTitle',
               'linkPreviewDescription',
               'linkPreviewImageUrl',
               'category'
             ])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['content'])
            || !resource.data.keys().hasAll(['editWindowExpiresAt'])
            || request.time <= resource.data.editWindowExpiresAt);
      allow delete: if isAuthenticated()
        && callerAccountActive()
        && resource.data.authorId == request.auth.uid;
      match /likes/{likeId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }
      match /comments/{commentId} {
        allow read: if isAuthenticated() && callerCanComment(postId);
        allow create: if isAuthenticated()
          && callerIsEmailVerified()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.get('text', '').size() > 0
          && validLength(request.resource.data.text, 2000)
          && callerCanComment(postId)
          && !request.resource.data.keys().hasAny([
            'flaggedForReview', 'removed', 'moderationScore'
          ]);
        allow update: if isAuthenticated()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['text', 'editedAt', 'updatedAt']);
        allow delete: if isAuthenticated()
          && (resource.data.authorId == request.auth.uid
            || get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid);
      }
      match /reposts/{repostId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }
      match /dynamicReplyPreviews/{previewId} {
        allow read: if isAuthenticated() && (resource == null || callerCanReadPostById(postId));
        allow write: if false;
      }
      match /dynamicReplyPreviewMeta/{docId} {
        allow read: if false;
        allow write: if false;
      }
      match /mediaMeta/{mediaId} {
        allow read: if isAuthenticated() && (resource == null || callerCanReadPost());
        allow write: if false;
        match /captionTracks/{trackId} {
          allow read: if isAuthenticated() && callerCanReadPost();
          allow write: if false;
        }
        match /keyMoments/{momentId} {
          allow read: if isAuthenticated() && callerCanReadPost();
          allow write: if false;
        }
      }
      match /mediaCaptionValidation/{uid} {
        allow read: if isAuthenticated() && request.auth.uid == uid;
        allow write: if false;
      }
    }
    match /conversations/{conversationId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participantIds;
      }
      function willBeParticipant() {
        return request.auth.uid in request.resource.data.participantIds;
      }
      allow get: if isAuthenticated()
        && isParticipant();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && willBeParticipant()
        && request.resource.data.participantIds.size() >= 2
        && callerCanUseDMs()
        && (
          (request.resource.data.isGroup == false) ||
          (request.resource.data.isGroup == true &&
           'groupName' in request.resource.data &&
           request.resource.data.groupName is string &&
           request.resource.data.groupName.size() > 0)
        );
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'requesterId', 'isGroup'
        ])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participantIds'])
          || (resource.data.get('isGroup', false) == true
              && request.auth.uid in resource.data.get('adminIds', []))
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'groupName', 'groupAvatarUrl', 'groupDescription', 'adminIds'
          ])
          || (resource.data.get('isGroup', false) == true
              && request.auth.uid in resource.data.get('adminIds', []))
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['conversationStatus'])
          || resource.data.get('requesterId', '') != request.auth.uid
        );
      allow delete: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds;
      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if isAuthenticated()
          && caller2FASessionValid()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && validLength(request.resource.data.get('text', ''), 10000)
          && (
            !exists(/databases/$(database)/documents/userSafetyRecords/$(request.auth.uid))
            || get(/databases/$(database)/documents/userSafetyRecords/$(request.auth.uid)).data.accountStatus != 'frozen'
          );
        allow update: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && (resource.data.senderId == request.auth.uid
              || request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['readBy', 'reactions', 'deliveryStatus']));
        allow delete: if isAuthenticated()
          && resource.data.senderId == request.auth.uid
          && (
            !exists(/databases/$(database)/documents/userSafetyRecords/$(request.auth.uid))
            || get(/databases/$(database)/documents/userSafetyRecords/$(request.auth.uid)).data.canDeleteMessages != false
          );
      }
      match /typing/{userId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow write: if isAuthenticated() && isOwner(userId)
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
      match /held_messages/{messageId} {
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow read: if isAuthenticated()
          && (resource.data.senderId == request.auth.uid
              || resource.data.recipientId == request.auth.uid)
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false;
      }
    }
    match /feeds/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
      match /items/{itemId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }
    match /communities/{communityId} {
      function callerCanReadCommunity() {
        return resource.data.get('isPrivate', false) == false
          || resource.data.get('creatorId', '') == request.auth.uid
          || request.auth.uid in resource.data.get('adminIds', [])
          || exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid))
          || isAdmin();
      }
      allow read: if isAuthenticated() && callerCanReadCommunity();
      allow create: if isAuthenticated()
        && request.resource.data.creatorId == request.auth.uid
        && hasRequiredFields(['name', 'description', 'creatorId'])
        && validLength(request.resource.data.name, 100)
        && validLength(request.resource.data.description, 500);
      // S1 FIX: Adding/removing adminIds requires caller to already be in adminIds.
      allow update: if isAuthenticated()
        && (resource.data.creatorId == request.auth.uid
          || request.auth.uid in resource.data.get('adminIds', []))
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['creatorId'])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['adminIds'])
          || request.auth.uid in resource.data.get('adminIds', [])
        );
      allow delete: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;
      match /members/{memberId} {
        allow read: if isAuthenticated() && callerCanReadCommunity();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && (resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid);
      }
      match /posts/{postId} {
        allow read: if isAuthenticated() && callerCanReadCommunity();
        allow create: if isAuthenticated()
          && request.resource.data.authorId == request.auth.uid;
        allow update: if isAuthenticated()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['content', 'visibility', 'updatedAt', 'editedAt', 'title', 'tags']);
        allow delete: if isAuthenticated()
          && (resource.data.authorId == request.auth.uid
            || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid);
      }
    }
    match /arkCommunities/{communityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.creatorId == request.auth.uid
        && hasRequiredFields(['name', 'description', 'creatorId'])
        && validLength(request.resource.data.name, 100)
        && validLength(request.resource.data.description, 500);
      // S1 FIX: Adding/removing adminIds requires caller to already be in adminIds.
      allow update: if isAuthenticated()
        && (resource.data.creatorId == request.auth.uid
          || request.auth.uid in resource.data.get('adminIds', []))
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['creatorId'])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['adminIds'])
          || request.auth.uid in resource.data.get('adminIds', [])
        );
      allow delete: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;
      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && (resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/arkCommunities/$(communityId)).data.creatorId == request.auth.uid);
      }
      match /posts/{postId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && callerAccountActive()
          && request.resource.data.authorId == request.auth.uid
          && (exists(/databases/$(database)/documents/arkCommunities/$(communityId)/members/$(request.auth.uid))
              || get(/databases/$(database)/documents/arkCommunities/$(communityId)).data.creatorId == request.auth.uid);
        allow update: if isAuthenticated()
          && callerAccountActive()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['content', 'visibility', 'updatedAt', 'editedAt', 'title', 'tags']);
        allow delete: if isAuthenticated()
          && (resource.data.authorId == request.auth.uid
            || get(/databases/$(database)/documents/arkCommunities/$(communityId)).data.creatorId == request.auth.uid);
      }
    }
    match /reports/{reportId} {
      allow read: if isAuthenticated()
        && (resource == null || resource.data.reporterId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid
        && hasRequiredFields(['reporterId', 'reportedContentId', 'reason'])
        && request.resource.data.reason in [
          'spam', 'harassment', 'inappropriate', 'other',
          'Inappropriate content', 'Spam', 'Harassment', 'Hate speech',
          'False information', 'Violence', 'Self-harm', 'Adult content',
          'Privacy violation', 'Other'
        ];
      allow update: if isAuthenticated()
        && resource.data.reporterId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'reporterId', 'reportedContentId', 'reason'
        ]);
      allow delete: if false;
    }
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['read', 'readAt', 'seenAt', 'openedAt', 'dismissedAt']);
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }
    match /toneAnalytics/{analyticsId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }
    match /moderationQueue/{queueId} {
      allow read: if isAuthenticated()
        && isAdmin();
      allow create: if false;
      allow update: if isAuthenticated()
        && isAdmin()
        && isOnlyUpdating(['status', 'handledBy', 'handledAt', 'notes', 'updatedAt']);
      allow delete: if false;
    }
    match /searchIndex/{indexType} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /analytics/{document=**} {
      allow read: if false;
      allow write: if false;
    }
    match /analytics_performance/{document=**} {
      allow read: if false;
      allow write: if false;
    }
    match /admin/{document=**} {
      allow read: if false;
      allow write: if false;
    }
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.creatorId == request.auth.uid
        && hasRequiredFields(['title', 'description', 'creatorId', 'date']);
      allow update: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;
      match /attendees/{userId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }
    }
    match /prayerRequests/{prayerId} {
      allow read: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid
            || resource.data.get('isPublic', false) == true);
      allow create: if isAuthenticated()
        && callerIsEmailVerified()
        && request.resource.data.authorId == request.auth.uid
        && hasRequiredFields(['content', 'authorId', 'authorName'])
        && validLength(request.resource.data.content, 1000);
      allow update: if isAuthenticated()
        && resource.data.authorId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['authorId', 'userId']);
      allow delete: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;
      match /prayers/{prayId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }
    }
    match /testimonies/{testimonyId} {
      allow read: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid
            // Safety fix: testimonies default PRIVATE (not public) to protect personal spiritual narratives.
            || resource.data.get('isPublic', false) == true);
      allow create: if isAuthenticated()
        && callerIsEmailVerified()
        && request.resource.data.authorId == request.auth.uid
        && hasRequiredFields(['content', 'authorId', 'authorName'])
        && validLength(request.resource.data.content, 2000);
      allow update: if isAuthenticated()
        && resource.data.authorId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['authorId', 'userId']);
      allow delete: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;
      match /amens/{amenId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }
    }
    match /featureFlags/{flagId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /user-reposts/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
      match /reposts/{repostId} {
        allow get: if isAuthenticated();
        allow list: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    match /savedPosts/{saveId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }
    match /reposts/{repostId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }
    // NOTE: The authoritative Church Notes rules — including AI-field write
    // blocking, collaborator support, and per-subcollection access — live in
    // the second `/churchNotes/{noteId}` block further down in this file.
    // This earlier match is kept tightly restricted so its OR-merge with the
    // authoritative rules cannot weaken security. Update + delete here require
    // the same allowlist of safe client fields as the authoritative rules.
    match /churchNotes/{noteId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
            || resource.data.get('isPublic', false) == true);
      allow create: if isAuthenticated()
        && callerIsEmailVerified()
        && request.resource.data.userId == request.auth.uid
        && !request.resource.data.keys().hasAny([
             'summaryDraft', 'transcriptText', 'ocrText', 'studyGuideDraft',
             'prayerPromptsDraft', 'actionItemsDraft', 'scriptureReferencesDraft',
             'translationDraft', 'approved_summaryDraft', 'approved_transcriptText',
             'approved_ocrText', 'approved_studyGuideDraft', 'approved_prayerPromptsDraft'
           ]);
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && churchNoteAllowedUpdateFields();
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }
    match /fcmQueue/{queueId} {
      allow read, write: if false;
    }
    match /mutedUsers/{muteId} {
      allow read: if isAuthenticated()
        && (resource == null || resource.data.userId == request.auth.uid);
