// ============================================================================
// firestore.verification.rules
//
// Amen Verification & Trust System — Firestore Security Rules
//
// HOW TO INTEGRATE:
//   Add all match blocks and helper functions inside the existing
//   "match /databases/{database}/documents" block in firestore 18.rules.
//
//   1. Add the helper functions (isVerificationAdmin, isOrgAdmin,
//      verificationTruthFields, clientIsNotWritingVerificationTruth)
//      to the existing helper function section near the top of the rules file.
//
//   2. Add each match block to the appropriate place in the document tree.
//
//   3. CRITICAL — integrate clientIsNotWritingVerificationTruth() into the
//      existing users/{userId} allow update rule:
//
//      BEFORE:
//        allow update: if isOwner(userId)
//          && !request.resource.data.diff(resource.data)
//               .affectedKeys().hasAny(premiumProtectedUserFields());
//
//      AFTER:
//        allow update: if isOwner(userId)
//          && !request.resource.data.diff(resource.data)
//               .affectedKeys().hasAny(premiumProtectedUserFields())
//          && clientIsNotWritingVerificationTruth();
//
//      This prevents any client — even a legitimately authenticated one —
//      from setting identityVerified, creatorVerified, emailVerified,
//      phoneVerified, safetyStanding, visibleBadges, or
//      publicVerificationSummary directly. All of these fields are owned
//      exclusively by the backend (Admin SDK) and the verification
//      Cloud Functions.
// ============================================================================


// ============================================================================
// SECTION 1 — Helper functions
// (Add these to the helpers section in firestore 18.rules)
// ============================================================================

// Returns true if the caller holds the 'admin' JWT custom claim.
// Avoids a per-request Firestore get() — same pattern as the existing isAdmin().
function isVerificationAdmin() {
  return isAuthenticated() && request.auth.token.get('admin', false) == true;
}

// Returns true if the authenticated caller is an admin member of the given org.
// Performs a single get() against organizations/{orgId}/members/{uid}.
function isOrgAdmin(orgId) {
  return isAuthenticated()
    && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
    && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == 'admin';
}

// The set of fields that constitute verification truth — these must NEVER be
// writable by clients directly. Mutations are only permitted via the Admin SDK
// (Cloud Functions) which bypasses these rules entirely.
function verificationTruthFields() {
  return [
    'identityVerified',
    'creatorVerified',
    'emailVerified',
    'phoneVerified',
    'safetyStanding',
    'visibleBadges',
    'publicVerificationSummary'
  ];
}

// Guard to be AND'd into users/{userId} allow update.
// Returns true only when the client is NOT touching any verification truth field.
// This is the last line of defence against client-side verification spoofing.
function clientIsNotWritingVerificationTruth() {
  return !request.resource.data.diff(resource.data)
    .affectedKeys()
    .hasAny(verificationTruthFields());
}


// ============================================================================
// SECTION 2 — Match blocks
// (Add these inside the existing match /databases/{database}/documents block)
// ============================================================================

// ── Private identity verification data ──────────────────────────────────────
// Raw verification results and provider references are stored here.
// Only the account owner and verification admins may read.
// Writes are backend-only (Admin SDK bypasses these rules).
match /users/{userId}/privateVerification/{doc} {
  allow read: if isOwner(userId) || isVerificationAdmin();
  allow write: if false; // Backend/Admin SDK only — never client-writable
}

// ── User verification requests ───────────────────────────────────────────────
// Users may submit new requests and read their own.
// Status transitions (approve, reject, revoke) are backend-only.
// The create allowlist intentionally excludes 'status', 'safeUserReason', and
// 'privateReviewerNotes' so clients cannot pre-populate admin-owned fields.
match /users/{userId}/verificationRequests/{requestId} {
  allow read: if isOwner(userId) || isVerificationAdmin();
  allow create: if isOwner(userId)
    && request.resource.data.keys().hasAll(['type', 'createdAt'])
    && !request.resource.data.keys().hasAny([
        'status',
        'safeUserReason',
        'privateReviewerNotes',
        'sessionToken',       // never client-provided
        'sessionTokenHash',   // server-generated only
        'providerReferenceId' // server-generated only
      ]);
  allow update, delete: if false; // Backend only — status changes are server-authoritative
}

// ── Organization public verification summary ─────────────────────────────────
// Public read — any visitor may check whether an org is verified.
// Writes are backend-only; clients can never self-approve.
match /organizations/{orgId}/publicVerificationSummary/{summaryDoc} {
  allow read: if true;
  allow write: if false; // Backend only
}

// ── Organization private verification data ───────────────────────────────────
// Contains domain challenge tokens and KYC results for the organization.
// Only org admins and verification admins may read.
match /organizations/{orgId}/privateVerification/{doc} {
  allow read: if isOrgAdmin(orgId) || isVerificationAdmin();
  allow write: if false; // Backend only
}

// ── Organization verification requests ───────────────────────────────────────
// Org admins may read their org's requests. Writes are backend-only.
match /organizations/{orgId}/verificationRequests/{requestId} {
  allow read: if isOrgAdmin(orgId) || isVerificationAdmin();
  allow write: if false; // Backend only
}

// ── Organization role records ─────────────────────────────────────────────────
// The role record is the source of truth for a member's verified role.
// Members may read their own record; org admins may read all; writes backend-only.
match /organizations/{orgId}/roles/{memberId} {
  allow read: if isOwner(memberId) || isOrgAdmin(orgId) || isVerificationAdmin();
  allow write: if false; // Backend only — issued and revoked exclusively by Cloud Functions
}

// ── Verification audit logs ───────────────────────────────────────────────────
// Append-only via Admin SDK. No client writes. Admins may read for audit trails.
// The Admin SDK bypasses these rules; the 'write: false' guard blocks any client
// that would attempt a direct SDK write.
match /verificationAuditLogs/{logId} {
  allow read: if isVerificationAdmin();
  allow write: if false; // Backend only — audit logs must not be tampered with
}

// ── Impersonation reports ─────────────────────────────────────────────────────
// Authenticated users may file a report. The reporterUid field is set exclusively
// by the server (the create rule explicitly blocks it from the client payload).
// Only verification admins may read, update, or delete reports.
match /impersonationReports/{reportId} {
  allow create: if isAuthenticated()
    && request.resource.data.keys().hasAll(['targetUid', 'reason', 'status', 'createdAt'])
    && request.resource.data.targetUid != request.auth.uid  // can't report yourself
    && request.resource.data.status == 'open'
    && request.resource.data.reason is string
    && request.resource.data.reason.size() > 0
    && request.resource.data.reason.size() <= 500
    && !request.resource.data.keys().hasAny(['reporterUid']); // server sets this field — client must not provide it
  allow read, update, delete: if isVerificationAdmin();
}

// ── Moderation queue (verification-sourced entries) ──────────────────────────
// The backend writes impersonation-report entries here for human review.
// Clients have no direct access to this collection.
match /moderationQueue/{entryId} {
  allow read: if isModerator();
  allow write: if false; // Backend only
}


// ============================================================================
// SECTION 3 — Integration note for existing users/{userId} rule
// ============================================================================
//
// Find the existing users/{userId} allow update rule (roughly):
//
//   match /users/{userId} {
//     allow update: if isOwner(userId)
//       && !request.resource.data.diff(resource.data)
//              .affectedKeys().hasAny(premiumProtectedUserFields());
//   }
