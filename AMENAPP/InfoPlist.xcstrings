    "NSHealthUpdateUsageDescription" : {
      "comment" : "Privacy - Health Update Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "قد يسجّل AMEN دقائق اليقظة الذهنية من جلسات الصلاة والتأمل في Apple Health، مما يساعدك على تتبع عافيتك الروحية إلى جانب صحتك الجسدية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN pot registrar minuts de consciència plena de les sessions de pregària i meditació a Apple Health, per ajudar-te a fer un seguiment del teu benestar espiritual juntament amb la teva salut física."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN může do aplikace Apple Health zaznamenávat minuty všímavosti z modliteb a meditací, abyste mohli sledovat svou duchovní pohodu spolu s fyzickým zdravím."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN kan registrere minutter med mindfulness fra bøn og meditation i Apple Health, så du kan følge dit åndelige velvære sammen med dit fysiske helbred."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN kann Achtsamkeitsminuten aus Gebets- und Meditationssitzungen in Apple Health protokollieren, damit du dein spirituelles Wohlbefinden gemeinsam mit deiner körperlichen Gesundheit verfolgen kannst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Το AMEN μπορεί να καταγράφει λεπτά ενσυνειδητότητας από συνεδρίες προσευχής και διαλογισμού στο Apple Health, βοηθώντας σας να παρακολουθείτε την πνευματική σας ευεξία παράλληλα με τη σωματική σας υγεία."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "AMEN may log mindfulness minutes from prayer and meditation sessions to Apple Health, helping you track your spiritual wellness alongside your physical health."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN may log mindfulness minutes from prayer and meditation sessions to Apple Health, helping you track your spiritual wellbeing alongside your physical health."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN puede registrar en Salud de Apple los minutos de plenitud mental de tus sesiones de oración y meditación, ayudándote a seguir tu bienestar espiritual junto con tu salud física."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN puede registrar en Apple Salud los minutos de plenitud mental de tus sesiones de oración y meditación, lo que te ayuda a llevar un seguimiento de tu bienestar espiritual junto con tu salud física."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN voi kirjata rukous- ja meditaatiohetkien tietoisuusminuutit Apple Healthiin, jotta voit seurata hengellistä hyvinvointiasi fyysisen terveytesi rinnalla."
