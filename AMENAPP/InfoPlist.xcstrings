    "NSAppleMusicUsageDescription" : {
      "comment" : "Privacy - Media Library Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "يستخدم AMEN تطبيق Apple Music لتشغيل أغاني العبادة في Church Notes الخاصة بك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN utilitza Apple Music per reproduir cançons de lloança a les teves Church Notes."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN používá Apple Music k přehrávání chválicích písní ve vašich poznámkách Church Notes."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN bruger Apple Music til at afspille lovsange i dine Church Notes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN nutzt Apple Music, um Lobpreislieder in deinen Church Notes abzuspielen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Το AMEN χρησιμοποιεί το Apple Music για την αναπαραγωγή ύμνων λατρείας στις Church Notes σας."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "AMEN uses Apple Music to play worship songs in your Church Notes."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN uses Apple Music to play worship songs in your Church Notes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN usa Apple Music para reproducir canciones de alabanza en tus Church Notes."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN usa Apple Music para reproducir canciones de adoración en tus Church Notes."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN käyttää Apple Musicia ylistyslaulujen toistamiseen Church Notes -muistiinpanoissasi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN utilise Apple Music pour lire des chants de louange dans vos Church Notes."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN utilise Apple Music pour faire jouer des chants de louange dans vos Church Notes."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN משתמשת ב-Apple Music כדי להשמיע שירי הלל ב״Church Notes״."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN आपके Church Notes में आराधना गीत चलाने के लिए Apple Music का उपयोग करता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN koristi Apple Music za reprodukciju pjesama hvale u vašim bilješkama Church Notes."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Az AMEN az Apple Music szolgáltatást használja, hogy dicsőítő dalokat játsszon le a Church Notes jegyzeteidben."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN menggunakan Apple Music untuk memutar lagu pujian di Church Notes Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN usa Apple Music per riprodurre canti di lode nei tuoi Church Notes."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMENは、Apple Musicを使用して、Church Notes内で礼拝の楽曲を再生します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN은 Apple Music을 사용하여 Church Notes에서 찬양곡을 재생합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AMEN menggunakan Apple Music untuk memainkan lagu penyembahan dalam Church Notes anda."
          }
