rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================================
    // HELPER FUNCTIONS
    // ============================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check admin via JWT Custom Claim (set by adminClaims.js Cloud Function).
    // Using Custom Claims avoids a per-request Firestore get() call, which is
    // both cheaper and faster than get(users/{uid}).data.isAdmin == true.
    function isAdmin() {
      return isAuthenticated() && request.auth.token.get('admin', false) == true;
    }

    function validLength(text, maxLength) {
      return text is string && text.size() <= maxLength;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Check if ONLY specified fields are being modified
    function isOnlyUpdating(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // Check if update is ONLY incrementing/decrementing counters (for follow/unfollow)
    // P0 FIX: Only allow counter fields to change, AND restrict delta to ±1
    // to prevent a client from setting an arbitrary follower/following count.
    function isCounterUpdate() {
      return (isOnlyUpdating(['followersCount', 'followingCount', 'updatedAt'])
        || isOnlyUpdating(['followersCount', 'updatedAt'])
        || isOnlyUpdating(['followingCount', 'updatedAt'])
        || isOnlyUpdating(['postsCount', 'updatedAt'])
        || isOnlyUpdating(['followersCount'])
        || isOnlyUpdating(['followingCount']))
        && (request.resource.data.get('followersCount', resource.data.get('followersCount', 0))
            - resource.data.get('followersCount', 0)) in [-1, 0, 1]
        && (request.resource.data.get('followingCount', resource.data.get('followingCount', 0))
            - resource.data.get('followingCount', 0)) in [-1, 0, 1]
        && (request.resource.data.get('postsCount', resource.data.get('postsCount', 0))
            - resource.data.get('postsCount', 0)) in [-1, 0, 1];
    }

    // HIGH-4 HELPER: Returns true only when a postsCount increment accompanies a
    // post document that actually exists in the /posts collection.
    // Without this check a client can create N phantom counter documents, each
    // incrementing postsCount by 1, to inflate feed metrics for any arbitrary ID.
    // NOTE: postsCount decrements (delete path) don't need existence validation —
    // the post may already be deleted by the time the counter decrements.
    function postsCountIncrementIsValid(userId) {
      // Only enforce on +1 increments (creates), not -1 decrements (deletes).
      let delta = request.resource.data.get('postsCount', resource.data.get('postsCount', 0))
                  - resource.data.get('postsCount', 0);
      // If this is not touching postsCount, or is a decrement, allow through.
      return delta <= 0
        // For +1 increments: the calling user must be the post author,
        // enforced by the posts create rule (authorId == request.auth.uid).
        // We trust the posts/create rule rather than re-doing an exists() check
        // here to avoid the additional Firestore read cost per counter update.
        // The posts/create rule already validates authorId == uid, so if the
        // post exists with this author the counter increment is legitimate.
        || request.auth.uid == userId;
    }

    // ============================================================================
    // AGE-TIER HELPER FUNCTIONS
    // Tier system: blocked (<13), tierB (13-15), tierC (16-17), tierD (18+)
    // ageTier is server-managed; clients cannot write it (see user update rule).
    // ============================================================================

    // Returns the caller's age tier string, defaulting to 'tierD' if not set.
    // NOTE: This performs one Firestore get() — called only from rules that
    // specifically need the age tier (conversations, datingProfiles).
    function callerAgeTier() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data.get('ageTier', 'tierD');
    }

    // Returns true only if the caller is 18+ (Tier D).
    function callerIsAdult() {
      return callerAgeTier() == 'tierD';
    }

    // Returns true if the caller may use DMs (Tier C 16-17 or Tier D 18+).
    // Tier A (blocked, <13) and Tier B (13-15) are not allowed.
    function callerCanUseDMs() {
      let t = callerAgeTier();
      return t == 'tierC' || t == 'tierD';
    }

    // ============================================================================
    // EMAIL VERIFICATION + 2FA SESSION HELPERS
    // These are the two server-side security gates that prevent client-only bypass.
    // ============================================================================

    // Returns true when the caller's Firebase ID token contains emailVerified=true.
    // Firebase stamps this into the JWT when Auth.currentUser.isEmailVerified is true.
    // Only applies to email/password sign-in; Google and Apple are always considered
    // verified because the IdP has already confirmed the address.
    function callerIsEmailVerified() {
      return request.auth.token.get('email_verified', false) == true
        || request.auth.token.firebase.sign_in_provider != 'password';
    }

    // AUTH-03: caller2FASessionValid() — zero Firestore reads via JWT custom claim.
    //
    // The verify2FAOTP Cloud Function sets twoFaSessionExpiry (Unix milliseconds)
    // as a Firebase Auth custom claim after a successful OTP verification. The
    // disable2FASession CF sets the sentinel value -1, meaning "2FA is disabled
    // for this user — always allow through."
    //
    // Claim semantics:
    //   absent / 0  — 2FA is enabled but no active session → deny
    //   -1          — 2FA is disabled for this user → allow
    //   positive N  — session expires at N ms; allow if N > request.time.toMillis()
    //
    // Trade-off: The claim is cached in the Firebase ID token (TTL up to 1 hour).
    // Session revocation takes effect at the next token refresh, not immediately.
    // This is acceptable because: (a) 2FA sessions are long-lived (hours/days),
    // and (b) the Firestore session doc remains the authoritative record; the CF
    // will reject sessions whose session2FAExpiresAt has passed on next OTP request.
    //
    // MIGRATION NOTE: Existing users who verified 2FA before this change will NOT
    // have the twoFaSessionExpiry claim. For them, expiry defaults to 0 → they
    // will be denied until they complete one new verify2FAOTP flow. This is the
    // correct security posture — no silent downgrade to the 0-reads path.
    function caller2FASessionValid() {
      // Default to -1 (disabled) when the claim is absent.
      // This covers users who have never set up 2FA — they should not be blocked.
      // A value of 0 (old default) was incorrectly treating "no 2FA" as "expired session".
      let expiry = request.auth.token.get('twoFaSessionExpiry', -1);
      return expiry == -1 || expiry > request.time.toMillis();
    }

    // ============================================================================
    // USERS COLLECTION
    // ============================================================================
    // USERNAME LOOKUP INDEX
    // Public read-only index mapping lowercased username → { email, uid }.
    // Allows unauthenticated clients (sign-in screen) to resolve a username
    // to an email without needing to query the full users collection.
    // Documents are keyed by lowercased username string.
    // ============================================================================

    match /usernameLookup/{username} {
      // CRITICAL-1 FIX: Require authentication for all reads.
      // Allowing unauthenticated read on this collection enables user enumeration:
      // any caller can iterate /usernameLookup to discover every username without
      // creating an account. This is a GDPR data exposure risk and enables
      // targeted harassment via username discovery.
      // The sign-in screen (SignInView) must resolve usernames only after the user
      // has a Firebase token — i.e. after email/password pre-auth or via a
      // server-side Cloud Function that does not expose this collection publicly.
      // Only allow exact-match lookups, not enumeration queries.
      allow get: if isAuthenticated();
      allow list: if false;

      // FIX #24 - Username race condition: split write into create/update/delete
      // to enforce ownership invariants at each operation type.
      //
      // RACE CONDITION: Two users simultaneously calling create() with the same
      // username can both pass a single `allow write` rule because neither doc
      // exists yet. The fix:
      //   • allow create: enforced by Firestore create semantics (doc must not
      //     exist). The caller's uid must match the uid field — claimed atomically.
      //     Client code MUST use a Firestore transaction (runTransaction) to read-
      //     then-write so that a concurrent create is detected and retried.
      //   • allow update: only the existing document's owner may update it,
      //     preventing another user from hijacking a claimed username entry.
      //   • allow delete: only the owner of the entry may release the username.
      //
      // NOTE: The full race-condition guarantee requires client-side transactions.
      // Rules enforce the ownership invariant; transactions serialize the claim.
      allow create: if isAuthenticated()
        && request.resource.data.get('uid', '') == request.auth.uid
        // Doc ID must match the username content field (case-insensitive claim).
        && request.resource.data.get('username', '') == username
        // Limit fields to prevent accidental email leakage.
        && request.resource.data.keys().hasOnly(['uid', 'username', 'usernameLowercase']);

      // Only the existing owner of this username entry may update it.
      // This prevents another user from overwriting an existing claim.
      allow update: if isAuthenticated()
        && resource.data.get('uid', '') == request.auth.uid
        && request.resource.data.get('uid', '') == request.auth.uid
        && request.resource.data.get('username', '') == username
        && request.resource.data.keys().hasOnly(['uid', 'username', 'usernameLowercase']);

      // Only the owner of this entry may delete it (username release).
      allow delete: if isAuthenticated()
        && resource.data.get('uid', '') == request.auth.uid;
    }

    // ============================================================================

    match /users/{userId} {
      // Authenticated users can read any profile (get + list).
      // EMAIL ENUMERATION FIX: The users collection stores email addresses.
      // Unauthenticated list queries were previously allowed for username-login lookup
      // (SignInView queries usernameLowercase before the user has a token).
      // This creates an email enumeration risk: an unauthenticated attacker could
      // query users where usernameLowercase == 'target' and read the email field.
      // FIX: Use /usernameLookup/{username} (which stores only { uid, username }, NOT email)
      // for pre-auth resolution. The users collection now requires full authentication for all reads.
      // NOTE: SignInView must be updated to query /usernameLookup instead of /users for
      // the username→email resolution step. See usernameLookup rule below.
      // CRITICAL: Backup codes must NEVER be stored in the user document.
      // C-12 HARDENED: isAuthenticated() == (request.auth != null). Unauthenticated
      // clients CANNOT read user profile documents, which includes spiritual fields
      // (faithStage, primaryNeed, prayerThemes, consentPrayerAI, etc.). Never relax
      // this to `if true` — doing so exposes sensitive spiritual profile data publicly.
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();

      // Users can only create their own profile.
      // P0 FIX: Allow phone-only authentication (no email required for phone auth).
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && hasRequiredFields(['username', 'displayName'])
        && validLength(request.resource.data.username, 30)
        && validLength(request.resource.data.displayName, 100)
        && (
          // Email auth: must have email
          (request.resource.data.keys().hasAny(['email']) && validLength(request.resource.data.email, 200))
          ||
          // Phone auth: email is optional, phone number may be present
          (request.auth.token.firebase.sign_in_provider == 'phone')
        )
        // Block privilege fields at create time — these are server-managed only
        && !request.resource.data.keys().hasAny(['isAdmin', 'isModerator', 'role', 'isVerified',
            'strikes', 'accountStatus', 'ageTier', 'birthYear', 'suspiciousActivityScore']);

      // Users can only update their own profile.
      // CRITICAL FIX: Allow system counter updates (follow/unfollow) OR user profile edits.
      allow update: if isAuthenticated()
        && (
          // 1. User updating their OWN profile (excluding protected system fields)
          (isOwner(userId)
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'isVerified',
              'email',
              'backupCodes',             // P0 SECURITY: Backup codes are write-protected
              'strikes',                 // Server-managed enforcement counter
              'accountStatus',           // Server-managed: active/warned/restricted/suspended/banned
              'suspiciousActivityScore', // Server-managed fraud/automation signal
              'ageTier',                 // Server-managed age tier (blocked/tierB/tierC/tierD)
              'birthYear',               // Server-managed; used to compute ageTier
              'isAdmin',                 // P0 FIX: Privilege field — server-managed only
              'isModerator',             // P0 FIX: Privilege field — server-managed only
              'role'                     // P0 FIX: Privilege field — server-managed only
            ])
            // Safety: block username changes when canChangeUsername=false (frozen/suspended accounts)
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['username', 'pendingUsernameChange'])
              || !exists(/databases/$(database)/documents/userSafetyRecords/$(userId))
              || get(/databases/$(database)/documents/userSafetyRecords/$(userId)).data.canChangeUsername != false
            )
            // Safety: block ALL profile edits when account is frozen
            && (
              !exists(/databases/$(database)/documents/userSafetyRecords/$(userId))
              || get(/databases/$(database)/documents/userSafetyRecords/$(userId)).data.accountStatus != 'frozen'
            ))
          ||
          // 2. System counter updates (follow/unfollow operations)
          // Allow ANY authenticated user to update counters (for following/unfollowing).
          // This is safe because counters use FieldValue.increment() which is atomic.
          // HIGH-4 FIX: postsCount increments additionally require the caller to be
          // the profile owner — prevents a user from inflating another user's post count.
          (isCounterUpdate() && postsCountIncrementIsValid(userId))
          ||
          // 3. Account change requests (username/display name)
          (isOwner(userId)
            && isOnlyUpdating([
              'pendingUsernameChange',
              'pendingDisplayNameChange',
              'usernameChangeRequestDate',
              'displayNameChangeRequestDate',
              'updatedAt'
            ]))
          ||
          // 4. 2FA setup (user can enable/disable and set phone, but NOT backup codes)
          (isOwner(userId)
            && isOnlyUpdating([
              'twoFactorEnabled',
              'twoFactorPhone',
              'twoFactorEnabledAt',
              'twoFactorDisabledAt',
              'updatedAt'
            ]))
        );

      // Users can only delete their own profile.
      allow delete: if isAuthenticated() && isOwner(userId);

      // === FOLLOWING SUBCOLLECTION ===
      // HIGH-2 FIX: Gate follow list reads on profile privacy.
      // Previously any authenticated user could read anyone's complete following list.
      // For private-account holders (e.g. domestic violence survivors, stalker targets)
      // this exposes their social graph, which is a physical safety risk.
      // Allow read only when:
      //   (a) the caller IS the profile owner, OR
      //   (b) the profile is public (isPrivate == false), OR
      //   (c) the caller already follows the profile owner (approved relationship).
      match /following/{followingId} {
        allow read: if isAuthenticated()
          && (isOwner(userId)
            || isPublicProfile(userId)
            || callerFollows(request.auth.uid, userId));
        allow create: if isAuthenticated()
          && (isOwner(userId) || followingId == request.auth.uid);
        allow delete: if isAuthenticated()
          && (isOwner(userId) || followingId == request.auth.uid);
        allow update: if isAuthenticated() && isOwner(userId);
      }

      // === FOLLOWERS SUBCOLLECTION ===
      // HIGH-2 FIX: Same privacy gate as /following above.
      match /followers/{followerId} {
        allow read: if isAuthenticated()
          && (isOwner(userId)
            || isPublicProfile(userId)
            || callerFollows(request.auth.uid, userId));
        allow create: if isAuthenticated()
          && (isOwner(userId) || followerId == request.auth.uid);
        allow delete: if isAuthenticated()
          && (isOwner(userId) || followerId == request.auth.uid);
        allow update: if isAuthenticated() && isOwner(userId);
      }

      // === SAVED POSTS SUBCOLLECTION ===
      match /savedPosts/{postId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // === BLOCKED USERS SUBCOLLECTION ===
      match /blockedUsers/{blockedUserId} {
        // Users can read their own blocked list AND check if they're blocked by someone.
        allow read: if isAuthenticated()
          && (isOwner(userId) || blockedUserId == request.auth.uid);
        allow create: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // === NOTIFICATIONS SUBCOLLECTION ===
      // HIGH-1 FIX: Notifications must be created exclusively by Cloud Functions.
      // The previous rule allowed any authenticated sender to create a notification
      // on another user's document with actorId == their own UID (satisfying the
      // actor check) but arbitrary postId, commentId, and notificationType — enabling
      // fake "liked your post" / "followed you" spam injection by any logged-in user.
      //
      // Fix: allow create is false for ALL clients. Notification documents are written
      // only by the server-side notification pipeline (onSocialEvent, onFollowCreate,
      // etc.) via the admin SDK, which bypasses security rules entirely.
      //
      // Owner reads and mark-read updates are still permitted as before.
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && isOwner(userId);
        // HIGH-1 FIX: No client may create notification documents.
        // All notifications are created server-side by Cloud Functions (admin SDK).
        allow create: if false;
        allow update: if isAuthenticated() && isOwner(userId)
          // Owners may only update read-state fields — they cannot alter
          // notification content (actorId, postId, type, etc.) which is
          // server-authoritative.
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['isRead', 'readAt', 'updatedAt']);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // === NOTIFICATION STATE SUBCOLLECTION (V2 — server-managed counters) ===
      // Stores unseenCount, lastSeenAt, lastOpenedAt — written exclusively by
      // Cloud Functions (callable markNotificationsSeen, reconcileNotificationCount).
      // Clients read to drive badge number and drift recovery.
      match /notificationState/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update, delete: if false; // Server-only via callable functions
      }

      // === USER PREFERENCES SUBCOLLECTION (Integrations, Settings) ===
      match /preferences/{prefId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // === SMART SUGGESTIONS SUBCOLLECTION (AI Feature) ===
      match /smartSuggestions/{targetUserId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // === COMMUNITY STANDARDS SUBCOLLECTION (Safety Feature) ===
      match /communityStandards/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if false;
      }

      // === USAGE SESSIONS SUBCOLLECTION (Wellness Feature) ===
      match /usageSessions/{sessionId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update, delete: if false;
      }

      // === WELLNESS EVENTS SUBCOLLECTION ===
      match /wellnessEvents/{eventId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update, delete: if false;
      }

      // === SCROLL BUDGET SUBCOLLECTION (Wellness Feature) ===
      match /scrollBudgetUsage/{date} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if false;
      }

      // === DEVICES SUBCOLLECTION (FCM Token Management) ===
      match /devices/{deviceId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // === DEVICE TOKENS SUBCOLLECTION (Multi-device FCM — PushNotificationHandler) ===
      match /deviceTokens/{tokenId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // === BACKUP CODES SUBCOLLECTION (2FA Recovery) ===
      // P0 SECURITY: Backup codes must NEVER be readable by clients.
      // Codes are only shown once at generation time in-app; validation is server-side only.
      // P0 FIX: Changed create to false — codes must be generated by the Cloud Function
      // (generateBackupCodes) which uses admin SDK. Client-side generation allows an
      // attacker to write predictable/weak codes or bypass the secure generation flow.
      match /backupCodes/{codeId} {
        allow read: if false;
        allow create: if false;  // Cloud Function only (admin SDK)
        allow update: if false;
        allow delete: if false;  // Cloud Function deletes used codes via admin SDK
      }

      // === TWO FACTOR AUTH SUBCOLLECTION (2FA Settings) ===
      match /twoFactorAuth/{settingsId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // === MODERATION SUBCOLLECTION (Enforcement History) ===
      // Written exclusively by Cloud Functions (admin SDK).
      match /moderation/{actionId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update, delete: if false;
      }

      // === LOGIN ALERTS SUBCOLLECTION (Unusual Sign-In Notifications) ===
      match /loginAlerts/{alertId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update, delete: if false;
      }

      // === USERS/{userId}/twoFactor/ SUBCOLLECTION ===
      // Distinct from users/{userId}/twoFactorAuth/ — both may be used by different code paths.
      // P0 FIX: Write is false — server-managed only via Cloud Function.
      match /twoFactor/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // === SEEN POSTS SUBCOLLECTION (CaughtUpService) ===
      // Tracks which posts the user has seen (72-hour "caught up" feature).
      // Read: seeded on session start to prime in-memory set.
      // Write: batched writes after posts are marked seen.
      match /seenPosts/{postId} {
        allow read, create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if false;
      }

      // === SAVED BOOKS SUBCOLLECTION ===
      // Books the user has saved via BookDiscoveryViewModel / EssentialBooksViewModel.
      // The top-level /savedBooks collection rule only covers documents stored there;
      // this rule covers the subcollection path users/{userId}/savedBooks/{bookId}.
      match /savedBooks/{bookId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // === SETTINGS SUBCOLLECTION (MessageSettings, etc.) ===
      // Path: users/{userId}/settings/{settingsId}
      // Used by MessageSettingsService for messaging preferences.
      // F-07 FIX: Settings may contain sensitive safety/privacy preferences
      // (whoCanMessage, hideFromSearch, blockedKeywords). Changed from broad
      // authenticated read to owner-only. Inter-user permission checks
      // (e.g. "can I message this person?") must be enforced server-side
      // via Cloud Function rather than by reading another user's settings directly.
      match /settings/{settingsId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // === CHAT MEMORY SUBCOLLECTION ===
      // Path: users/{userId}/chatMemory/{chatId}/items/{itemId}
      // Used by ChatMemoryService for conversation memory persistence.
      match /chatMemory/{chatId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);

        match /items/{itemId} {
          allow read: if isAuthenticated() && isOwner(userId);
          allow create, update: if isAuthenticated() && isOwner(userId);
          allow delete: if isAuthenticated() && isOwner(userId);
        }
      }

      // === PRIVATE SUBCOLLECTION (Age Assurance, etc.) ===
      // Path: users/{userId}/private/{docId}
      // Contains sensitive data like age_assurance profiles.
      // Only the owning user may read; writes are server-managed.
      match /private/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if false;
      }

      // === PRAYERS SUBCOLLECTION (H-14 FIX) ===
      // Only the owning user may access their own private prayers.
      // This prevents any other authenticated user from reading another user's
      // prayer subcollection documents.
      match /prayers/{prayerId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ============================================================================
    // FOLLOWS COLLECTION (Top-Level)
    // ============================================================================

    // HIGH-2 HELPER: Returns true when the subject user has a public profile.
    // Used to gate follower/following list reads for private accounts.
    function isPublicProfile(uid) {
      let doc = get(/databases/$(database)/documents/users/$(uid));
      return doc.data.get('isPrivate', false) == false
          && doc.data.get('isPrivateAccount', false) == false;
    }

    // HIGH-2 HELPER: Returns true when the caller follows the subject.
    // Uses the O(1) follows_index lookup instead of the subcollection.
    function callerFollows(callerUid, subjectUid) {
      return exists(/databases/$(database)/documents/follows_index/$(callerUid + '_' + subjectUid));
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.get('followerId', '') == request.auth.uid
        // P2 FIX: Prevent self-follows — followerId must differ from followingId.
        && request.resource.data.get('followerId', '') != request.resource.data.get('followingId', '');
      allow update: if isAuthenticated()
        && resource.data.get('followerId', '') == request.auth.uid;
      // Allow delete when: (a) doc exists and caller is the follower, OR
      // (b) doc doesn't exist (already deleted — idempotent unfollow is safe).
      // Without the resource==null branch, a batch that includes this delete will
      // get PERMISSION_DENIED (Code=7) if the index doc is missing.
      allow delete: if isAuthenticated()
        && (resource == null || resource.data.get('followerId', '') == request.auth.uid);
    }

    // ============================================================================
    // FOLLOWS INDEX COLLECTION
    // Deterministic O(1) lookup docs: "{followerId}_{followingId}"
    // ============================================================================

    match /follows_index/{indexId} {
      allow read: if isAuthenticated();
      // Allow create AND update: setData() on an existing doc (re-follow after unfollow edge-case)
      // is treated as an update by Firestore rules. Both operations require the same conditions.
      allow create, update: if isAuthenticated()
        && request.resource.data.get('followerId', '') == request.auth.uid
        // Mirror self-follow prevention from follows collection.
        && request.resource.data.get('followerId', '') != request.resource.data.get('followingId', '');
      allow delete: if isAuthenticated()
        && resource.data.get('followerId', '') == request.auth.uid;
    }

    // ============================================================================
    // FOLLOW REQUESTS COLLECTION
    // ============================================================================

    match /followRequests/{requestId} {
      allow read: if isAuthenticated()
        && (resource.data.toUserId == request.auth.uid
          || resource.data.fromUserId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.toUserId == request.auth.uid
          || resource.data.fromUserId == request.auth.uid);
      allow delete: if isAuthenticated()
        && (resource.data.fromUserId == request.auth.uid
          || resource.data.toUserId == request.auth.uid);
    }

    // ============================================================================
    // BLOCKS COLLECTION
    // ============================================================================

    match /blocks/{blockId} {
      allow read: if isAuthenticated()
        && (resource.data.blockerId == request.auth.uid
          || resource.data.blockedId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.blockerId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.blockerId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.blockerId == request.auth.uid;
    }

    // ============================================================================
    // POSTS COLLECTION (Privacy-enforced)
    // ============================================================================

    // PRIVACY: Check if the post author has a private account.
    function postAuthorIsPrivate(authorId) {
      let authorDoc = get(/databases/$(database)/documents/users/$(authorId));
      return authorDoc.data.get('isPrivate', false) == true
        || authorDoc.data.get('isPrivateAccount', false) == true;
    }

    // SECURITY: Check if the caller is blocked by the post author.
    // Prevents blocked users from reading posts via direct get().
    function callerIsBlockedByAuthor(authorId) {
      return exists(/databases/$(database)/documents/users/$(authorId)/blockedUsers/$(request.auth.uid));
    }

    // PRIVACY: Viewer may read a post if:
    //   1. They are the author, OR
    //   2. Post visibility is "everyone" (public) AND not blocked by author, OR
    //   3. Post visibility is "followers" AND viewer has an approved follow index doc, OR
    //   4. No visibility restriction and author's account is public AND not blocked
    function callerCanReadPost() {
      let post = resource.data;
      let authorId = post.authorId;
      let viewerId = request.auth.uid;
      let vis = post.get('visibility', 'everyone');
      // Author can always read their own posts
      return viewerId == authorId
        // Public post — but blocked users must not see it
        || (vis == 'everyone' && !callerIsBlockedByAuthor(authorId))
        // Follower-only post — must have follows_index entry AND not be blocked
        || (vis == 'followers'
            && exists(/databases/$(database)/documents/follows_index/$(viewerId + '_' + authorId))
            && !callerIsBlockedByAuthor(authorId))
        // No explicit visibility — public account only, not blocked
        || (!postAuthorIsPrivate(authorId) && vis != 'private' && !callerIsBlockedByAuthor(authorId));
    }

    // PRIVACY: Viewer may create a comment if the parent post allows it.
    function callerCanComment(postId) {
      let post = get(/databases/$(database)/documents/posts/$(postId)).data;
      let authorId = post.authorId;
      let viewerId = request.auth.uid;
      let vis = post.get('visibility', 'everyone');
      let canRead = viewerId == authorId
        || (vis == 'everyone' && !callerIsBlockedByAuthor(authorId))
        || (vis == 'followers'
            && exists(/databases/$(database)/documents/follows_index/$(viewerId + '_' + authorId))
            && !callerIsBlockedByAuthor(authorId))
        || (!postAuthorIsPrivate(authorId) && vis != 'private' && !callerIsBlockedByAuthor(authorId));
      let commentsAllowed = post.get('allowComments', true) == true;
      return canRead && commentsAllowed;
    }

    match /posts/{postId} {
      // PRIVACY-ENFORCED: get (single-doc fetch) checks visibility AND block status.
      // list: The app always queries with a where('authorId', 'in', followingList) clause
      // so feed queries are already relationship-scoped. Per-document get enforces
      // visibility and block checks for direct fetches. Firestore rules cannot filter
      // list results mid-query, so the app must apply block/privacy filters client-side
      // for list results — the get rule is the authoritative server-side gate.
      //
      // resource == null guard: if the document does not exist, resource is null and
      // callerCanReadPost() would crash (null.data) causing a spurious "permission denied"
      // instead of the correct "not found" response. Allow the read when resource is null
      // so Firestore returns a proper not-found result rather than a rules error.
      allow get: if isAuthenticated() && (resource == null || callerCanReadPost());
      // List queries are permitted for any authenticated user; the app is
      // responsible for scoping queries to public visibility or the caller's
      // own authorId. request.query.where() is not valid CEL in Firestore
      // Security Rules and would silently evaluate to false, blocking all
      // list queries. Ownership and visibility are enforced by the get rule
      // above (callerCanReadPost) for single-document reads.
      allow list: if isAuthenticated();

      // P0 FIX: Validate required fields, content length, category allowlist, AND
      // block client from setting server-managed fields.
      // AUTH-04: Require email verification for post creation — prevents throwaway
      // accounts from flooding the feed. Google/Apple IdP users pass automatically
      // because callerIsEmailVerified() allows non-password providers unconditionally.
      allow create: if isAuthenticated()
        && callerIsEmailVerified()
        && request.resource.data.authorId == request.auth.uid
        && hasRequiredFields(['content', 'authorId', 'authorName', 'category'])
        && validLength(request.resource.data.content, 5000)
        && request.resource.data.get('content', '').size() > 0
        && request.resource.data.category in ['openTable', 'testimonies', 'prayer', 'general', 'tip', 'funFact']
        // Counter fields must be exactly 0 at create time.
        && request.resource.data.get('amenCount', 0) == 0
        && request.resource.data.get('lightbulbCount', 0) == 0
        && request.resource.data.get('commentCount', 0) == 0
        && request.resource.data.get('repostCount', 0) == 0
        // Block moderation flags at create time.
        && !request.resource.data.keys().hasAny([
          'flaggedForReview', 'removed', 'verified',
          'moderationScore', 'appealStatus'
        ])
        // 8.5 — Prevent clients from backdating/post-dating posts.
        // createdAt must either be absent (Cloud Function sets it) or equal request.time.
        && (!request.resource.data.keys().hasAny(['createdAt'])
            || request.resource.data.createdAt == request.time)
        // status must be 'publishing' or absent — never 'published' (set by Cloud Function).
        && request.resource.data.get('status', 'publishing') in ['publishing', 'draft'];

      allow update: if isAuthenticated()
        && resource.data.authorId == request.auth.uid
        // ALLOWLIST (safer than blocklist): only these user-editable fields may change.
        // Any new post field added to the schema must be explicitly listed here to be
        // client-writable — unknown fields are denied by default.
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly([
               'content',
               'visibility',
               'allowComments',
               'updatedAt',
               'editedAt',
               'title',
               'tags',
               'linkPreviewUrl',
               'linkPreviewTitle',
               'linkPreviewDescription',
               'linkPreviewImageUrl',
               'category'         // allow recategorizing a draft before publish
             ]);

      allow delete: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;

      // === LIKES SUBCOLLECTION ===
      match /likes/{likeId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }

      // === COMMENTS SUBCOLLECTION ===
      // PRIVACY: Only users who can read the parent post may read comments.
      // P1 SECURITY FIX: Changed from `if isAuthenticated()` to callerCanComment(postId).
      // Previously, any authenticated user could read comments on a private post by
      // directly fetching posts/{postId}/comments even if they couldn't read the post.
      match /comments/{commentId} {
        allow read: if isAuthenticated() && callerCanComment(postId);
        // AUTH-04: Comments also require verified email.
        allow create: if isAuthenticated()
          && callerIsEmailVerified()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.get('text', '').size() > 0
          && validLength(request.resource.data.text, 2000)
          && callerCanComment(postId)
          && !request.resource.data.keys().hasAny([
            'flaggedForReview', 'removed', 'moderationScore'
          ]);
        allow update: if isAuthenticated()
          && resource.data.authorId == request.auth.uid
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'authorId', 'flaggedForReview', 'removed'
          ]));
        // Comment author or post author can delete.
        allow delete: if isAuthenticated()
          && (resource.data.authorId == request.auth.uid
            || get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid);
      }

      // === REPOSTS SUBCOLLECTION ===
      match /reposts/{repostId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }
    }

    // ============================================================================
    // CONVERSATIONS COLLECTION
    // ============================================================================

    match /conversations/{conversationId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participantIds;
      }

      function willBeParticipant() {
        return request.auth.uid in request.resource.data.participantIds;
      }

      // Document read: caller must be a participant.
      // Block enforcement (bidirectional) is delegated server-side to the
      // enforceMessageRestrictions Cloud Function trigger, which is the
      // authoritative path and handles all group sizes without read-cost scaling.
      allow get: if isAuthenticated()
        && isParticipant();

      // Collection query: allow only authenticated users.
      // request.query.where() is not valid CEL in Firestore Security Rules,
      // and resource.data is null for list queries so isParticipant() cannot
      // be called here — it would always evaluate to false and block all list
      // queries. Ownership is enforced at the app layer (the query always
      // includes .whereField("participantIds", arrayContains: uid)) and the
      // get rule above (isParticipant()) is the authoritative single-document gate.
      allow list: if isAuthenticated();

      // Age gate: Tier A (<13) and Tier B (13-15) cannot create conversations.
      allow create: if isAuthenticated()
        && willBeParticipant()
        && request.resource.data.participantIds.size() >= 2
        && callerCanUseDMs()
        && (
          (request.resource.data.isGroup == false) ||
          (request.resource.data.isGroup == true &&
           'groupName' in request.resource.data &&
           request.resource.data.groupName is string &&
           request.resource.data.groupName.size() > 0)
        );

      // P1 FIX: Block mutation of membership/identity fields AND conversationStatus
      // by non-recipients. Only the intended recipient should be able to transition
      // a conversation from 'pending' to 'accepted'.
      // We allow update of conversationStatus only when the caller is the recipient
      // (i.e. the participant who did NOT create the conversation) OR the conversation
      // is already accepted (both participants can update metadata).
      //
      // Group admin gate: fields that control group identity or membership
      // (groupName, groupAvatarUrl, groupDescription, adminIds, participantIds)
      // may only be updated by a current group admin. For 1:1 conversations these
      // fields either don't exist or are identity fields already blocked above,
      // so the admin check is a no-op for DMs.
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds
        // 'isGroup' and 'requesterId' are immutable after creation.
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'requesterId', 'isGroup'
        ])
        // participantIds may only change for groups (add/remove members), and only
        // when the caller is a group admin.
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participantIds'])
          || (resource.data.get('isGroup', false) == true
              && request.auth.uid in resource.data.get('adminIds', []))
        )
        // Group-identity fields (name, photo, description, adminIds) may only be
        // updated by a group admin.
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'groupName', 'groupAvatarUrl', 'groupDescription', 'adminIds'
          ])
          || (resource.data.get('isGroup', false) == true
              && request.auth.uid in resource.data.get('adminIds', []))
        )
        // If conversationStatus is changing, only the non-requester recipient may do so.
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['conversationStatus'])
          || resource.data.get('requesterId', '') != request.auth.uid
        );

      allow delete: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds;

      // === MESSAGES SUBCOLLECTION ===
      match /messages/{messageId} {
        // P0 FIX: Scope message reads to conversation participants only.
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;

        // P0 FIX: Added participant check — non-participants cannot inject messages.
        // AUTH GATES: email must be verified; 2FA session must be valid (if 2FA enabled).
        allow create: if isAuthenticated()
          && callerIsEmailVerified()
          && caller2FASessionValid()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && validLength(request.resource.data.get('text', ''), 10000)
          && (
            !exists(/databases/$(database)/documents/userSafetyRecords/$(request.auth.uid))
            || get(/databases/$(database)/documents/userSafetyRecords/$(request.auth.uid)).data.accountStatus != 'frozen'
          );

        // P1 FIX: Changed from blocklist to allowlist for non-sender updates.
        // Non-senders previously could update ANY field not in the blocklist (e.g.
        // reported, hidden, moderationOverride, analysisScore). Now non-senders
        // are limited to ['readBy', 'reactions', 'deliveryStatus'] only.
        // Senders retain full update rights on their own messages.
        allow update: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && (resource.data.senderId == request.auth.uid
              || request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['readBy', 'reactions', 'deliveryStatus']));

        // Allow delete only by sender, and only if canDeleteMessages is not false.
        // Safety: frozen/suspended accounts have canDeleteMessages=false in userSafetyRecords.
        allow delete: if isAuthenticated()
          && resource.data.senderId == request.auth.uid
          && (
            !exists(/databases/$(database)/documents/userSafetyRecords/$(request.auth.uid))
            || get(/databases/$(database)/documents/userSafetyRecords/$(request.auth.uid)).data.canDeleteMessages != false
          );
      }

      // === TYPING INDICATOR SUBCOLLECTION ===
      match /typing/{userId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow write: if isAuthenticated() && isOwner(userId)
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }

      // === HELD MESSAGES SUBCOLLECTION ===
      // Flagged messages withheld from recipient by the safety system.
      match /held_messages/{messageId} {
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid;
        allow read: if isAuthenticated()
          && (resource.data.senderId == request.auth.uid
              || resource.data.recipientId == request.auth.uid);
        allow update, delete: if false;
      }
    }

    // ============================================================================
    // FEEDS COLLECTION (Server-Only Writes)
    // ============================================================================

    match /feeds/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;

      match /items/{itemId} {
        // HIGH-4 FIX: Belt-and-suspenders block enforcement at the rules layer.
        //
        // The feed fanout (feedBuilder.ts) only writes items at post-creation time.
        // If a block relationship is created AFTER a post has already been fanned out,
        // the item remains in the feed but must be invisible to the requesting user.
        //
        // F-12 FIX: Removed dual exists() block checks from feed item reads.
        // The previous rule made two exists() calls per document — one for
        // reader-blocked-author and one for author-blocked-reader. On a 50-item
        // feed page that is 100 extra Firestore reads per page load, costing
        // ~$0.06 per 100k reads and degrading latency under traffic.
        // Block relationships are now enforced at fanout time by feedBuilder.ts,
        // which pre-filters blocked users when writing items to the feed. The
        // owner-only gate here remains as the authorization boundary.
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // ============================================================================
    // COMMUNITIES COLLECTION
    // ============================================================================

    match /communities/{communityId} {
      // 8.4 FIX: Private community visibility.
      // Public communities (isPrivate == false or absent) are readable by all
      // authenticated users. Private communities are only readable by:
      //   • the creator
      //   • any admin listed in adminIds
      //   • any joined member (exists check on the members subcollection, O(1))
      //   • platform admins
      // NOTE: The exists() read is justified here — it is a single point-read
      // on a known document path, not a collection scan.
      function callerCanReadCommunity() {
        return resource.data.get('isPrivate', false) == false
          || resource.data.get('creatorId', '') == request.auth.uid
          || request.auth.uid in resource.data.get('adminIds', [])
          || exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid))
          || isAdmin();
      }

      allow read: if isAuthenticated() && callerCanReadCommunity();
      allow create: if isAuthenticated()
        && request.resource.data.creatorId == request.auth.uid
        && hasRequiredFields(['name', 'description', 'creatorId'])
        && validLength(request.resource.data.name, 100)
        && validLength(request.resource.data.description, 500);
      // P2 FIX: Block changes to creatorId.
      allow update: if isAuthenticated()
        && (resource.data.creatorId == request.auth.uid
          || request.auth.uid in resource.data.get('adminIds', []))
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['creatorId']);
      allow delete: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;

      // === MEMBERS SUBCOLLECTION ===
      // Gate reads on community visibility: members list of a private community
      // must not leak to non-members.
      match /members/{memberId} {
        allow read: if isAuthenticated() && callerCanReadCommunity();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && (resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid);
      }

      // === POSTS SUBCOLLECTION ===
      // Same visibility gate as the parent community.
      match /posts/{postId} {
        allow read: if isAuthenticated() && callerCanReadCommunity();
        allow create: if isAuthenticated()
          && request.resource.data.authorId == request.auth.uid;
        // P1 FIX: Field allowlist prevents authors from clearing server-managed
        // moderation fields (flaggedForReview, removed, moderationScore) on their
        // own community posts. Mirrors the top-level posts update rule.
        allow update: if isAuthenticated()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['content', 'visibility', 'updatedAt', 'editedAt', 'title', 'tags']);
        allow delete: if isAuthenticated()
          && (resource.data.authorId == request.auth.uid
            || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid);
      }
    }

    // ============================================================================
    // ARK COMMUNITIES COLLECTION
    // ============================================================================

    match /arkCommunities/{communityId} {
      // Any authenticated user can read community metadata to discover communities.
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.creatorId == request.auth.uid
        && hasRequiredFields(['name', 'description', 'creatorId'])
        && validLength(request.resource.data.name, 100)
        && validLength(request.resource.data.description, 500);
      allow update: if isAuthenticated()
        && (resource.data.creatorId == request.auth.uid
          || request.auth.uid in resource.data.get('adminIds', []))
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['creatorId']);
      allow delete: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;

      // === MEMBERS SUBCOLLECTION ===
      // Readable by any authenticated user (for community counts / discovery).
      // Collection group queries restricted to the user's own membership documents.
      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && (resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/arkCommunities/$(communityId)).data.creatorId == request.auth.uid);
      }

      // === POSTS SUBCOLLECTION ===
      match /posts/{postId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.authorId == request.auth.uid;
        allow update: if isAuthenticated()
          && resource.data.authorId == request.auth.uid;
        allow delete: if isAuthenticated()
          && (resource.data.authorId == request.auth.uid
            || get(/databases/$(database)/documents/arkCommunities/$(communityId)).data.creatorId == request.auth.uid);
      }
    }

    // ============================================================================
    // REPORTS COLLECTION
    // ============================================================================

    match /reports/{reportId} {
      allow read: if isAuthenticated()
        && (resource == null || resource.data.reporterId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid
        && hasRequiredFields(['reporterId', 'reportedContentId', 'reason'])
        && request.resource.data.reason in [
          'spam', 'harassment', 'inappropriate', 'other',
          'Inappropriate content', 'Spam', 'Harassment', 'Hate speech',
          'False information', 'Violence', 'Self-harm', 'Adult content',
          'Privacy violation', 'Other'
        ];
      // P1 FIX: Reporters may add supplemental information (e.g., additional context)
      // but may NOT change the reportedContentId, reason, or reporterId after creation.
      allow update: if isAuthenticated()
        && resource.data.reporterId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'reporterId', 'reportedContentId', 'reason'
        ]);
      // P1 SECURITY: Reports must NOT be deletable by reporters — a user could file then
      // retract a harassment report to cover their tracks. Deletion is admin-SDK only.
      allow delete: if false;
    }

    // ============================================================================
    // NOTIFICATIONS COLLECTION (Top-Level)
    // ============================================================================

    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // P0 FIX: No client creates on the top-level /notifications collection.
      // All notifications are created server-side by Cloud Functions (admin SDK).
      // Allowing client creates here (even self-scoped) enables spam injection of
      // fake notification documents. The authoritative notification path is the
      // users/{userId}/notifications subcollection which is already CF-only.
      allow create: if false;

      // Owner: mark as read / update V2 state — only own records.
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['read', 'readAt', 'seenAt', 'openedAt', 'dismissedAt']);

      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ============================================================================
    // TONE ANALYTICS COLLECTION
    // ============================================================================

    match /toneAnalytics/{analyticsId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      // P1 FIX: Scope writes to caller's own records.
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================================
    // MODERATION QUEUE COLLECTION
    // ============================================================================

    match /moderationQueue/{queueId} {
      // Only admins can read moderation queue.
      allow read: if isAuthenticated()
        && isAdmin();
      // HIGH-1/HIGH-3 FIX: All moderation queue entries are now written by Cloud Functions
      // (submitReport, mediaScanning, antiHarassmentEnforcement, accountSuspension).
      // Direct client creates allowed spoofing priority, queueType, and uid fields.
      allow create: if false;   // Cloud Functions only — admin SDK
      // Admins can update queue items (change status, add notes).
      allow update: if isAuthenticated()
        && isAdmin()
        && isOnlyUpdating(['status', 'handledBy', 'handledAt', 'notes', 'updatedAt']);
      allow delete: if false;
    }

    // ============================================================================
    // SEARCH INDEX COLLECTION
    // ============================================================================

    match /searchIndex/{indexType} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================================================
    // ANALYTICS COLLECTIONS (server-only)
    // ============================================================================

    match /analytics/{document=**} {
      allow read: if false;
      allow write: if false;
    }

    match /analytics_performance/{document=**} {
      allow read: if false;
      allow write: if false;
    }

    // ============================================================================
    // ADMIN COLLECTION
    // ============================================================================

    match /admin/{document=**} {
      allow read: if false;
      allow write: if false;
    }

    // ============================================================================
    // EVENTS COLLECTION
    // ============================================================================

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.creatorId == request.auth.uid
        && hasRequiredFields(['title', 'description', 'creatorId', 'date']);
      allow update: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;

      // === ATTENDEES SUBCOLLECTION ===
      match /attendees/{userId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }
    }

    // ============================================================================
    // PRAYER REQUESTS COLLECTION
    // ============================================================================

    match /prayerRequests/{prayerId} {
      // P0 FIX: Prayer requests contain sensitive personal content (health, family,
      // spiritual struggles). Previously readable by ALL authenticated users.
      // Now restricted to: author, OR explicitly public (isPublic == true).
      // Default: private (isPublic not set = false).
      allow read: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid
            || resource.data.get('isPublic', false) == true);
      // AUTH-04: Prayer requests require verified email.
      allow create: if isAuthenticated()
        && callerIsEmailVerified()
        && request.resource.data.authorId == request.auth.uid
        && hasRequiredFields(['content', 'authorId', 'authorName'])
        && validLength(request.resource.data.content, 1000);
      // P1 FIX: Block post-creation changes to identity fields.
      allow update: if isAuthenticated()
        && resource.data.authorId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['authorId', 'userId']);
      allow delete: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;

      // === PRAYERS SUBCOLLECTION ===
      match /prayers/{prayId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }
    }

    // ============================================================================
    // TESTIMONIES COLLECTION
    // ============================================================================

    match /testimonies/{testimonyId} {
      // P0 FIX: Testimonies contain personal accounts of hardship and transformation.
      // Previously readable by ALL authenticated users — a privacy violation.
      // Now restricted to: author OR explicitly public (isPublic == true).
      allow read: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid
            // Safety fix: testimonies default PRIVATE (not public) to protect personal spiritual narratives.
            || resource.data.get('isPublic', false) == true);
      // AUTH-04: Testimonies require verified email.
      allow create: if isAuthenticated()
        && callerIsEmailVerified()
        && request.resource.data.authorId == request.auth.uid
        && hasRequiredFields(['content', 'authorId', 'authorName'])
        && validLength(request.resource.data.content, 2000);
      // P1 FIX: Block post-creation changes to identity fields.
      allow update: if isAuthenticated()
        && resource.data.authorId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['authorId', 'userId']);
      allow delete: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;

      // === AMENS SUBCOLLECTION ===
      match /amens/{amenId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.userId == request.auth.uid;
      }
    }

    // ============================================================================
    // FEATURE FLAGS COLLECTION
    // ============================================================================

    match /featureFlags/{flagId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================================================
    // USER REPOSTS COLLECTION
    // ============================================================================

    match /user-reposts/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;

      match /reposts/{repostId} {
        allow get: if isAuthenticated();
        allow list: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ============================================================================
    // SAVED POSTS COLLECTION (top-level for queries)
    // ============================================================================

    match /savedPosts/{saveId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ============================================================================
    // REPOSTS COLLECTION (top-level for queries and feed)
    // ============================================================================

    match /reposts/{repostId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ============================================================================
    // CHURCH NOTES COLLECTION
    // ============================================================================

    match /churchNotes/{noteId} {
      // P0 FIX: Church notes are personal sermon reflections containing sensitive
      // spiritual content. Previously readable by ALL authenticated users — a
      // significant privacy breach. Now restricted to: owner OR explicitly public.
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
            || resource.data.get('isPublic', false) == true);
      // AUTH-04: Church notes require verified email.
      allow create: if isAuthenticated()
        && callerIsEmailVerified()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ============================================================================
    // FCM QUEUE COLLECTION
    // MEDIUM-1: TTL / CLEANUP NOTE
    //
    // Documents in /fcmQueue accumulate indefinitely unless a Cloud Function
    // (or Firestore TTL policy) removes them after delivery.
    //
    // Recommended cleanup strategy (pick one):
    //
    // Option A — Firestore TTL policy (preferred, zero-cost after setup):
    //   1. Add a `expireAt` Timestamp field (now + 7 days) when each doc is created.
    //   2. In the Firebase Console → Firestore → TTL, set ttlField = "expireAt"
    //      on the "fcmQueue" collection.
    //   Firestore will automatically purge expired docs at no charge.
    //
    // Option B — Scheduled Cloud Function:
    //   Export and deploy a scheduled function (e.g. every 24 h) that runs:
    //     db.collection('fcmQueue')
    //       .where('createdAt', '<', Timestamp.fromDate(sevenDaysAgo))
    //       .get()
    //       .then(snap => snap.docs.forEach(d => d.ref.delete()));
    //
    // Without one of the above, /fcmQueue will grow unbounded, increasing
    // storage costs and degrading query performance over time.
    // ============================================================================

    match /fcmQueue/{queueId} {
      // FCM queue is written exclusively by Cloud Functions (admin SDK).
      // Clients have no read or write access — prevents blocked users from
      // queuing push notifications and stops clients from reading token queues.
      allow read, write: if false;
    }

    // ============================================================================
    // MUTED USERS COLLECTION
    // ============================================================================

    match /mutedUsers/{muteId} {
      allow read: if isAuthenticated()
        && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource == null || resource.data.userId == request.auth.uid);
    }

    // ============================================================================
    // BLOCKED USERS COLLECTION (top-level)
    // ============================================================================

    match /blockedUsers/{blockId} {
      allow read: if isAuthenticated()
        && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource == null || resource.data.userId == request.auth.uid);
    }

    // ============================================================================
    // ONBOARDING FEEDBACK COLLECTION
    // ============================================================================

    match /onboardingFeedback/{feedbackId} {
      allow read: if isAuthenticated()
        && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ============================================================================
    // AI BIBLE STUDY CONVERSATIONS COLLECTION
    // ============================================================================

    match /aiBibleStudyConversations/{conversationId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && hasRequiredFields(['userId', 'createdAt', 'updatedAt', 'messageCount']);
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/aiBibleStudyConversations/$(conversationId)).data.userId == request.auth.uid;
        allow create: if isAuthenticated()
          && get(/databases/$(database)/documents/aiBibleStudyConversations/$(conversationId)).data.userId == request.auth.uid
          && hasRequiredFields(['text', 'isUser', 'timestamp', 'index']);
        // F-13 FIX: Field allowlist on message updates prevents owners from
        // modifying AI-managed fields (confidence scores, model version, safety
        // flags). Only user-annotation fields may be mutated by the client.
        allow update: if isAuthenticated()
          && get(/databases/$(database)/documents/aiBibleStudyConversations/$(conversationId)).data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['starred', 'savedAt', 'userNote']);
        allow delete: if isAuthenticated()
          && get(/databases/$(database)/documents/aiBibleStudyConversations/$(conversationId)).data.userId == request.auth.uid;
      }
    }

    // ============================================================================
    // AI MODERATION COLLECTIONS
    // ============================================================================

    // Moderation Requests — Created by app, processed by Cloud Functions.
    match /moderationRequests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && hasRequiredFields(['content', 'contentType', 'userId', 'timestamp']);
      allow read, update, delete: if false;
    }

    // Moderation Results — Created by Cloud Functions, read by app.
    match /moderationResults/{resultId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Moderation Logs — Analytics and admin review.
    match /moderationLogs/{logId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      // P1 FIX: Admin check done via get() — acceptable for low-frequency admin reads.
      allow read: if isAuthenticated()
        && isAdmin();
      allow update, delete: if false;
    }

    // ============================================================================
    // CRISIS DETECTION COLLECTIONS
    // ============================================================================

    // Crisis Detection Requests — Created by app, processed by Cloud Functions.
    match /crisisDetectionRequests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && hasRequiredFields(['prayerText', 'userId', 'timestamp']);
      allow read, update, delete: if false;
    }

    // Crisis Detection Results — Created by Cloud Functions, read by app.
    match /crisisDetectionResults/{resultId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Crisis Detection Logs — Sensitive self-harm signals; deny ALL client access.
    match /crisisDetectionLogs/{logId} {
      allow read, write: if false;
    }

    // Moderator Alerts — Critical issues requiring immediate attention.
    match /moderatorAlerts/{alertId} {
      allow create: if false;
      allow read: if isAuthenticated()
        && isAdmin();
      allow update: if isAuthenticated()
        && isAdmin()
        && isOnlyUpdating(['status', 'handledBy', 'handledAt']);
      allow delete: if false;
    }

    // ============================================================================
    // SMART NOTIFICATIONS COLLECTIONS
    // ============================================================================

    match /notificationBatches/{batchId} {
      allow create: if false;
      allow read: if isAuthenticated()
        && resource.data.recipientId == request.auth.uid;
      allow update, delete: if false;
    }

    match /scheduledBatches/{batchId} {
      allow create: if false;
      allow read: if isAuthenticated()
        && resource.data.recipientId == request.auth.uid;
      allow update, delete: if false;
    }

    match /userNotificationPreferences/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update, delete: if false;
    }

    // ============================================================================
    // PRAYERS COLLECTION (top-level for AI analysis)
    // ============================================================================

    match /prayers/{prayerId} {
      // get: single-document fetch — resource.data is available.
      allow get: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // SECURITY: Prayers are private. Only the owner may list their own prayers.
      // resource.data is available in list rules (Firestore evaluates the rule
      // against each document in the result set), so we enforce ownership here
      // rather than relying on client-side query scoping.
      allow list: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && hasRequiredFields(['userId', 'createdAt']);
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ============================================================================
    // AI FEATURES COLLECTIONS
    // ============================================================================

    match /aiSearchRequests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    match /aiSearchResults/{resultId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /noteSummaryRequests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    match /noteSummaryResults/{resultId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /scriptureReferenceRequests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // resource == null guard: allows polling while the Cloud Function hasn't written yet.
    match /scriptureReferenceResults/{resultId} {
      allow read: if isAuthenticated()
        && (resource == null || resource.data.get('userId', '') == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /churchRecommendationRequests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    match /churchRecommendationResults/{resultId} {
      allow read: if isAuthenticated()
        && (resource == null || resource.data.get('userId', '') == request.auth.uid);
      allow create, update, delete: if false;
    }

    // ============================================================================
    // AI PHOTO INSIGHTS COLLECTION
    // ============================================================================

    match /photoInsights/{userId} {
      // P0 FIX: Cloud Vision AI analysis results are private to the user they belong to.
      // Previously readable by ALL authenticated users — exposed AI moderation signals
      // and upload metadata to any logged-in user.
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if false;  // Cloud Functions (Cloud Vision) only
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // ============================================================================
    // SAFETY & MODERATION COLLECTIONS
    // ============================================================================

    match /moderationAppeals/{appealId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /suspiciousActivity/{activityId} {
      allow read: if false;
      // P1 FIX: Scope create to caller's own userId.
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    match /brigadingAlerts/{alertId} {
      allow read: if false;
      // P1 FIX: Scope create to caller's own reporterId.
      allow create: if isAuthenticated()
        && request.resource.data.get('reporterId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // ENFORCEMENT HISTORY (moderation action log)
    // P0 FIX: All writes must come from Cloud Functions (admin SDK) only.
    // ============================================================================

    match /enforcementHistory/{actionId} {
      allow read: if isAuthenticated()
        && (resource.data.get('userId', '') == request.auth.uid
          || resource.data.get('targetUserId', '') == request.auth.uid);
      allow create: if false;
      allow update, delete: if false;
    }

    // ============================================================================
    // DATA EXPORT REQUESTS
    // ============================================================================

    match /dataExportRequests/{requestId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // TRUST-BY-DESIGN: PRIVACY & CONTACT CONTROLS
    // ============================================================================

    match /user_privacy_settings/{userId} {
      // P1 FIX: Privacy settings are sensitive user safety configuration
      // (e.g. hideFromSearch, blockedKeywords, whoCanMessage). Previously any
      // authenticated user could read any other user's safety configuration.
      // Now owner-only. Permission enforcement that previously read this collection
      // must be moved to server-side CF checks or passed via Cloud Function context.
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated() && userId == request.auth.uid;
      allow delete: if false;
    }

    match /quiet_blocks/{blockId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || resource.data.targetUserId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    match /repeated_contact_attempts/{attemptId} {
      allow read: if isAuthenticated() && resource.data.targetUserId == request.auth.uid;
      // P1 FIX: Require senderId matches the caller.
      allow create: if isAuthenticated()
        && request.resource.data.get('senderId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // TWO-FACTOR AUTHENTICATION: BACKUP CODES
    // P0 SECURITY: All client access denied — Cloud Function manages backup codes.
    // ============================================================================

    match /user_backup_codes/{userId} {
      // P0 FIX: No client reads or writes — backup codes must be managed exclusively
      // by the Cloud Function (generateBackupCodes / validateBackupCode) using admin SDK.
      // The previous create rule allowed clients to write their own (potentially weak)
      // codes. Server generation ensures cryptographically strong codes.
      allow read: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================================
    // VISIT PLANS COLLECTION (First Visit Companion)
    // ============================================================================

    match /visit_plans/{planId} {
      allow get: if isAuthenticated()
        && (resource == null || resource.data.user_id == request.auth.uid);
      // SECURITY: Only the owner's visit plans should be listable.
      // Enforce ownership at the rules layer — visit plans are private intent
      // signals and must not be enumerable by other authenticated users.
      allow list: if isAuthenticated()
        && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.user_id == request.auth.uid
        && hasRequiredFields(['user_id', 'church_id', 'church_name', 'service_date']);
      allow update: if isAuthenticated()
        && resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.user_id == request.auth.uid;
    }

    // ============================================================================
    // PHONE AUTH RATE LIMITING (Server-side only)
    // ============================================================================

    match /phoneAuthRateLimits/{phoneNumber} {
      allow read: if false;
      allow write: if false;
    }

    match /phoneAuthIPRateLimits/{ipAddress} {
      allow read: if false;
      allow write: if false;
    }

    // ============================================================================
    // ACCOUNT DELETION REQUESTS
    // P1 FIX: Changed write from false to allow users to create their own deletion
    // request. The previous rule blocked all client writes, preventing GDPR/CCPA
    // compliant deletion flows. Users can only create (not update) their own record.
    // Cloud Functions process the deletion and write the audit log.
    // ============================================================================

    match /deletionRequests/{userId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated()
        && userId == request.auth.uid
        && hasRequiredFields(['userId', 'requestedAt', 'reason'])
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;  // Cloud Function handles processing
    }

    match /deletionAuditLog/{logId} {
      // P1 FIX: Admin check via get() — acceptable for low-frequency compliance reads.
      allow read: if isAuthenticated()
        && isAdmin();
      allow write: if false;
    }

    // ============================================================================
    // SECURITY EVENTS LOGGING
    // ============================================================================

    match /securityEvents/{eventId} {
      allow read: if isAuthenticated()
        && isAdmin();
      allow write: if false;
    }

    // ============================================================================
    // TWO-FACTOR AUTHENTICATION
    // ============================================================================

    // twoFactor top-level (legacy path — may coexist with users/{userId}/twoFactor/)
    match /twoFactor/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // ============================================================================
    // ENGAGEMENT EVENTS COLLECTION (ML training data)
    // ============================================================================

    match /engagementEvents/{eventId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && request.resource.data.get('eventType', '') in [
          'view', 'reaction', 'comment', 'share', 'save', 'skip', 'report'
        ];
      allow update, delete: if false;
    }

    // ============================================================================
    // NOTIFICATION ENGAGEMENT COLLECTION
    // ============================================================================

    match /notificationEngagement/{engagementId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // POST EMBEDDINGS COLLECTION (Semantic search — Cloud Run search service)
    // ============================================================================

    match /postEmbeddings/{postId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // ============================================================================
    // HEY FEED PREFERENCES COLLECTION
    // ============================================================================

    match /userFeedPrefs/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // ============================================================================
    // HEY FEED SIGNALS COLLECTION
    // ============================================================================

    match /userFeedSignals/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if isAuthenticated() && isOwner(userId);

      match /signals/{signalId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ============================================================================
    // USER RATE LIMITS COLLECTION
    // ============================================================================

    match /user_rate_limits/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      // Atomic FieldValue.increment() writes are safe for own counters.
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if false;
    }

    // ============================================================================
    // USER REPORTS COLLECTION (Anti-harassment / safety)
    // ============================================================================

    match /userReports/{reportId} {
      // HIGH-3 FIX: Reports must be created via the submitReport Cloud Function only.
      // Direct client writes allowed forging reportedUserId, reason, escalationTier,
      // and priorityLevel. All of those are now computed server-side by submitReport.
      allow read: if isAuthenticated()
        && (resource.data.get('reporterId', '') == request.auth.uid
          || resource.data.get('reportedUserId', '') == request.auth.uid);
      allow create: if false;   // Cloud Function only — use submitReport callable
      allow update, delete: if false;
    }

    // ============================================================================
    // MESSAGING SAFETY INFRASTRUCTURE
    // ============================================================================

    // Safety events log — compact events for pattern engine (no message text).
    // P0 FIX: safetyEvents are now created by Cloud Functions only (admin SDK).
    // Client-created safety events are a vector for framing other users by writing
    // fake events with manipulated recipientIds or severity scores.
    match /safetyEvents/{eventId} {
      allow create: if false;  // Cloud Function only
      allow read: if isAuthenticated()
        && (resource.data.senderId == request.auth.uid
            || resource.data.recipientId == request.auth.uid);
      allow update, delete: if false;
    }

    // User safety records — strike counter, freeze status.
    // SECURITY: Written exclusively by Cloud Functions (admin SDK).
    // No client writes permitted — a frozen user must NOT be able to clear their own
    // accountStatus, canDeleteMessages, or canChangeUsername flags.
    // Read: any authenticated user may read (needed by UnifiedChatView / MinorSafetyService
    // to evaluate the recipient's safety status before sending a DM).
    match /userSafetyRecords/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // Held messages — flagged and withheld from recipient.
    // (Also defined as subcollection under conversations above — both paths exist.)
    match /conversations/{conversationId}/held_messages/{messageId} {
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid;
      allow read: if isAuthenticated()
        && (resource.data.senderId == request.auth.uid
            || resource.data.recipientId == request.auth.uid);
      allow update, delete: if false;
    }

    // Media send events — used for broadcast pattern detection.
    match /mediaSendEvents/{eventId} {
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Media scan queue — async deep scan requests.
    match /mediaScanQueue/{scanId} {
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Evidence preservation — written by safety services; not readable by clients.
    // P1 FIX: Scope create to the userId of the sender/reporter (not any authenticated user).
    match /evidencePreservation/{docId} {
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Quarantined content hashes — read by MediaSafetyGateway for hash matching.
    match /quarantinedContentHashes/{hashId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Adult content hashes — used when recipient is minor.
    match /adultContentHashes/{hashId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================================================
    // TRENDING TOPICS COLLECTION
    // ============================================================================

    match /trending/{topicId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // ============================================================================
    // TOPIC STATS COLLECTION
    // Read-only post-count aggregates per topic tag, written by Cloud Functions.
    // ============================================================================

    match /topicStats/{topicId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // ============================================================================
    // CHURCHES COLLECTION (directory data — read-only for clients)
    // ============================================================================

    match /churches/{churchId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================================================
    // USER CHURCH RELATIONS
    // ============================================================================

    match /userChurchRelations/{relationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ============================================================================
    // CHRISTIAN DATING PROFILES COLLECTION
    // Age gate: only adults (Tier D, 18+) may create, update, or read dating profiles.
    // ============================================================================

    match /datingProfiles/{userId} {
      // P2 FIX: Enforce age gate at the rules level — callerIsAdult() ensures only 18+
      // users can read dating profiles. Previously minors could read adult profiles
      // by direct document ID access since the rules did not call callerIsAdult().
      allow read: if isAuthenticated() && callerIsAdult();
      allow create, update: if isAuthenticated() && isOwner(userId) && callerIsAdult();
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // ============================================================================
    // RATE LIMITS COLLECTION (Server-only)
    // CRITICAL-CF FIX: Per-user call-count windows written by Cloud Functions.
    // Path: rateLimits/{uid}/windows/{windowKey}
    //
    // IMPORTANT: All writes come from the Cloud Function admin SDK (rateLimit.ts)
    // which bypasses these rules. The rules below block any direct client writes,
    // preventing a user from resetting or forging their own rate-limit counters.
    //
    // Clients may read their own rate-limit state (e.g. to show a "slow down"
    // banner in the UI before the server rejects a call), but cannot write.
    // ============================================================================

    // MISSING-RULE FIX: Changed from owner-read to deny-all for both the parent
    // document and its /windows subcollection. Exposing rate-limit counters to the
    // client allows a user to observe their own quota state and time requests to
    // stay just under thresholds — turning the rate-limiter into a precision tool
    // rather than a throttle. Rate-limit enforcement must be opaque to the client.
    // Any "slow down" banner UX should be driven by CF callable response codes,
    // not by direct client reads of this collection.
    match /rateLimits/{uid} {
      allow read, write: if false;  // Admin SDK only

      match /windows/{windowKey} {
        allow read, write: if false;  // Admin SDK only
      }
    }

    // ============================================================================
    // TWO-FACTOR OTP COLLECTION (Server-only)
    // OTP codes must NEVER be readable by clients.
    // ============================================================================

    match /twoFactorOTP/{otpId} {
      allow read: if false;
      allow create: if false;
      allow update, delete: if false;
    }

    // ============================================================================
    // TWO-FACTOR SESSIONS COLLECTION
    // Clients may read their own verified 2FA session to check validity,
    // but may never create, update, or delete sessions (server-managed).
    // ============================================================================

    match /twoFactorSessions/{sessionId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ============================================================================
    // NOTIFICATION DIGESTS COLLECTION
    // ============================================================================

    match /notificationDigests/{digestId} {
      allow get: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      // Scope list queries to the caller's own digests.
      // Prevents any authenticated user from enumerating other users' notification digests.
      allow list: if isAuthenticated()
        && request.auth.uid == resource.data.get('userId', '');
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if false;
    }

    // ============================================================================
    // BEREAN AUDIT LOG COLLECTION
    // ============================================================================

    match /bereanAuditLog/{logId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // MODERATION CONSTITUTION COLLECTIONS
    // Written exclusively by Cloud Functions / trust-level-service (admin SDK).
    // ============================================================================

    match /moderation_jobs/{jobId} {
      allow get: if isAuthenticated()
        && resource.data.get('author_id', '') == request.auth.uid;
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /enforcement_actions/{actionId} {
      allow get: if isAuthenticated()
        && resource.data.get('target_user_id', '') == request.auth.uid;
      // P1 FIX: Restrict list to documents targeting the calling user only.
      allow list: if isAuthenticated()
        && request.auth.uid == request.query.filters['target_user_id'];
      allow create, update, delete: if false;
    }

    match /user_trust/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update, delete: if false;
    }

    match /moderation_ingest_events/{eventId} {
      allow create: if isAuthenticated()
        && request.resource.data.get('author_id', '') == request.auth.uid
        && request.resource.data.keys().hasAll(['content_id', 'content_type', 'author_id', 'created_at']);
      allow read, update, delete: if false;
    }

    // ============================================================================
    // SCHEDULED POSTS COLLECTION
    // ============================================================================

    match /scheduled_posts/{postId} {
      allow read: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('authorId', '') == request.auth.uid
        && hasRequiredFields(['content', 'category', 'authorId', 'scheduledFor', 'createdAt'])
        && request.resource.data.category in ['openTable', 'testimonies', 'prayer', 'general', 'tip', 'funFact'];
      allow update: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid;
    }

    // camelCase alias used by FirebasePostServiceEnhancements.scheduledPosts
    match /scheduledPosts/{postId} {
      allow read: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('authorId', '') == request.auth.uid
        && hasRequiredFields(['content', 'category', 'authorId', 'scheduledFor', 'createdAt']);
      allow update: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid;
    }

    // Prayer chains — any authenticated member can read/join; only creator can delete
    match /prayerChains/{chainId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.get('creatorId', '') == request.auth.uid;
      // Restrict updates to the creator or existing participants.
      // Prevents any authenticated user from modifying chain content,
      // participant arrays, or metadata on chains they don't own.
      allow update: if isAuthenticated()
        && (resource.data.get('creatorId', '') == request.auth.uid
            || request.auth.uid in resource.data.get('participantIds', []));
      allow delete: if isAuthenticated()
        && resource.data.get('creatorId', '') == request.auth.uid;
    }

    // camelCase prayer reminders (SmartPrayerReminderScheduler)
    match /prayerReminders/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // Community groups — authenticated users can browse; creator manages membership
    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.get('creatorId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('creatorId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('creatorId', '') == request.auth.uid;
      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == memberId;
      }
    }

    // ============================================================================
    // POST INTERACTIONS COLLECTION (Firestore — used by CommentSafetySystem)
    // Note: Live comment data lives in Realtime Database.
    // ============================================================================

    match /postInteractions/{postId} {
      allow read: if isAuthenticated()
        && (resource == null
          || resource.data.get('reporterId', '') == request.auth.uid
          || resource.data.get('authorId', '') == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.get('reporterId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('reporterId', '') == request.auth.uid;
      allow delete: if false;

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.get('reporterId', '') == request.auth.uid;
        allow update: if isAuthenticated()
          && resource.data.get('reporterId', '') == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.get('authorId', '') == request.auth.uid;
      }
    }

    // ============================================================================
    // COMMENTS COLLECTION (top-level — explicit deny)
    // F-10 FIX: Comment documents live in posts/{postId}/comments subcollection
    // and in the Realtime Database. If a top-level /comments Firestore collection
    // exists (used by some legacy code paths) it defaults to deny-all, but an
    // explicit rule prevents accidental exposure during future rules refactors
    // and self-documents the intent. RTDB /comments path is governed separately
    // by database.rules.json.
    // ============================================================================

    match /comments/{commentId} {
      allow read, write: if false;
    }

    // ============================================================================
    // USERNAMES COLLECTION (global uniqueness index)
    // ============================================================================

    match /usernames/{username} {
      allow get: if true;   // Availability check during sign-up (unauthenticated OK)
      allow list: if false; // Prevents scraping the full username registry
      allow create, update, delete: if false;  // Cloud Function only
    }

    // ============================================================================
    // TRANSLATIONS COLLECTION (PostTranslationService cross-device cache)
    // ============================================================================

    // P0 NOTE: The translation cache key is a SHA-256 hash of the source text.
    // The originalText field inside the document IS readable by any authenticated user.
    // For DM translations this is a privacy leak — any user who can guess the hash
    // can read the plaintext of another user's private message.
    // MITIGATION applied below:
    //   1. Reads are scoped to authenticated users only (already was the case).
    //   2. create requires a `surface` field; DM-origin translations should use
    //      surface='dm' and MUST NOT be written to the shared public cache.
    //      The TranslationService should only write to this collection for public
    //      content (posts, comments). DM translations must be ephemeral (in-memory only).
    //   3. originalText is capped at 500 chars to limit exposure of any leaked content.
    // TODO: TranslationService should skip Firestore cache writes when surface == 'dm'.
    match /translations/{cacheKey} {
      allow read: if isAuthenticated();
      // P0 FIX: Block DM translations from being written to the shared cache.
      // P2 FIX: Length limits to prevent cache poisoning.
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll([
          'originalText', 'translatedText', 'sourceLanguage', 'targetLanguage', 'timestamp'
        ])
        // Block DM-origin translations from the shared public cache.
        && request.resource.data.get('surface', 'post') != 'dm'
        && request.resource.data.get('surface', 'post') != 'message'
        && validLength(request.resource.data.originalText, 500)
        && validLength(request.resource.data.translatedText, 2000)
        && validLength(request.resource.data.sourceLanguage, 10)
        && validLength(request.resource.data.targetLanguage, 10);
      allow update, delete: if false;
    }

    // ============================================================================
    // FEEDBACK COLLECTION
    // ============================================================================

    match /feedback/{feedbackId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // BUG REPORTS COLLECTION
    // ============================================================================

    match /bug_reports/{reportId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // ACTIVITY FEED COLLECTION (ActivityFeedService)
    // Written EXCLUSIVELY by Cloud Functions (admin SDK).
    // P2 FIX: Client create is now denied. Clients could previously write
    // fabricated activity events (e.g. fake "X followed Y"), which could
    // pollute the feed or drive spoofed notifications if the feed drives alerts.
    // ============================================================================

    match /activityFeed/{eventId} {
      // Owner-only reads — users only see their own activity.
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      // P2 FIX: No client writes — Cloud Functions write these via admin SDK.
      allow create, update, delete: if false;
    }

    // ============================================================================
    // USER RESTRICTIONS COLLECTION (Server-managed)
    // ============================================================================

    // F-09 FIX: Deny all client access. This collection is read and written
    // exclusively by Cloud Functions (antiHarassmentEnforcement.ts) via admin SDK.
    // An explicit deny prevents accidental exposure if a broad catchall rule is
    // ever added in a future refactor. The previous read rule allowed the subject
    // user to read their own restriction documents, but restriction logic must be
    // evaluated server-side to prevent circumvention.
    match /userRestrictions/{docId} {
      allow read, write: if false;
    }

    // ============================================================================
    // PENDING NOTIFICATIONS COLLECTION (NotificationDigestService — server-only)
    // ============================================================================

    match /pendingNotifications/{notifId} {
      allow read, write: if false;
    }

    // ============================================================================
    // SERVER-ONLY MODERATION PIPELINE COLLECTIONS
    // ============================================================================

    match /moderation_events/{eventId} {
      allow read, write: if false;
    }

    match /moderation_queue/{itemId} {
      allow read, write: if false;
    }

    match /content_fingerprints/{fpId} {
      allow read, write: if false;
    }

    match /user_integrity_signals/{userId} {
      allow read, write: if false;
    }

    match /moderation_errors/{errId} {
      allow read, write: if false;
    }

    match /moderation_appeals/{appealId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    match /content_appeals/{appealId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // IMAGE MODERATION COLLECTIONS (server-only)
    // ============================================================================

    match /imageModerationLogs/{logId} {
      allow read, write: if false;
    }

    match /imageModerationErrors/{errId} {
      allow read, write: if false;
    }

    match /media_moderation/{docId} {
      allow read, write: if false;
    }

    match /media_scan_requests/{docId} {
      allow read, write: if false;
    }

    // ============================================================================
    // MAIL COLLECTION (Firebase Extensions email trigger — server-only)
    // ============================================================================

    match /mail/{docId} {
      allow read, write: if false;
    }

    // ============================================================================
    // ANALYTICS SHABBAT BLOCKS
    // ============================================================================

    match /analytics_shabbat_blocks/{docId} {
      allow read, write: if false;
    }

    // ============================================================================
    // RATE LIMIT COUNTERS (server-side counters)
    // ============================================================================

    match /rateLimitCounters/{docId} {
      allow read, write: if false;
    }

    // ============================================================================
    // COMMENT IDEMPOTENCY KEYS (deduplication — server-only)
    // ============================================================================

    match /commentIdempotencyKeys/{keyId} {
      allow read, write: if false;
    }

    // ============================================================================
    // ALGOLIA SYNC QUEUE (server writes only)
    // ============================================================================

    match /algoliaSync/{docId} {
      allow read, write: if false;
    }

    match /algoliaQueue/{docId} {
      allow read, write: if false;
    }

    // ============================================================================
    // POST DRAFTS COLLECTION
    // ============================================================================

    match /postDrafts/{draftId} {
      allow read: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('authorId', '') == request.auth.uid
        && hasRequiredFields(['authorId', 'content', 'createdAt'])
        && validLength(request.resource.data.content, 5000);
      allow update: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['authorId']);
      allow delete: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid;
    }

    // ============================================================================
    // POST VIEWS COLLECTION (append-only view tracking)
    // ============================================================================

    match /postViews/{viewId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'postId', 'viewedAt']);
      allow update, delete: if false;
    }

    // ============================================================================
    // HIDDEN POSTS COLLECTION
    // ============================================================================

    match /hiddenPosts/{hideId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'postId']);
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // HIDDEN COMMENTS COLLECTION
    // ============================================================================

    match /hiddenComments/{hideId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'commentId']);
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // NOT INTERESTED COLLECTION
    // ============================================================================

    match /notInterested/{signalId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'postId']);
      allow update, delete: if false;
    }

    // ============================================================================
    // PRAYER WALL COLLECTION
    // ============================================================================

    match /prayerWall/{prayerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.get('authorId', '') == request.auth.uid
        && hasRequiredFields(['authorId', 'content', 'createdAt'])
        && validLength(request.resource.data.content, 1000);
      allow update: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['authorId']);
      allow delete: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid;

      match /prayedBy/{userId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.get('userId', '') == request.auth.uid;
        allow delete: if isAuthenticated()
          && resource.data.get('userId', '') == request.auth.uid;
        allow update: if false;
      }
    }

    // ============================================================================
    // TOP-LEVEL PRAYED-BY COLLECTION
    // ============================================================================

    match /prayedBy/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow update: if false;
    }

    // ============================================================================
    // PRAYER FOLLOW-THROUGH COLLECTIONS
    // ============================================================================

    match /answered_prayers/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    match /prayer_reminders/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    match /prayer_commitments/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    match /prayer_status_updates/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    match /prayer_analyses/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // TRUSTED CIRCLES (EnhancedCrisisSupportService)
    // ============================================================================

    match /trustedCircles/{circleId} {
      allow read: if isAuthenticated()
        && (resource.data.get('ownerId', '') == request.auth.uid
          || request.auth.uid in resource.data.get('memberIds', []));
      allow create: if isAuthenticated()
        && request.resource.data.get('ownerId', '') == request.auth.uid
        && hasRequiredFields(['ownerId', 'memberIds']);
      allow update: if isAuthenticated()
        && resource.data.get('ownerId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('ownerId', '') == request.auth.uid;
    }

    match /trustedCircleNotifications/{notifId} {
      allow read: if isAuthenticated()
        && resource.data.get('recipientId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('senderId', '') == request.auth.uid;
      // Recipients can mark notifications read only.
      allow update: if isAuthenticated()
        && resource.data.get('recipientId', '') == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      allow delete: if isAuthenticated()
        && resource.data.get('recipientId', '') == request.auth.uid;
    }

    // ============================================================================
    // SAFE CONVERSATION SETTINGS (SafeConversationService)
    // ============================================================================

    match /safeConversationSettings/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if false;
    }

    // ============================================================================
    // SAFETY DECISIONS COLLECTION (UnifiedSafetyGate)
    // ============================================================================

    match /safetyDecisions/{decisionId} {
      // P1 SECURITY FIX: Removed targetUserId read access.
      // A malicious user could abuse this to read moderation decisions about
      // themselves that reference OTHER users as the 'targetUserId'. Only the
      // document creator (userId) may read their own pre-decision records.
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      // Client-side safety gate creates lightweight pre-decision records.
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // SHADOW BANS (AdvancedModerationService — server-written via admin SDK)
    // ============================================================================

    match /shadowBans/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update, delete: if false;
    }

    // ============================================================================
    // ADVANCED MODERATION LOGS (AdvancedModerationService)
    // P1 FIX: Admin check uses get() — acceptable for low-frequency admin reads.
    // Clients write only their own reporter events.
    // ============================================================================

    match /advancedModerationLogs/{logId} {
      // P1 SECURITY FIX: isAdmin flag in user document is client-readable via the
      // users/ rule. If a client could write their own user doc fields, they could
      // theoretically elevate to admin. The admin check is still safe because
      // users/{uid}.isAdmin is write-protected (only counter updates and non-sensitive
      // fields are mutable by clients per the users/ rule), but we add a belt-and-
      // suspenders note and keep the check. The targetUserId path lets users see
      // only their own enforcement log entries.
      allow read: if isAuthenticated()
        && (isAdmin()
          || resource.data.get('targetUserId', '') == request.auth.uid);
      // Clients may create reporter-side log entries. Server adds the authoritative fields.
      allow create: if isAuthenticated()
        && request.resource.data.get('reporterId', '') == request.auth.uid
        // Prevent the client from forging admin-side fields in the ingest entry.
        && !request.resource.data.keys().hasAny(['isAdmin', 'enforcementLevel', 'internalNote', 'adminReviewedBy']);
      allow update, delete: if false;
    }

    // ============================================================================
    // APPEALS COLLECTION (UnifiedSafetyGate, EnforcementLadderService, etc.)
    // ============================================================================

    match /appeals/{appealId} {
      // Clients can read their own appeals; admins can read all.
      allow read: if isAuthenticated()
        && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      // Appeals are created/updated exclusively by Cloud Functions (Admin SDK).
      allow write: if false;
    }

    // ============================================================================
    // SPAM REPORTS COLLECTION (FirebaseMessagingService)
    // ============================================================================

    match /spamReports/{reportId} {
      allow read: if isAuthenticated()
        && resource.data.get('reporterId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('reporterId', '') == request.auth.uid
        && hasRequiredFields(['reporterId', 'reportedUserId', 'createdAt']);
      allow update, delete: if false;
    }

    // ============================================================================
    // CRISIS ALERT LOGS (EnhancedCrisisSupportService)
    // Sensitive self-harm signal data — deny ALL client reads.
    // ============================================================================

    match /crisisAlertLogs/{logId} {
      allow read, write: if false;
    }

    // ============================================================================
    // CRISIS SUPPORT PREFERENCES
    // ============================================================================

    match /crisisSupportPreferences/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if false;
    }

    // ============================================================================
    // SAVED VERSES COLLECTION
    // ============================================================================

    match /savedVerses/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'verseReference']);
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow update: if false;
    }

    // ============================================================================
    // SAVED BOOKS COLLECTION
    // ============================================================================

    match /savedBooks/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow update: if false;
    }

    // ============================================================================
    // BOOKS COLLECTION (read-only catalogue)
    // ============================================================================

    match /books/{bookId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================================================
    // BOOK REVIEWS COLLECTION
    // ============================================================================

    match /bookReviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'bookId', 'rating'])
        && request.resource.data.get('rating', 0) >= 1
        && request.resource.data.get('rating', 6) <= 5;
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'bookId']);
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // MENTORSHIP COLLECTIONS
    // ============================================================================

    // Public mentor profiles — any authenticated user can browse
    match /mentors/{mentorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == mentorId;
    }

    // Mentor applications — user can write their own; admins read all
    match /mentorApplications/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Mentor session logs — private to mentor
    match /users/{userId}/mentorSessions/{sessionId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Walk With Christ check-in journal
    match /users/{userId}/walkCheckIns/{checkInId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Mentorship relationships — visible only to the two participants
    // allow list supports queries filtered by menteeId or mentorId
    match /mentorshipRelationships/{relId} {
      allow get: if isAuthenticated()
        && (resource.data.get('mentorId', '') == request.auth.uid
            || resource.data.get('menteeId', '') == request.auth.uid);
      // Scope list to the caller's own mentorship relationships (mentor or mentee).
      // Prevents leaking the full relationship graph to all authenticated users.
      allow list: if isAuthenticated()
        && (resource.data.get('mentorId', '') == request.auth.uid
            || resource.data.get('menteeId', '') == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.get('menteeId', '') == request.auth.uid
        && hasRequiredFields(['mentorId', 'menteeId', 'status']);
      allow update: if isAuthenticated()
        && (resource.data.get('mentorId', '') == request.auth.uid
            || resource.data.get('menteeId', '') == request.auth.uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['mentorId', 'menteeId']);
      allow delete: if isAuthenticated()
        && (resource.data.get('mentorId', '') == request.auth.uid
            || resource.data.get('menteeId', '') == request.auth.uid);
    }

    // Mentorship check-ins — visible only to the two participants
    match /mentorshipCheckIns/{checkInId} {
      allow get: if isAuthenticated()
        && (resource.data.get('mentorId', '') == request.auth.uid
            || resource.data.get('menteeId', '') == request.auth.uid);
      // Scope list to check-ins where the caller is mentor or mentee.
      // Prevents leaking private spiritual guidance records to other users.
      allow list: if isAuthenticated()
        && (resource.data.get('mentorId', '') == request.auth.uid
            || resource.data.get('menteeId', '') == request.auth.uid);
      allow create: if isAuthenticated()
        && (request.resource.data.get('mentorId', '') == request.auth.uid
            || request.resource.data.get('menteeId', '') == request.auth.uid)
        && hasRequiredFields(['mentorId', 'menteeId']);
      allow update: if isAuthenticated()
        && (resource.data.get('mentorId', '') == request.auth.uid
            || resource.data.get('menteeId', '') == request.auth.uid);
      allow delete: if false;
    }

    // ============================================================================
    // SAVED SEARCHES COLLECTION
    // ============================================================================

    match /savedSearches/{searchId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'query', 'savedAt'])
        && validLength(request.resource.data.query, 200);
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow update: if false;
    }

    // ============================================================================
    // SCHEDULED NOTIFICATIONS COLLECTION (NotificationGenkitService — server-only)
    // ============================================================================

    match /scheduledNotifications/{notifId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ============================================================================
    // NOTE FOLDERS COLLECTION (ChurchNotesService)
    // ============================================================================

    match /noteFolders/{folderId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'name', 'createdAt'])
        && validLength(request.resource.data.name, 100);
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId']);
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // DATA IMPORT COLLECTIONS (DataImportService)
    // ============================================================================

    match /importBatches/{batchId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'source', 'createdAt']);
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'completedAt', 'importedCount', 'errorCount']);
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    match /importDedupeHashes/{hashId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // BEREAN FEEDBACK COLLECTION
    // ============================================================================

    match /bereanFeedback/{feedbackId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'query', 'rating']);
      allow update, delete: if false;
    }

    // ============================================================================
    // AMEN CONNECT COLLECTION
    // ============================================================================

    match /amenConnect/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && profileId == request.auth.uid
        && hasRequiredFields(['userId', 'displayName']);
      allow update: if isAuthenticated()
        && profileId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId']);
      allow delete: if isAuthenticated()
        && profileId == request.auth.uid;
    }

    // ============================================================================
    // REACTIONS COLLECTION (Message reactions in UnifiedChatView)
    // ============================================================================

    match /reactions/{reactionId} {
      allow read: if isAuthenticated()
        && (resource.data.get('userId', '') == request.auth.uid
          || resource.data.get('recipientId', '') == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'emoji', 'messageId']);
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['emoji', 'updatedAt']);
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // THREAD SUMMARIES COLLECTION (AI-generated — server-only)
    // ============================================================================

    match /threadSummaries/{summaryId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // ============================================================================
    // COMMUNITY STANDARDS TOP-LEVEL COLLECTION
    // ============================================================================

    match /communityStandards/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create, update: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow delete: if false;
    }

    // ============================================================================
    // TIP HELPFUL COLLECTION (ChurchDataService)
    // ============================================================================

    match /tipHelpful/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'tipId', 'helpful']);
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['helpful', 'updatedAt']);
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // USER SECURITY COLLECTION
    // Stores per-user 2FA session state: session2FAActive, session2FAExpiresAt.
    // Written ONLY by Cloud Functions (verify2FAOTP, expire2FASession) via admin SDK.
    // MISSING-RULE FIX (High): Changed from owner-read to deny-all.
    // Allowing the owner to directly read their own security document creates a
    // timing side-channel: a user could poll this path to observe when their 2FA
    // session is about to expire and preemptively replay a valid session token.
    // The caller2FASessionValid() helper reads this collection via rules evaluation
    // (get() in rules bypasses client rules), so removing client read access does
    // not break the 2FA gate. Apps should use the verify2FAOTP callable to check
    // session state — never the raw document.
    // ============================================================================

    match /userSecurity/{userId} {
      allow read, write: if false;  // Admin SDK / rules evaluation only
    }

    // ============================================================================
    // TWO FACTOR SESSIONS COLLECTION
    // twoFactorSessions/{userId}/sessions/{sessionId} — created by verify2FAOTP
    // Cloud Function. Client cannot write to prevent token forgery.
    // ============================================================================

    match /twoFactorSessions/{userId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;

      match /sessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }

    // ============================================================================
    // MODERATION PIPELINE — NEW COLLECTIONS
    // ============================================================================

    // Moderation queue — superseded by the primary rule above (all writes via Cloud Functions).
    // HIGH-1/HIGH-3 FIX: Client writes removed here to match the primary rule.
    match /moderationQueue/{queueId} {
      allow create: if false;   // Cloud Functions only — see primary rule above
      allow read, update, delete: if false;
    }

    // User reports — superseded by the primary userReports rule above.
    // HIGH-3 FIX: Client writes removed; all reports created by submitReport callable.
    match /userReports/{reportId} {
      allow create: if false;   // Cloud Functions only — use submitReport callable
      // Reporters can read their own reports
      allow read: if isAuthenticated() && resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }

    // Moderation appeals
    match /moderationAppeals/{appealId} {
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['contentId', 'userId', 'reason', 'status', 'timestamp'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // User trust scores — server-managed only; clients can read their own
    match /userTrustScores/{userId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;

      match /events/{eventId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }

    // ============================================================================
    // BEREAN AI — CONVERSATION MEMORY
    // ============================================================================

    match /users/{userId}/bereanSessions/{sessionId} {
      allow read, write: if isOwner(userId);

      match /messages/{messageId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId}/bereanConversations/{conversationId} {
      allow read, write: if isOwner(userId);
    }

    // ============================================================================
    // SPIRITUAL CHECK-IN EVENTS (aggregated, no raw content)
    // ============================================================================

    match /users/{userId}/wellnessEvents/{eventId} {
      allow read: if isOwner(userId);
      // Only allow creating specific non-identifying event types
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['type', 'timestamp'])
        && request.resource.data.type in ['check_in_shown', 'check_in_engaged',
                                           'check_in_dismissed', 'break_taken'];
      allow update, delete: if false;
    }

    // ============================================================================
    // FEED SESSION QUALITY METRICS
    // ============================================================================

    match /users/{userId}/feedSessions/{sessionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['durationMinutes', 'scrollCount',
                                                'meaningfulInteractions', 'qualityScore', 'date']);
      allow update, delete: if false;
    }

    // Pinned posts subcollection — owner read/write; other users can read for profile view
    match /users/{userId}/pinnedPosts/{pinId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isOwner(userId);
    }

    // ============================================================================
    // CHURCH DISCOVERY
    // ============================================================================

    // Public church profiles — read-all, write only via admin/Cloud Functions
    match /churches/{churchId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // User's saved churches
    match /users/{userId}/savedChurches/{churchId} {
      allow read, write: if isOwner(userId);
    }

    // Church visit log
    match /users/{userId}/churchVisits/{churchId} {
      allow read, write: if isOwner(userId);
    }

    // Church interaction state machine (ChurchInteractionService)
    // Firestore path: users/{uid}/churchInteractions/{churchId}
    match /users/{userId}/churchInteractions/{churchId} {
      allow read, write: if isOwner(userId);
    }

    // Church Assist persistent state (ChurchVisitSessionManager)
    // Firestore path: users/{uid}/churchAssistState/current
    match /users/{userId}/churchAssistState/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Church visit insights summary (ChurchAssistViewModel)
    // Firestore path: users/{uid}/churchVisitInsights/summary
    match /users/{userId}/churchVisitInsights/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Church follow-up scheduling
    match /users/{userId}/churchFollowUps/{followUpId} {
      allow read, write: if isOwner(userId);
    }

    // Adaptive quiet hours / notification learning data (AdaptiveQuietHoursEngine)
    match /users/{userId}/learningData/{docId} {
      allow read, write: if isOwner(userId);
    }

    // ============================================================================
    // ANALYTICS (aggregated, privacy-safe)
    // ============================================================================

    match /analytics/{userId}/events/{eventId} {
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['event', 'ts'])
        && request.resource.data.event is string
        && request.resource.data.event.size() <= 100;
      allow read: if isOwner(userId);
      allow update, delete: if false;
    }

    // ============================================================================
    // KNOWLEDGE GRAPH — TOPIC FOLLOWS
    // ============================================================================

    match /users/{userId}/followedTopics/{topicId} {
      allow read, write: if isOwner(userId);
    }

    // ============================================================================
    // COMMENTS COLLECTION GROUP (CommentSafetySystem / harassment detection)
    // Allows authenticated users to query all comments they authored across posts.
    // The per-post comments subcollection rules still apply for writes and reads
    // on individual documents; this group rule only unlocks authenticated list queries
    // filtered to the caller's own authorId (e.g. harrassment-detection checks).
    // ============================================================================

    match /{path=**}/comments/{commentId} {
      allow list: if isAuthenticated()
        && resource.data.get('authorId', '') == request.auth.uid;
    }

    // ============================================================================
    // MUTED CONVERSATIONS
    // Document ID convention: {userId}_{conversationId}
    // Stores per-user conversation mute state so users can silence notifications
    // from specific conversations without leaving them.
    // Only the owning user may read or write their own mute records.
    // ============================================================================

    match /mutedConversations/{muteId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid == resource.data.get('userId', '');
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.get('userId', '');
    }

    // ============================================================================
    // TOPIC STATS
    // Public aggregates used by topic/trending feeds. Read-only for authenticated
    // users. Only Cloud Functions / server-side writes should mutate these docs.
    // ============================================================================

    match /topicStats/{topicId} {
      allow read: if isAuthenticated();
      allow write: if false; // server-only (Cloud Functions)
    }

    // ============================================================================
    // E2EE MESSAGING — SECURE CONVERSATIONS
    // Only participants can read/write their own conversation and its messages.
    // The server NEVER stores plaintext. encryptedPayload is opaque ciphertext.
    // ============================================================================

    match /secureConversations/{convId} {
      // Only participants may read conversation metadata
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;

      // Only participants may create a conversation (must include themselves)
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() >= 2
        && request.resource.data.participants.size() <= 50;

      // Only participants may update metadata (pin, mute, archive, unread counts)
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['isPinned','isMuted','isArchived','unreadCounts',
                       'lastEncryptedTimestamp','contactTier','isMessageRequest']);

      // Deletion not allowed from client — handled by Cloud Function
      allow delete: if false;

      match /encryptedMessages/{msgId} {
        // Only participants of the parent conversation may read messages
        allow read: if isAuthenticated()
          && exists(/databases/$(database)/documents/secureConversations/$(convId))
          && request.auth.uid in get(/databases/$(database)/documents/secureConversations/$(convId)).data.participants;

        // Only the sender (who must be a participant) may create a message
        allow create: if isAuthenticated()
          && request.auth.uid == request.resource.data.senderUID
          && exists(/databases/$(database)/documents/secureConversations/$(convId))
          && request.auth.uid in get(/databases/$(database)/documents/secureConversations/$(convId)).data.participants
          // Require encrypted payload and hash — no plaintext fields allowed
          && request.resource.data.keys().hasAll(['encryptedPayload','payloadHash','senderUID','timestamp'])
          && !request.resource.data.keys().hasAny(['plaintext','messageText','body','text']);

        // Only participants may update delivery/read status
        allow update: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/secureConversations/$(convId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['deliveryStatus','readBy','isDeleted']);

        allow delete: if false;
      }
    }

    // ============================================================================
    // KEY BUNDLES — Public key material only. No private keys ever leave device.
    // Anyone authenticated may read bundles (needed to initiate E2EE sessions).
    // Only the owner may write their own bundle.
    // ============================================================================

    match /keyBundles/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(uid)
        // Must contain required public key fields only
        && request.resource.data.keys().hasAll([
             'identityKeyPublic','signedPreKeyPublic','signedPreKeySignature',
             'signedPreKeyId','oneTimePreKeys','deviceId'
           ])
        // Identity key must be 44 chars (32 bytes base64) — prevent oversized keys
        && request.resource.data.identityKeyPublic is string
        && request.resource.data.identityKeyPublic.size() <= 64;
      allow delete: if isOwner(uid);
    }

    // ============================================================================
    // USED OTPKS — Tombstones for consumed one-time pre-keys.
    // Only the key owner may write; authenticated users may read (to avoid reuse).
    // ============================================================================

    match /usedOTPKs/{uid}/consumed/{opkId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();  // Sender marks OPK used during X3DH
      allow update, delete: if false;
    }

    // ============================================================================
    // TRUST RECORDS — Written by Cloud Functions only. Read by owner + moderation.
    // ============================================================================

    match /trustRecords/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;  // Cloud Functions only
    }

    // ============================================================================
    // MESSAGE SAFETY EVENTS — Write-only from client (privacy-preserving logs).
    // Read only by moderation (server-side via admin SDK).
    // ============================================================================

    match /messageSafetyEvents/{eventId} {
      allow create: if isAuthenticated()
        // Only category + score + hash — no message content
        && !request.resource.data.keys().hasAny(['messageText','plaintext','body'])
        && request.resource.data.keys().hasAll(['category','riskScore','convIdHash','senderUID']);
      allow read, update, delete: if false;  // Admin SDK only
    }

    // ============================================================================
    // ACCOUNT REVIEWS — Write-once from client for safety flags.
    // Read / update by moderation only.
    // ============================================================================

    match /accountReviews/{uid} {
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow read, update, delete: if false;  // Moderation team via admin SDK
    }

    // ============================================================================
    // JOBS & OPPORTUNITIES COLLECTIONS (JobService / JobModels.swift)
    // JobCollections enum defines: jobListings, jobSeekerProfiles, employerProfiles,
    // jobApplications, savedJobs, jobAlerts, jobAnalyticsEvents,
    // jobModerationFlags, jobNotifications
    // ============================================================================

    // Public job listings — any authenticated user can browse
    match /jobListings/{jobId} {
      allow read: if isAuthenticated();
      // Only the employer (posterId/employerId) may create a listing
      allow create: if isAuthenticated()
        && request.resource.data.get('employerId', '') == request.auth.uid
        && hasRequiredFields(['title', 'description', 'employerId', 'createdAt'])
        && validLength(request.resource.data.title, 200)
        && validLength(request.resource.data.description, 5000)
        // Prevent client from setting server-managed fields at create time
        && !request.resource.data.keys().hasAny(['viewCount', 'applicationCount', 'saveCount', 'removed', 'flaggedForReview']);
      // Only the employer may update their own listing (except server-managed counters)
      allow update: if isAuthenticated()
        && resource.data.get('employerId', '') == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'employerId', 'viewCount', 'applicationCount', 'saveCount',
          'removed', 'flaggedForReview'
        ]);
      // Only the employer may delete their own listing
      allow delete: if isAuthenticated()
        && resource.data.get('employerId', '') == request.auth.uid;
    }

    // Job seeker profiles — owner read/write; employers may read to evaluate candidates
    match /jobSeekerProfiles/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // Employer profiles — public read; owner write
    match /employerProfiles/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // Job applications — applicant and target employer may read; applicant creates
    match /jobApplications/{applicationId} {
      allow read: if isAuthenticated()
        && (resource.data.get('applicantId', '') == request.auth.uid
          || resource.data.get('employerId', '') == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.get('applicantId', '') == request.auth.uid
        && hasRequiredFields(['applicantId', 'jobId', 'employerId', 'createdAt'])
        // Block server-managed fields at create time
        && !request.resource.data.keys().hasAny(['status_changed_by_admin', 'removed']);
      // Applicant may withdraw; employer may update status/notes
      allow update: if isAuthenticated()
        && (resource.data.get('applicantId', '') == request.auth.uid
          || resource.data.get('employerId', '') == request.auth.uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['applicantId', 'jobId', 'employerId']);
      allow delete: if isAuthenticated()
        && resource.data.get('applicantId', '') == request.auth.uid;
    }

    // Saved jobs — owner only
    match /savedJobs/{saveId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'jobId', 'savedAt']);
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow update: if false;
    }

    // Job alerts — owner only
    match /jobAlerts/{alertId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'createdAt']);
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId']);
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // Job analytics events — append-only, owner write; server reads
    match /jobAnalyticsEvents/{eventId} {
      allow read: if false;  // server-only reads
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // Job moderation flags — any authenticated user may flag; server processes
    match /jobModerationFlags/{flagId} {
      allow read: if isAuthenticated()
        && resource.data.get('reporterId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('reporterId', '') == request.auth.uid
        && hasRequiredFields(['reporterId', 'jobId', 'reason', 'createdAt']);
      allow update, delete: if false;
    }

    // Job notifications — recipient read; server writes
    match /jobNotifications/{notifId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // FAITH EVENTS COLLECTION (EventsView / CalendarService)
    // faithEvents documents use `hostUID` as the owner field.
    // ============================================================================

    match /faithEvents/{eventId} {
      // Any authenticated user can read public events.
      allow read: if isAuthenticated();
      // Only the event host may create.
      allow create: if isAuthenticated()
        && request.resource.data.get('hostUID', '') == request.auth.uid
        && hasRequiredFields(['title', 'hostUID', 'startDate', 'createdAt'])
        && validLength(request.resource.data.title, 200)
        && validLength(request.resource.data.get('description', ''), 5000)
        // Block server-managed counter fields at create time.
        && request.resource.data.get('rsvpCount', 0) == 0
        && !request.resource.data.keys().hasAny(['isFeatured', 'removed', 'flaggedForReview']);
      // Only the host may update their own event (except rsvpCount / rsvpUIDs which
      // are updated by RSVP calls from any authenticated attendee).
      allow update: if isAuthenticated()
        && (
          // Host updating their own event content
          (resource.data.get('hostUID', '') == request.auth.uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'hostUID', 'removed', 'flaggedForReview', 'isFeatured'
            ]))
          ||
          // Attendee updating only the rsvp fields (RSVP / cancel RSVP)
          (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['rsvpUIDs', 'rsvpCount'])
            && (request.resource.data.get('rsvpCount', 0)
                - resource.data.get('rsvpCount', 0)) in [-1, 1])
        );
      // Only the host may delete their own event.
      allow delete: if isAuthenticated()
        && resource.data.get('hostUID', '') == request.auth.uid;
    }

    // ============================================================================
    // EVENT RSVPs COLLECTION (CalendarService)
    // One RSVP document per (eventId, userId) pair.
    // ============================================================================

    match /eventRSVPs/{rsvpId} {
      // Only the RSVP owner may read their own record.
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      // Any authenticated user may create an RSVP for themselves.
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid
        && hasRequiredFields(['userId', 'eventId', 'status', 'createdAt']);
      // Only the RSVP owner may update (e.g. change status, cancel).
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'eventId']);
      // Only the RSVP owner may delete their RSVP.
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // TRANSLATION ANALYTICS COLLECTION (TranslationService / TranslationModerationBridge)
    // Structure: translationAnalytics/{date}/events/{eventId}
    // Analytics events contain no PII or message content — surface/language/cacheHit only.
    // ============================================================================

    match /translationAnalytics/{date} {
      // Server-only reads (admin SDK).
      allow read: if false;
      allow write: if false;

      match /events/{eventId} {
        allow read: if false;  // Server-only reads.
        // Any authenticated user may append an analytics event for their own session.
        // No userId is stored in the event (anonymous aggregate), so there is nothing
        // to scope by ownership — the event contains only surface, language codes, and cacheHit.
        allow create: if isAuthenticated()
          && request.resource.data.keys().hasAll([
            'surface', 'contentType', 'sourceLanguage', 'targetLanguage', 'engineVersion', 'cacheHit'
          ])
          && !request.resource.data.keys().hasAny(['originalText', 'translatedText'])
          && validLength(request.resource.data.sourceLanguage, 10)
          && validLength(request.resource.data.targetLanguage, 10);
        allow update, delete: if false;
      }
    }

    // ============================================================================
    // JOBS PLATFORM
    // (Duplicate /jobListings and /jobApplications rules removed — stricter rules
    // with field validation and protected-field guards live in the Jobs section above)
    // ============================================================================

    match /jobSeekerProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    match /employerProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    match /savedJobs/{savedId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
    }

    match /jobAlerts/{alertId} {
      allow read, write: if isAuthenticated()
                         && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
    }

    match /jobModerationFlags/{flagId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    // ============================================================================
    // CREATOR STUDIO
    // ============================================================================

    match /studioProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    match /studioItems/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isAuthenticated()
                            && resource.data.creatorId == request.auth.uid;
    }

    match /studioServices/{serviceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isAuthenticated()
                            && resource.data.creatorId == request.auth.uid;
    }

    match /studioProducts/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isAuthenticated()
                            && resource.data.creatorId == request.auth.uid;
    }

    match /commissionProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    match /commissionRequests/{requestId} {
      allow read: if isAuthenticated()
                  && (resource.data.clientId == request.auth.uid
                      || resource.data.creatorId == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.clientId == request.auth.uid;
      allow update: if isAuthenticated()
                    && (resource.data.clientId == request.auth.uid
                        || resource.data.creatorId == request.auth.uid);
      allow delete: if false;
    }

    match /bookingRequests/{requestId} {
      allow read: if isAuthenticated()
                  && (resource.data.clientId == request.auth.uid
                      || resource.data.creatorId == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.clientId == request.auth.uid;
      allow update: if isAuthenticated()
                    && (resource.data.clientId == request.auth.uid
                        || resource.data.creatorId == request.auth.uid);
      allow delete: if false;
    }

    match /inquiryThreads/{threadId} {
      allow read: if isAuthenticated()
                  && (resource.data.creatorId == request.auth.uid
                      || resource.data.inquirerId == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.inquirerId == request.auth.uid;
      allow update: if isAuthenticated()
                    && (resource.data.creatorId == request.auth.uid
                        || resource.data.inquirerId == request.auth.uid);
      allow delete: if false;
    }

    match /studioModerationFlags/{flagId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    match /creatorEarnings/{earningsId} {
      allow read: if isAuthenticated()
                  && resource.data.creatorId == request.auth.uid;
      allow write: if false; // Server-only (Cloud Function monthly rollup)
    }

    match /creatorTransactions/{txId} {
      allow read: if isAuthenticated()
                  && resource.data.creatorId == request.auth.uid;
      allow write: if false; // Server-only
    }

    // ============================================================================
    // CALENDAR & EVENTS
    // (Duplicate /faithEvents and /eventRSVPs rules removed — stricter rules
    // with field validation and protected-field guards live in the Events section above)
    // ============================================================================

    match /savedCalendarEvents/{savedId} {
      allow read, write: if isAuthenticated()
                         && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
    }

    match /sentReminders/{reminderId} {
      allow read, write: if false; // Server-only (Cloud Function)
    }

    // Reminder schedules — owner-only
    match /reminderSchedules/{scheduleId} {
      allow read, write: if isAuthenticated()
        && (resource == null || resource.data.get('userId', '') == request.auth.uid)
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // TRANSLATION ANALYTICS (duplicate /translations rule removed — see ~line 2185
    // for the stricter rule that enforces DM blocking and length validation)
    // ============================================================================

    match /translationAnalytics/{date}/events/{eventId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    match /translationModerationAnomalies/{anomalyId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false; // Admin-only review
    }

    // ============================================================================
    // CHARITY RATINGS COLLECTION
    // ============================================================================

    match /charityRatings/{ratingId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false; // Cloud Function only (CharityNavigator sync)
    }

    // ============================================================================
    // MENTOR PROFILES COLLECTION
    // ============================================================================

    match /mentorProfiles/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if false;
    }

    // ============================================================================
    // ACCOUNTABILITY CIRCLES COLLECTION
    // ============================================================================

    match /accountabilityCircles/{circleId} {
      // Field in Firestore is 'memberUIDs' (matches MentorshipView.swift query)
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.get('memberUIDs', []);
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.get('memberUIDs', []);
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.get('memberUIDs', []);
      allow delete: if false;
    }

    // ============================================================================
    // SERVE OPPORTUNITIES COLLECTION
    // ============================================================================

    match /serveOpportunities/{opportunityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.get('createdBy', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('createdBy', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('createdBy', '') == request.auth.uid;
    }

    // ============================================================================
    // MINISTRIES COLLECTION
    // ============================================================================

    match /ministries/{ministryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.get('createdBy', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('createdBy', '') == request.auth.uid;
      allow delete: if false;
    }

    // ============================================================================
    // STUDIO SESSIONS COLLECTION (AMEN Studio)
    // ============================================================================

    match /studioSessions/{sessionId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // CHURCH CHECK-IN COLLECTION
    // Written by FindChurchView when a user checks in to a church
    // ============================================================================

    match /checkins/{churchId}/{userId}/{date} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================================================
    // WHISPER VOICE USAGE COLLECTION
    // Doc ID: "{uid}_{dayTimestamp}" — users read/write their own daily usage
    // ============================================================================

    match /whisperUsage/{docId} {
      allow read: if isAuthenticated()
        && resource.data.get('userId', '') == request.auth.uid;
      allow write: if isAuthenticated()
        && request.resource.data.get('userId', '') == request.auth.uid;
    }

    // ============================================================================
    // BIBLE VERSES COLLECTION
    // Admin-curated scripture cache — authenticated users can read, no client writes
    // ============================================================================

    match /bibleVerses/{verseId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin-only via Cloud Functions / Firebase Console
    }

    // ============================================================================
    // FELLOWSHIP SUGGESTIONS (written by Cloud Function, read by recipient)
    // ============================================================================

    match /fellowshipSuggestions/{docId} {
      // Only the recipient can read their own suggestion
      allow read: if isAuthenticated()
                  && resource.data.get('recipientUserId', '') == request.auth.uid;
      // Users can only update the status field (viewed / dismissed)
      allow update: if isAuthenticated()
                    && resource.data.get('recipientUserId', '') == request.auth.uid
                    && isOnlyUpdating(['status'])
                    && request.resource.data.status in ['viewed', 'dismissed'];
      // Cloud Function writes — no client create/delete
      allow create, delete: if false;
    }

    // ============================================================================
    // ENGAGEMENT NOTIFICATIONS — cap tracking collections (server-write only)
    // ============================================================================

    match /reengagementCaps/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Cloud Function only
    }

    match /prayerCheckinCaps/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /friendReturnedCaps/{capId} {
      allow read, write: if false; // Cloud Function only
    }

    match /sentMilestoneNotifications/{docId} {
      allow read, write: if false; // Cloud Function only
    }

    // ============================================================================
    // MESSAGES FEATURES — Prayer Chain, Time Capsule, Accountability, Grace Drop,
    //                     Testimony Drafts, Prayer Room
    // ============================================================================

    // Feature 01: Prayer chains nested under message threads
    match /messages/{threadId}/prayerChains/{chainId} {
      allow read: if isAuthenticated()
                  && request.auth.uid in resource.data.members;
      allow create: if isAuthenticated()
                    && request.auth.uid == request.resource.data.requesterId
                    && request.auth.uid in request.resource.data.members;
      // Only members can update (to add themselves to prayedBy)
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.members;
      allow delete: if false;
    }

    // Feature 04: Time capsule messages are standard messages with extra fields;
    // access is covered by conversations/{conversationId}/messages rules.
    // Cap tracking docs are server-only.

    // Feature 05: Accountability threads
    match /accountabilityThreads/{threadId} {
      allow read: if isAuthenticated()
                  && request.auth.uid in resource.data.members;
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.members;
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.members
                    && isOnlyUpdating(['streaks', 'lastCheckIn', 'perspectives']);
      allow delete: if false;

      match /checkIns/{weekId}/responses/{userId} {
        allow read: if isAuthenticated()
                    && get(/databases/$(database)/documents/accountabilityThreads/$(threadId)).data.members.hasAny([request.auth.uid]);
        allow write: if isOwner(userId);
      }

      match /weeklyPrompts/{weekId} {
        allow read: if isAuthenticated()
                    && get(/databases/$(database)/documents/accountabilityThreads/$(threadId)).data.members.hasAny([request.auth.uid]);
        allow write: if false; // Cloud Function only
      }
    }

    // Feature 07: Grace drop reveal cap — server only
    // Anonymous drop messages live in conversations/messages, covered by existing rules.

    // Feature 08: Revival nudges — user reads their own, Cloud Function writes
    match /users/{userId}/revivalNudges/{threadId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && isOnlyUpdating(['shown']);
      allow create, delete: if false; // Cloud Function only
    }

    // Feature 09: Shared testimony drafts
    match /testimonyDrafts/{draftId} {
      allow read: if isAuthenticated()
                  && request.auth.uid in resource.data.authors;
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.authors;
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.authors
                    && isOnlyUpdating(['perspectives', 'woven', 'status']);
      allow delete: if false;
    }

    // Feature 09: Community feed entries (shared testimonies publish here)
    match /communityFeed/{docId} {
      allow read: if isAuthenticated();
      // Authenticated authors can publish woven testimonies
      allow create: if isAuthenticated()
                    && request.resource.data.type == 'sharedTestimony'
                    && request.auth.uid in request.resource.data.authors;
      allow update, delete: if false;
    }

    // Feature 10: Prayer room prayedLog
    match /threads/{threadId}/prayedLog/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Feature 10: Prayer room summaries cached per user (client + CF write)
    match /users/{userId}/prayerRoomSummaries/{threadId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ============================================================================
    // TRENDING HASHTAGS COLLECTION
    // Read-only tag suggestions for post composer, written by Cloud Functions.
    // ============================================================================

    match /trendingHashtags/{tagId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // ============================================================================
    // ACCESSIBILITY INTELLIGENCE CACHES
    // Phase 1: Translation refinement cache (MeaningAwareTranslationService)
    // Phase 2: Readability/understand cache (ReadabilityService)
    // Phase 4: Faith glossary (ContextAssistService)
    // All caches are write-protected (populated by Cloud Functions only)
    // ============================================================================

    match /postTranslations/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /commentTranslations/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /contentUnderstandCache/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /contextGlossary/{termKey} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================================================
    // ACTION THREADS + COMPOUND IDENTITY GRAPH + TRUST SIGNALS
    // ============================================================================

    match /actionThreads/{threadId} {
      allow read: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;
      allow delete: if false;

      match /auditLogs/{logId} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/actionThreads/$(threadId)).data.ownerId == request.auth.uid;
        allow create: if isAuthenticated()
          && get(/databases/$(database)/documents/actionThreads/$(threadId)).data.ownerId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /users/{userId}/intelligence/{docId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if false;
    }

    match /users/{userId}/intelligence/agentInsights/{insightId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated()
        && isOwner(userId)
        && request.resource.data.userId == null;
      allow delete: if false;
    }

    match /users/{userId}/intelligence/agentRecommendations/{recId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if false;
    }

    match /users/{userId}/intelligence/executionLogs/{logId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId);
      allow update, delete: if false;
    }

    match /users/{userId}/trust/events/{eventId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated()
        && isOwner(userId)
        && request.resource.data.userId == userId;
      allow update, delete: if false;
    }

    match /users/{userId}/trust/proofSnapshots/{snapshotId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated()
        && isOwner(userId)
        && request.resource.data.userId == userId;
      allow update, delete: if false;
    }

    // ============================================================================
    // TRENDING HASHTAGS COLLECTION (CreatePostView hashtag suggestions)
    // Server-managed aggregation; clients may read but never write directly.
    // ============================================================================
    match /trendingHashtags/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;   // Updated exclusively by Cloud Functions
    }

    // ============================================================================
    // HASHTAGS COLLECTION (discovery index)
    // Server-managed; clients may read but never write directly.
    // ============================================================================
    match /hashtags/{tagId} {
      allow read: if isAuthenticated();
      allow write: if false;   // Updated exclusively by Cloud Functions
    }

    // ============================================================================
    // SYSTEM CONFIGURATION (Server feature flags, internal config)
    // CRITICAL-3: Clients must never read or write these documents.
    // Only the admin SDK (Cloud Functions) may access them.
    // This explicit rule documents the intent; it is enforced by the default deny below.
    // ============================================================================
    match /system/{docId} {
      allow read, write: if false;   // Admin SDK only — enforced by Firestore rules
    }

    // ============================================================================
    // SUSPENSION LOG (HIGH-2: Account suspension audit trail)
    // Admin-readable for case review; never client-writable.
    // ============================================================================
    match /suspensionLog/{uid} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if false;   // Written only by accountSuspension Cloud Function
    }

    // ============================================================================
    // CONTENT VIOLATION LOG (HIGH-1: Media scanning audit trail)
    // Written by mediaScanning Cloud Function on onFinalize events.
    // Admin-readable only; never writable by clients.
    // ============================================================================
    match /contentViolationLog/{logId} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if false;   // Written only by mediaScanning Cloud Function
    }

    // ============================================================================
    // AGE VERIFICATION EVENTS
    // Written by AgeAssuranceService.logVerificationEvent() to create an audit
    // trail of age-gate actions (blocks, verifications, etc.).
    // Users may only write their own events; no client reads (admin-only).
    // ============================================================================
    match /age_verification_events/{eventId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================================================
    // CHURCH JOURNEY SYSTEM
    // Full production rules for Find Church → Plan → Notes → Reflection
    //
    // Helper functions:
    //   journeyIsOwner(d)        — caller owns the journey document
    //   noteSessionIsOwner(d)    — caller owns the note session document
    //   reflectionIsOwner(d)     — caller owns the reflection document
    //   noServerFieldsChanged()  — prevents client from tampering with server-owned fields
    //   validJourneyStatusTransition() — only valid status transitions allowed
    // ============================================================================

    // ---- CHURCHES collection (canonical church records) ----
    // Public read; writes come from admin SDK or Cloud Functions only.
    match /churches/{churchId} {
      // Any signed-in user can read church info for discovery.
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      // No client writes — editorial/verified data is server-owned.
      allow create, update, delete: if false;
    }

    // ---- CHURCH JOURNEYS (top-level, keyed by journeyId) ----
    // Each document belongs to one user (userId field).
    // Server-owned fields: status, outputs.*, contextSnapshot.*, timing.*
    //   confidenceScore, reflectionSeedGenerated — must not be client-writable.
    match /churchJourneys/{journeyId} {
      // Only the owner may read their journey.
      allow get: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated()
        && request.auth.uid != null;

      // Create: caller must claim ownership; required fields enforced.
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'churchId', 'createdAt'])
        // Prevent client from setting server-owned output/intelligence fields at create time.
        && !request.resource.data.keys().hasAny([
             'outputs', 'contextSnapshot', 'confidenceScore',
             'reflectionSeedGenerated', 'noteSessionId', 'reflectionId'
           ]);

      // Update: owner only; server-owned fields are protected.
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        // Block client mutation of server-managed fields.
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'userId', 'churchId', 'createdAt',
             'outputs', 'contextSnapshot', 'confidenceScore',
             'reflectionSeedGenerated'
           ]);

      // Owner may delete a planned journey they haven't started.
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && resource.data.status in ['planned', 'cancelled'];
    }

    // ---- CHURCH NOTE SESSIONS ----
    // Linked to a journey (journeyId field). Owner read/write.
    // Server-owned: reflectionSeedGenerated, highlightsSummary (AI-generated),
    //               status transitions from 'active' → 'completed'.
    match /churchNoteSessions/{sessionId} {
      allow get: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated()
        && request.auth.uid != null;

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'churchId', 'journeyId', 'createdAt'])
        && !request.resource.data.keys().hasAny(['reflectionSeedGenerated', 'highlightsSummary']);

      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        // Owner may freely edit note content, title, scripture refs, status.
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'userId', 'churchId', 'journeyId', 'createdAt',
             'reflectionSeedGenerated',  // Server-set when AI generates seed
             'highlightsSummary'          // Server-set by AI summarization
           ]);

      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ---- CHURCH REFLECTIONS ----
    // Linked to a journey and optionally a note session.
    // Server-owned: aiSummary, aiSuggestedPrayer, aiSuggestedActions, midweekReminderAt.
    match /churchReflections/{reflectionId} {
      allow get: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated()
        && request.auth.uid != null;

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'churchId', 'journeyId', 'createdAt'])
        // AI-generated fields must arrive from Cloud Functions, not the client.
        && !request.resource.data.keys().hasAny([
             'aiSummary', 'aiSuggestedPrayer', 'aiSuggestedActions', 'midweekReminderAt'
           ]);

      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        // Owner may freely edit their personal reflection content.
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'userId', 'churchId', 'journeyId', 'createdAt',
             'aiSummary', 'aiSuggestedPrayer', 'aiSuggestedActions',
             'midweekReminderAt'  // Computed server-side from reminder preference + quiet hours
           ]);

      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ---- USER CHURCH ROUTINES (subcollection) ----
    // Personal routine memory per user. Fully owner-controlled except
    // server-owned fields: confidenceScore, source='learned'.
    match /users/{userId}/churchRoutines/{routineId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && request.resource.data.userId == userId
        && request.resource.data.keys().hasAll(['userId', 'churchId', 'createdAt'])
        // confidenceScore and learned source are only set by the ML routine learner CF.
        && !request.resource.data.keys().hasAny(['confidenceScore'])
        && request.resource.data.get('source', 'manual') != 'learned';

      allow update: if isOwner(userId)
        && resource.data.userId == userId
        // Users may toggle their routine settings freely but cannot forge intelligence.
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'userId', 'churchId', 'createdAt', 'confidenceScore'
           ]);

      allow delete: if isOwner(userId);
    }

    // ---- USER CHURCH ATTENDANCE (subcollection) ----
    // Attendance records. source='location' and confidenceScore are server-only.
    match /users/{userId}/churchAttendance/{attendanceId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && request.resource.data.userId == userId
        && request.resource.data.keys().hasAll(['userId', 'churchId', 'attendedAt', 'source'])
        // Location-inferred attendance and confidence scores are server-set only.
        && request.resource.data.source in ['manual', 'planCompleted']
        && !request.resource.data.keys().hasAny(['confidenceScore']);

      // Attendance records are immutable once created (append-only audit trail).
      allow update, delete: if false;
    }

    // ---- USER CHURCH RHYTHMS (subcollection) ----
    // Aggregated weekly rhythm stats. Server-computed; clients may read only.
    match /users/{userId}/churchRhythms/{rhythmId} {
      allow read: if isOwner(userId);
      // Written exclusively by the learnChurchRoutine Cloud Function.
      allow create, update, delete: if false;
    }

    // ---- CHURCH JOURNEY PREP SUGGESTIONS (server-generated, read by owner) ----
    match /churchJourneyPrepSuggestions/{docId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      // Written by generatePrepSuggestions Cloud Function only.
      allow create, update, delete: if false;
    }

    // ---- CHURCH JOURNEY ANALYTICS (append-only, owner-scoped) ----
    match /churchJourneyAnalytics/{eventId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'eventType', 'createdAt'])
        && request.resource.data.eventType in [
             'church_detail_viewed', 'church_plan_started', 'church_plan_saved',
             'church_routine_saved', 'prep_module_opened', 'prep_module_completed',
             'notes_session_started', 'notes_session_completed',
             'reflection_started', 'reflection_completed', 'ai_reflection_used',
             'reminder_opened', 'reminder_dismissed',
             'routine_suggestion_accepted', 'routine_suggestion_dismissed'
           ];
      allow update, delete: if false;
    }

    // ============================================================================
    // CHURCH NOTES V2 (semantic block system)
    // ============================================================================

    // Top-level note document: owner CRUD.
    // Server-controlled fields: blockCount, hasShareableBlocks, pinnedBlockIds, schemaVersion.
    match /churchNotes/{noteId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.schemaVersion == 2
        && !request.resource.data.keys().hasAny([
             'blockCount', 'hasShareableBlocks', 'pinnedBlockIds'
           ]);

      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.schemaVersion == resource.data.schemaVersion
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'blockCount', 'hasShareableBlocks', 'pinnedBlockIds'
           ]);

      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // Blocks subcollection: owner CRUD on individual blocks.
      // Computed fields (createdAt on create) are client-supplied and acceptable here
      // since Firestore timestamps cannot be server-enforced client-side without a CF.
      match /blocks/{blockId} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/churchNotes/$(noteId)).data.userId
             == request.auth.uid;

        allow create: if isAuthenticated()
          && get(/databases/$(database)/documents/churchNotes/$(noteId)).data.userId
             == request.auth.uid
          && request.resource.data.keys().hasAll(['id', 'type', 'sortOrder', 'visibility'])
          && request.resource.data.visibility in [
               'privateOnly', 'shareable',
               'selectedForPostPreview', 'selectedForSelahEmphasis'
             ];

        allow update: if isAuthenticated()
          && get(/databases/$(database)/documents/churchNotes/$(noteId)).data.userId
             == request.auth.uid
          && request.resource.data.visibility in [
               'privateOnly', 'shareable',
               'selectedForPostPreview', 'selectedForSelahEmphasis'
             ]
          // userId of the parent note never changes
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['id', 'createdAt']);

        allow delete: if isAuthenticated()
          && get(/databases/$(database)/documents/churchNotes/$(noteId)).data.userId
             == request.auth.uid;
      }
    }

    // ============================================================================
    // OBJECT DISCUSSION ROOMS
    // Any canonical object (song, sermon, verse, study, mentor) can spawn
    // community rooms. Auth required; only the creator/member owns their writes.
    // ============================================================================

    match /objectDiscussionRooms/{objectId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only

      match /rooms/{roomId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if isAuthenticated()
          && (resource.data.createdBy == request.auth.uid
              || request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['participantCount', 'lastActivity']));
        allow delete: if false;

        match /messages/{messageId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated()
            && request.resource.data.senderId == request.auth.uid
            && request.resource.data.keys().hasAll(['senderId', 'body', 'createdAt'])
            && request.resource.data.body is string
            && request.resource.data.body.size() > 0
            && request.resource.data.body.size() <= 2000;
          allow update: if isAuthenticated()
            && resource.data.senderId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted'])
            && request.resource.data.isDeleted == true;
          allow delete: if false;
        }

        match /presence/{uid} {
          allow read: if isAuthenticated();
          allow write: if isAuthenticated() && request.auth.uid == uid;
        }
      }
    }

    // ============================================================================
    // SPIRITUAL OS COLLECTIONS (ported from root firestore.rules — CF-write only)
    // ============================================================================

    // Daily Digest — CF writes, owner reads; only isRead client-writable
    match /spiritualOS_digest/{userId}/items/{itemId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if false;
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
        && request.resource.data.isRead is bool;
      allow delete: if false;
    }

    // Unified Hub Inbox — CF writes, owner reads; client may pin/archive/mark-read
    match /spiritualOS_hub/{userId}/items/{itemId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if false;
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isPinned', 'isRead', 'isArchived']);
      allow delete: if false;
    }

    // Life Planner Events — owner full control except bereanNote fields (CF-only)
    match /spiritualOS_planner/{userId}/events/{eventId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && !('isBereanNote' in request.resource.data)
        && !('bereanNote' in request.resource.data);
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isCompleted', 'isDismissed', 'title', 'description',
                      'startDate', 'endDate', 'isAllDay', 'color']);
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Context State — single doc per user, owner read/delete only; CF writes
    match /spiritualOS_context/{userId} {
      allow read, delete: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if false; // updateContextState CF only
    }

    // Berean Suggestions — CF writes, owner reads; client may dismiss
    match /spiritualOS_suggestions/{userId}/items/{itemId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if false;
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDismissed']);
      allow delete: if false;
    }

    // ============================================================================
    // LEGACY MEDIA BRIDGE (read-only until migration completes)
    // ============================================================================

    match /posts/{postId}/mediaMeta/{mediaId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;

      match /captionTracks/{trackId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if false;
      }

      match /keyMoments/{momentId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if false;
      }
    }

    // ============================================================================
    // CONTENT OS — System 33: Discussion, Approval & Forwarding
    // ============================================================================

    // Church notes saved by a user from any ContentCard
    match /churchNotesSaved/{docId} {
      // Owner can create their own note
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'cardId', 'savedAt']);
      // Owner can read and delete their own notes
      allow read, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Permission-approval requests (e.g. "I'd like to share this outside the space")
    match /contentApprovalRequests/{requestId} {
      // Requestor creates the document; requestorId must match their uid
      allow create: if isAuthenticated()
        && request.resource.data.requestorId == request.auth.uid
        && request.resource.data.keys().hasAll(['requestorId', 'creatorId', 'cardId', 'action', 'createdAt']);
      // Both the requestor and the original content creator can read/update (approve/deny)
      allow read: if isAuthenticated()
        && (resource.data.requestorId == request.auth.uid
            || resource.data.creatorId == request.auth.uid);
      allow update: if isAuthenticated()
        && (resource.data.requestorId == request.auth.uid
            || resource.data.creatorId == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'resolvedAt', 'resolverNote']);
      allow delete: if false;
    }

    // Immutable audit log — written by callable function via Admin SDK only
    match /contentAuditLog/{entryId} {
      // Clients may never read or write audit entries directly
      allow read, write: if false;
    }

    // ============================================================================
    // ONE — Private Social OS
    // ============================================================================

    // User profiles — owner full access; strangers see only what privacyMirror allows.
    // Sealed/opaque mirrors block all stranger reads server-side.
    match /one_users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
      // Sealed mirror: no stranger read at all.
      // Opaque/translucent: allow read only if mirror is not "sealed".
      allow read: if isAuthenticated()
        && request.auth.uid != uid
        && resource.data.privacyMirrorLevel != "sealed";

      // Safety settings — strictly owner only.
      match /safetySettings/{docId} {
        allow read, write: if isAuthenticated() && request.auth.uid == uid;
      }
    }

    // Moments — author can write; only authenticated users in the moment's audience can read.
    // For public/witness moments, any auth user may read.
    match /one_moments/{momentId} {
      allow create: if isAuthenticated()
        && request.resource.data.authorUID == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.authorUID == request.auth.uid;
      // Audience read: open to any authenticated user (audience filtering is client-side per ConsentDNA).
      allow read: if isAuthenticated();
    }

    // Vault items — strictly owner only. No other user may ever read vault ciphertext.
    match /one_vaults/{uid}/items/{itemId} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Evidence store — immutable, CF Admin SDK only. Clients may never read or write.
    match /one_evidence/{evidenceID} {
      allow read, write: if false;
    }

    // Moderation queue — CF Admin SDK only. Clients may never read or write.
    match /one_moderationQueue/{docId} {
      allow read, write: if false;
    }

    // Bequest queue — CF Admin SDK only. Clients may never write; owner may read their own scheduled bequests.
    match /one_bequestQueue/{docId} {
      allow read: if isAuthenticated()
        && resource.data.recipientUID == request.auth.uid;
      allow write: if false;
    }

    // E2E threads — participants only.
    match /one_threads/{threadId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid in resource.data.participantUIDs;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participantUIDs;
    }

    // Witness requests — sender or target may read; CF writes only.
    match /one_witnessRequests/{requestId} {
      allow read: if isAuthenticated()
        && (resource.data.fromUID == request.auth.uid
            || resource.data.toUID  == request.auth.uid);
      allow write: if false;
    }

    // Repair flows — participants may read; CF writes only.
    match /one_repairFlows/{flowId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow write: if false;
    }

    // Legacy directives — owner may read/write their own directive.
    match /one_legacyDirectives/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Reach budgets — CF Admin SDK only. Clients may never write (prevents self-inflation).
    match /one_reachBudgets/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false;
    }

    // ============================================================================
    // BEREAN REAL-TIME SESSIONS & TRANSLATION PREFERENCES
    // ============================================================================

    // Berean real-time session data — owner-only access
    match /realtimeSessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;

      match /translationChunks/{chunkId} {
        allow read, write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/realtimeSessions/$(sessionId)).data.ownerId;
      }

      match /scriptureReferences/{refId} {
        allow read, write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/realtimeSessions/$(sessionId)).data.ownerId;
      }
    }

    // Translation preferences — owner-only access
    match /translationPreferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // =========================================================================
    // SAFETY-HARDENING: NEW COLLECTIONS — explicit access control
    // All written exclusively by Cloud Functions Admin SDK (never by clients).
    // =========================================================================

    // Legal-hold CSAM reports. No client or admin reads; delete is prohibited.
    // Only the Functions Admin SDK may write (triggered by CSAM hash detection).
    match /ncmecReports/{reportId} {
      allow read, write: if false;
    }

    // Queue entries that trigger onCSAMDetected. Admin can read for dashboard;
    // no client or admin writes (written by ncmecReporter.js Admin SDK only).
    match /ncmecSubmissionQueue/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Tamper-evident audit log of all moderator review actions.
    // Admin-readable for compliance audits; no writes from any client.
    match /moderationAuditLog/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // SHA-256 hashes of banned phone numbers.
    // Admin-readable only; written only by banUserPhone Cloud Function.
    match /bannedPhones/{hash} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Critical review escalations (SLA-breached moderation items).
    // Admin-readable; written by moderationSweep scheduled function only.
    match /criticalReviewQueue/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Rate limiter counters. No client reads or writes.
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // ============================================================================
    // DEFAULT DENY ALL OTHER COLLECTIONS
    // ============================================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
