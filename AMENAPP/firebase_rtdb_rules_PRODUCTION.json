{
  "rules": {
    ".read": false,
    ".write": false,
    
    "postInteractions": {
      "$postId": {
        ".read": "auth != null",
        ".indexOn": ["timestamp"],

        "lightbulbs": {
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid == $userId"
          }
        },

        "amens": {
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid == $userId"
          }
        },

        "comments": {
          ".indexOn": ["timestamp"],
          "$commentId": {
            ".read": "auth != null",
            ".write": "auth != null",

            "replies": {
              ".indexOn": ["timestamp"]
            }
          }
        }
      }
    },
    
    "conversations": {
      "$conversationId": {
        ".read": "auth != null && (data.child('participantIds').child(auth.uid).exists() || newData.child('participantIds').child(auth.uid).exists())",
        ".write": "auth != null && (data.child('participantIds').child(auth.uid).exists() || newData.child('participantIds').child(auth.uid).exists())",
        
        "messages": {
          ".indexOn": ["timestamp"]
        }
      }
    },
    
    "activityFeed": {
      "global": {
        ".read": "auth != null",
        ".write": false,
        ".indexOn": ["timestamp"]
      }
    },

    "communityActivity": {
      "$communityId": {
        ".read": "auth != null",
        ".write": false,
        ".indexOn": ["timestamp"]
      }
    },

    "prayerActivity": {
      "$postId": {
        ".read": "auth != null",

        "prayingUsers": {
          "$userId": {
            ".write": "auth != null && auth.uid == $userId"
          }
        },

        "count": {
          ".read": "auth != null",
          ".write": false
        }
      }
    },
    
    "users": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth.uid == $userId"
      }
    },
    
    "followers": {
      "$userId": {
        ".read": "auth != null",
        "$followerId": {
          ".write": "auth != null && auth.uid == $followerId"
        }
      }
    },
    
    "following": {
      "$userId": {
        ".read": "auth != null",
        "$followingId": {
          ".write": "auth != null && auth.uid == $userId"
        }
      }
    },
    
    "user_saved_posts": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId",
        "$postId": {
          ".validate": "newData.isNumber()"
        }
      }
    }
  }
}
