rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check admin via JWT custom claim (matches Firestore rules).
    // The 'admin' claim is set by the adminClaims Cloud Function via admin SDK.
    function isAdmin() {
      return request.auth != null && request.auth.token.get('admin', false) == true;
    }

    // Helper function to check file size (in MB)
    function isValidSize(maxSizeMB) {
      return request.resource.size < maxSizeMB * 1024 * 1024;
    }

    // 4.3 CONTENT-TYPE SPOOFING LIMITATION:
    // request.resource.contentType is supplied by the client in the upload request.
    // An attacker can declare contentType: 'image/jpeg' while uploading a PHP script,
    // HTML file, or other malicious payload. The allowlists below act as a deterrent
    // but are NOT a hard security boundary — they only validate the client-declared
    // MIME type, not the actual file bytes.
    //
    // MANDATORY server-side mitigation: deploy a Firebase Storage onFinalize Cloud
    // Function that downloads the file, checks magic bytes with the `file-type` npm
    // package, and deletes files whose actual type does not match the declared type.
    // Without this, Storage URLs served in any web context risk XSS via HTML uploads.

    // P0 FIX: Explicit MIME allowlists to prevent SVG/script injection and
    // exotic video container exploits. 'image/.*' would allow image/svg+xml
    // which can contain embedded scripts.
    function isAllowedImage() {
      return request.resource.contentType in [
        'image/jpeg', 'image/jpg', 'image/png',
        'image/webp', 'image/heic', 'image/heif'
      ];
    }

    function isAllowedVideo() {
      return request.resource.contentType in [
        'video/mp4', 'video/quicktime', 'video/x-m4v'
      ];
    }

    // ========================================
    // PROFILE IMAGES
    // ========================================
    match /profile_images/{userId}/{fileName} {
      // P0 FIX: Require authentication for reads.
      // Unauthenticated scrapers/bots could previously enumerate and download all
      // user profile photos without an account — a mass-harvesting risk, especially
      // for users (e.g. domestic violence survivors) who need profile privacy.
      allow read: if isAuthenticated();

      // Users can only upload to their own folder
      // Max 5MB, must be an allowed image type
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isValidSize(5)
        && isAllowedImage();

      // Users can delete their own profile images
      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ========================================
    // PROFILE IMAGE RESIZED VARIANTS
    // Written ONLY by the firebase/storage-resize-images extension service account.
    // P0 FIX: Deny ALL client writes here. The resize extension writes via admin SDK
    // (bypasses rules). Previously any authenticated user could overwrite
    // another user's resized avatar with arbitrary content.
    // ========================================
    match /profile_images/{userId}/resized/{fileName} {
      allow read;
      // No client write — extension uses admin SDK which bypasses rules.
      allow write: if false;
      allow delete: if false;
    }

    // ========================================
    // USER PHOTOS (Gallery, additional photos)
    // ========================================
    match /user_photos/{userId}/{albumName}/{fileName} {
      // P0 FIX: Require authentication for reads.
      // Previously any unauthenticated caller could download full user photo albums.
      allow read: if isAuthenticated();

      // Users can only upload to their own folder
      // Max 10MB, must be an image or video
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isValidSize(10)
        && (isAllowedImage() || isAllowedVideo());

      // Users can delete their own photos
      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ========================================
    // POST MEDIA — canonical path (new uploads)
    // Path: post_media/{authorUserId}/{postId}/{fileName}
    // The authorUserId segment enforces ownership — only the author can upload
    // to their own post media folder.
    // ========================================
    match /post_media/{authorUserId}/{postId}/{fileName} {
      // Authenticated users can read post media (posts are public within the app).
      allow read: if isAuthenticated();

      // Only the author can upload media to their own post folder.
      // Max 20MB, must be an explicitly allowed image or video MIME type.
      allow write: if isAuthenticated()
        && request.auth.uid == authorUserId
        && isValidSize(20)
        && (isAllowedImage() || isAllowedVideo());

      // Only the author can delete their own post media.
      allow delete: if isAuthenticated()
        && request.auth.uid == authorUserId;
    }

    // ========================================
    // POST IMAGES — legacy upload path used by CreatePostView and
    // FirebasePostServiceEnhancements (posts/{userId}/{fileName} and
    // posts/images/{fileName}).
    // Ownership is enforced on the userId segment where present.
    // ========================================

    // posts/{userId}/{fileName}  — CreatePostView current path
    match /posts/{userId}/{fileName} {
      // Authenticated users can read (posts are public).
      allow read: if isAuthenticated();

      // Only the owner can upload to their own folder.
      // Max 20MB, image or video.
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isValidSize(20)
        && (isAllowedImage() || isAllowedVideo());

      // Only the owner can delete.
      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // posts/images/{fileName}  — LEGACY flat namespace
    // P0 FIX: This path has NO per-user ownership segment. Any authenticated user
    // could overwrite another user's uploaded image by guessing the file name.
    // NEW client writes are DENIED. All new post media must use the ownership-enforced
    // post_media/{authorUserId}/{postId}/{fileName} path instead.
    // Legacy reads remain permitted for auth'd users to avoid breaking existing posts.
    match /posts/images/{fileName} {
      // Authenticated users can read (legacy URLs still work).
      allow read: if isAuthenticated();

      // P0 SECURITY FIX: DENY new writes — no ownership can be established here.
      // Any client could overwrite another user's file. Migrate to post_media/.
      allow write: if false;

      // No client deletes — server cleanup only via admin SDK (account deletion CF).
      allow delete: if false;
    }

    // ========================================
    // TESTIMONY MEDIA
    // Path: testimony_media/{authorUserId}/{testimonyId}/{fileName}
    // ========================================
    match /testimony_media/{authorUserId}/{testimonyId}/{fileName} {
      // Authenticated users can read testimony media (testimonies are public).
      allow read: if isAuthenticated();

      // Only the testimony author can upload media to their own folder.
      // Max 15MB, must be an explicitly allowed image or video MIME type.
      allow write: if isAuthenticated()
        && request.auth.uid == authorUserId
        && isValidSize(15)
        && (isAllowedImage() || isAllowedVideo());

      // Only the testimony author can delete their own media.
      allow delete: if isAuthenticated()
        && request.auth.uid == authorUserId;
    }

    // ========================================
    // DATING PROFILE PHOTOS
    // ========================================
    match /dating_photos/{userId}/{fileName} {
      // Anyone authenticated can read dating photos
      allow read: if isAuthenticated();

      // Users can only upload to their own folder
      // Max 8MB, must be an explicitly allowed image type
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isValidSize(8)
        && isAllowedImage();

      // Users can delete their own dating photos
      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ========================================
    // MESSAGE ATTACHMENTS
    // Path: message_attachments/{senderId}/{recipientId}/{fileName}
    // Both senderId and recipientId are in the path so Storage rules can
    // verify participant identity without a Firestore lookup.
    // ========================================
    match /message_attachments/{senderId}/{recipientId}/{fileName} {
      // Only the sender or the recipient of this attachment can read it.
      allow read: if isAuthenticated()
        && (request.auth.uid == senderId || request.auth.uid == recipientId);

      // Only the sender can upload. Max 10MB.
      // P1 FIX: Restrict to safe content types. Voice notes (audio/m4a, audio/mpeg),
      // images, and PDFs are allowed. "any content type" was too broad —
      // an attacker could upload executable files, HTML, SVG, etc.
      allow write: if isAuthenticated()
        && request.auth.uid == senderId
        && isValidSize(10)
        && (isAllowedImage()
            || isAllowedVideo()
            || request.resource.contentType in [
              'audio/m4a', 'audio/mpeg', 'audio/mp4', 'audio/aac',
              'application/pdf'
            ]);

      // Only the sender can delete their own attachments.
      allow delete: if isAuthenticated()
        && request.auth.uid == senderId;
    }

    // ========================================
    // GROUP CHAT PHOTOS
    // Path: group_photos/{uploaderId}/{fileName}
    // P0-F FIX: Added {uploaderId} segment so Storage rules can verify the uploader's
    // identity. Previously any authenticated user could overwrite any group avatar because
    // the flat group_photos/{fileName} path carried no ownership information.
    // Full group-admin gating (only the group admin may set the avatar) is enforced server-
    // side by the Cloud Function that processes the upload. The Storage rule provides a
    // necessary first layer: the caller must be the authenticated user whose UID matches
    // the path segment, preventing anonymous overwrites of other groups' avatars.
    // ========================================
    match /group_photos/{uploaderId}/{fileName} {
      // Any authenticated user can read group photos (public within app).
      allow read: if isAuthenticated();

      // Only the authenticated user matching the uploaderId path segment may write.
      // Max 5MB, must be an allowed image type.
      // Group-admin enforcement is performed by the server-side Cloud Function.
      allow write: if isAuthenticated()
        && request.auth.uid == uploaderId
        && isValidSize(5)
        && isAllowedImage();

      // Only the uploader can delete their uploaded group photos.
      // Bulk cleanup on group deletion is handled by the account/group-deletion Cloud Function.
      allow delete: if isAuthenticated()
        && request.auth.uid == uploaderId;
    }

    // Legacy flat path - deny writes, allow reads for backward compatibility with old URLs.
    match /group_photos/{fileName} {
      allow read: if isAuthenticated();
      allow write: if false;
      allow delete: if false;
    }

    // ========================================
    // CHURCH VERIFICATION DOCUMENTS
    // ========================================
    match /verification_docs/{userId}/{fileName} {
      // 4.4 FIX: Added isAdmin() to the read condition.
      // Previously only the owner could read their own verification docs, which
      // meant church admins processing verification applications had to use the
      // Firebase Console (not scalable). Admins now read via the JWT 'admin'
      // custom claim, which is set server-side and cannot be forged by clients.
      allow read: if isAuthenticated()
        && (request.auth.uid == userId || isAdmin());

      // Users can upload verification documents
      // Max 5MB, must be image or PDF
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isValidSize(5)
        && (isAllowedImage() || request.resource.contentType == 'application/pdf');

      // Users can delete their verification docs
      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ========================================
    // DEFAULT - DENY ALL
    // ========================================
    // Anything not explicitly allowed above is denied
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
