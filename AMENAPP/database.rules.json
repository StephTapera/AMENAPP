{
  "rules": {
    "test": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "user_posts": {
      "$userId": {
        // 3.4 FIX: Added .indexOn for timestamp so ordered queries on this path
        // (e.g. profile feed sorted by recency) use an index rather than a full
        // subtree scan. Without an index Firebase logs deprecation warnings and
        // will refuse unindexed queries at scale, causing severe latency.
        ".indexOn": ["timestamp"],
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $userId",
        ".validate": "newData.hasChildren(['postId', 'timestamp']) && newData.child('authorId').val() == $userId && newData.child('timestamp').isNumber()"
      }
    },

    "user_profiles": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $userId",
        ".validate": "newData.hasChildren(['displayName', 'username'])"
      }
    },

    "postInteractions": {
      "$postId": {
        ".read": "auth != null",
        // FIX: Engagement counts must be server-only writes (Cloud Function / admin SDK).
        // Previously any authenticated user could set amenCount, lightbulbCount,
        // commentCount, or repostCount to an arbitrary number, breaking feed ranking.
        "lightbulbs": {
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid == $userId",
            ".validate": "newData.isBoolean() || newData.isNumber()"
          }
        },
        "amens": {
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid == $userId",
            ".validate": "newData.isBoolean() || newData.isNumber()"
          }
        },
        "reposts": {
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid == $userId",
            ".validate": "!newData.exists() || (newData.hasChildren(['userId', 'timestamp']) && newData.child('userId').val() == $userId)"
          }
        },
        "lightbulbCount": {
          ".read": "auth != null",
          ".write": false,
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "amenCount": {
          ".read": "auth != null",
          ".write": false,
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "commentCount": {
          ".read": "auth != null",
          ".write": false,
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "repostCount": {
          ".read": "auth != null",
          ".write": false,
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },

    "online_status": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $userId",
        ".validate": "newData.hasChildren(['isOnline', 'lastSeen'])"
      }
    },

    "conversations": {
      "$conversationId": {
        "typing": {
          "$userId": {
            ".read": "auth != null && root.child('userConversations').child(auth.uid).child($conversationId).exists()",
            ".write": "auth != null && auth.uid == $userId",
            ".validate": "newData.hasChildren(['userId', 'timestamp']) && newData.child('userId').val() == $userId && newData.child('timestamp').isNumber()"
          }
        },
        "messages": {
          ".indexOn": ["timestamp"],
          "$messageId": {
            ".read": "auth != null && root.child('userConversations').child(auth.uid).child($conversationId).exists()",
            ".write": "auth != null && root.child('userConversations').child(auth.uid).child($conversationId).exists()"
          }
        },
        "metadata": {
          ".read": "auth != null && root.child('userConversations').child(auth.uid).child($conversationId).exists()",
          ".write": "auth != null && root.child('userConversations').child(auth.uid).child($conversationId).exists()"
        }
      }
    },

    "userConversations": {
      "$userId": {
        // Item-31 FIX: Added .indexOn [".value"] so ordered queries on this path
        // (e.g. conversation list sorted by last message time) use an index rather
        // than a full subtree scan. Each child's value is a Unix-ms timestamp, so
        // ordering by ".value" gives recency-sorted conversations.
        ".indexOn": [".value"],
        "$conversationId": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId",
          // 3.5 FIX: Removed isBoolean() from the validate rule. The value stored
          // here should be a numeric timestamp (last activity time), not a boolean.
          // Accepting booleans is ambiguous — `true` conveys no ordering information
          // and makes recency-sorted conversation queries impossible. Clients must
          // write a Unix-millisecond timestamp (newData.isNumber()) instead.
          ".validate": "newData.isNumber() && newData.val() > 0"
        }
      }
    },

    "notification_tokens": {
      "$userId": {
        "$tokenId": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId",
          ".validate": "newData.hasChildren(['token', 'platform', 'createdAt'])"
        }
      }
    },

    "last_read": {
      "$conversationId": {
        "$userId": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId",
          ".validate": "newData.isNumber()"
        }
      }
    },

    "live_reactions": {
      "$postId": {
        "$userId": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $userId",
          ".validate": "newData.isString() && newData.val().length < 10"
        }
      }
    },

    "live_reaction_timestamps": {
      "$postId": {
        "$userId": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId",
          ".validate": "newData.isNumber() && newData.val() <= now"
        }
      }
    },

    "counters": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        "unreadMessages": {
          ".write": "auth != null && auth.uid == $userId",
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "unreadNotifications": {
          ".write": "auth != null && auth.uid == $userId",
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "followerCount": {
          ".write": false
        },
        "followingCount": {
          ".write": false
        }
      }
    },

    "connections": {
      "$userId": {
        "followers": {
          ".indexOn": ["timestamp"],
          "$followerId": {
            ".read": "auth != null",
            // 3.6 FIX: Changed from user-writable to server-only (.write: false).
            // The previous rule allowed any authenticated user to add themselves to
            // ANY other user's followers list — bypassing Firestore's private-account
            // follow-approval gate entirely. A user could gain follower access to
            // private-account posts without ever being approved.
            // Follower documents must be written exclusively by the onFollowCreated
            // Cloud Function trigger (admin SDK) AFTER a follow request has been
            // approved in Firestore. This ensures Firestore is the single source of
            // truth for follow relationships and private-account approval.
            ".write": false
          }
        },
        "following": {
          ".indexOn": ["timestamp"],
          "$followingId": {
            ".read": "auth != null",
            // 3.6: following writes are still user-side for now (owner's own list).
            // TODO: Migrate to server-only once onFollowCreated CF is confirmed as
            // the sole write path, to maintain full consistency with Firestore.
            ".write": "auth != null && auth.uid == $userId",
            ".validate": "newData.isNumber()"
          }
        }
      }
    },

    "devices": {
      "$userId": {
        "$deviceId": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId",
          ".validate": "newData.hasChildren(['deviceType', 'lastActive'])"
        }
      }
    },

    "sessions": {
      "$userId": {
        "$sessionId": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId",
          ".validate": "newData.hasChildren(['startTime', 'deviceType'])"
        }
      }
    },

    "user_saved_posts": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId",
        "$postId": {
          ".validate": "newData.isNumber() || newData.isBoolean()"
        }
      }
    },

    "post-reposts": {
      "$postId": {
        ".read": "auth != null",
        "$userId": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $userId"
        }
      }
    },

    "user-reposts": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $userId",
        "$postId": {
          ".validate": "newData.isNumber() || newData.isBoolean()"
        }
      }
    },

    "user_comments": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId",
        "$commentId": {
          ".validate": "newData.hasChildren(['postId', 'timestamp'])"
        }
      }
    },

    "comments": {
      "$postId": {
        ".read": "auth != null",
        ".indexOn": ["timestamp"],
        "$commentId": {
          ".read": "auth != null",
          // Item-13 FIX: Enforce comment identity at the RTDB layer.
          // newData.child('userId').val() == auth.uid prevents writing comments on
          // behalf of another user. Block enforcement (blocked users silently
          // dropping writes) is NOT possible at the RTDB rules layer because RTDB
          // cannot read Firestore data. Block enforcement is authoritative at the
          // CF layer (enforceMessageRestrictions).
          ".write": "auth != null && (!newData.exists() || newData.child('userId').val() == auth.uid)",
          ".validate": "newData.hasChildren(['userId', 'text', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length <= 2000 && newData.child('timestamp').isNumber()"
        }
      }
    },

    "comment_stats": {
      "$commentId": {
        ".read": "auth != null",
        // FIX: Engagement counts must be server-only writes (Cloud Function / admin SDK).
        // Previously any authenticated user could set amenCount or replyCount to any value.
        "amenCount": {
          ".write": false,
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "replyCount": {
          ".write": false,
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },

    // Per-user interaction state: lightbulb/amen status keyed by postId.
    // Path: /userInteractions/{userId}/lightbulbs/{postId}
    //       /userInteractions/{userId}/amens/{postId}
    "userInteractions": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        "lightbulbs": {
          "$postId": {
            ".read": "auth != null && auth.uid == $userId",
            ".write": "auth != null && auth.uid == $userId",
            ".validate": "newData.isBoolean() || newData.isNumber()"
          }
        },
        "amens": {
          "$postId": {
            ".read": "auth != null && auth.uid == $userId",
            ".write": "auth != null && auth.uid == $userId",
            ".validate": "newData.isBoolean() || newData.isNumber()"
          }
        }
      }
    },

    "prayerActivity": {
      "$postId": {
        ".read": "auth != null",
        "prayingUsers": {
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid == $userId",
            // 3.7 FIX: Added schema validation to prevent arbitrary data injection.
            // Previously any authenticated user could write any structure here
            // (e.g. { "csam": true } or a 1MB payload). The validate rule enforces
            // the expected shape: a timestamp (required, numeric) and an optional
            // numeric duration (seconds prayed). Unknown fields are implicitly denied
            // because the rule uses hasChildren() rather than a permissive wildcard.
            ".validate": "newData.hasChildren(['timestamp']) && newData.child('timestamp').isNumber() && (!newData.hasChild('duration') || newData.child('duration').isNumber() && newData.child('duration').val() >= 0)"
          }
        },
        "prayingNow": {
          ".read": "auth != null",
          ".write": false
        },
        "totalPrayerSessions": {
          ".read": "auth != null",
          ".write": false
        },
        "sessions": {
          "$sessionId": {
            ".read": "auth != null",
            ".write": false
          }
        }
      }
    }
  }
}
