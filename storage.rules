rules_version = '2';

// ── Storage Security Audit 2026-05-29 ────────────────────────────────────────
// All paths verified against the following criteria:
//   [1] NO wildcard path allows reads without auth — catch-all deny at bottom
//   [2] ALL paths require isOwner(uid) for read/write — no cross-user access
//   [3] ALL upload paths enforce content-type constraints (isAudioType / isImageType / isVideoType)
//   [4] ALL upload paths enforce file size constraints (withinAudioLimit / withinImageLimit / withinVideoLimit)
//   [5] Church notes paths enforce strict owner validation with typed subfolder structure
//   [6] Profile images allow signed-in reads (intentionally public for display) — owner-only write
//   [7] Primary size enforcement for large uploads occurs in Cloud Functions before
//       issuing signed URLs; Storage rules provide defense-in-depth for direct uploads
//
// GAPS (acceptable with current architecture):
//   - Only four Storage path types are declared. Any other path hits the default deny.
//   - Signed URLs (generated by Admin SDK) bypass Storage rules — size/type validation
//     at the CF layer is the primary control for signed-URL upload flows.
// ─────────────────────────────────────────────────────────────────────────────

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Maximum file sizes by media type (enforced where supported by Storage rules).
    // Primary size enforcement happens in the Cloud Function before returning a signed upload URL.
    function withinAudioLimit()  { return request.resource.size <= 100 * 1024 * 1024; }
    function withinImageLimit()  { return request.resource.size <=  20 * 1024 * 1024; }
    function withinVideoLimit()  { return request.resource.size <= 500 * 1024 * 1024; }

    // Allowed content types by folder.
    function isAudioType()  {
      return request.resource.contentType.matches('audio/.*');
    }
    function isImageType()  {
      return request.resource.contentType.matches('image/(jpeg|png|webp|heic|heif)');
    }
    function isVideoType()  {
      return request.resource.contentType.matches('video/(mp4|quicktime|mpeg|avi|webm)');
    }

    // ── Church Notes media ────────────────────────────────────────────────────
    // Path: churchNotes/{uid}/{noteId}/audio/{filename}
    //       churchNotes/{uid}/{noteId}/images/{filename}
    //       churchNotes/{uid}/{noteId}/video/{filename}
    //
    // Rules:
    //  - Only the owning user can upload or read their own media.
    //  - No public reads allowed.
    //  - Type and size constraints enforced at upload.
    //  - Deletion only by the owner.
    //  - Processing service reads via signed URLs generated by Admin SDK.

    match /churchNotes/{uid}/{noteId}/audio/{filename} {
      allow read:   if isOwner(uid);
      allow write:  if isOwner(uid) && isAudioType() && withinAudioLimit();
      allow delete: if isOwner(uid);
    }

    match /churchNotes/{uid}/{noteId}/images/{filename} {
      allow read:   if isOwner(uid);
      allow write:  if isOwner(uid) && isImageType() && withinImageLimit();
      allow delete: if isOwner(uid);
    }

    match /churchNotes/{uid}/{noteId}/video/{filename} {
      allow read:   if isOwner(uid);
      allow write:  if isOwner(uid) && isVideoType() && withinVideoLimit();
      allow delete: if isOwner(uid);
    }

    // ── User profile media (existing pattern — preserved) ─────────────────────

    match /users/{uid}/profileImages/{filename} {
      allow read:   if isSignedIn();
      allow write:  if isOwner(uid) && isImageType() && withinImageLimit();
      allow delete: if isOwner(uid);
    }

    // ── Default deny ──────────────────────────────────────────────────────────

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
