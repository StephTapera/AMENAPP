    // Safety OS: humanReviewQueue — moderators claim and resolve items.
    // Clients cannot read or write. All queue operations go through
    // claimReviewItem / resolveReviewItem / getReviewQueue callables.
    match /humanReviewQueue/{docId} {
      allow read: if isModerator() || request.auth.token.trustSafetyReviewer == true;
      allow create, update, delete: if false;
    }

    // Safety OS: strikes — account violation history.
    // The account owner may read their own strikes. Moderators may read all.
    // Only Cloud Functions (Admin SDK) may write.
    match /strikes/{strikeId} {
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid || isModerator()
      );
      allow create, update, delete: if false;
    }

    // Safety OS: guardianConnections — parent/guardian ↔ minor account links.
    // Both parties (guardianUid and minorUid) may read their own connections.
    // Writes go through callable functions only.
    match /guardianConnections/{connectionId} {
      allow read: if isSignedIn() && (
        resource.data.guardianUid == request.auth.uid ||
        resource.data.minorUid == request.auth.uid ||
        isModerator()
      );
      allow create, update, delete: if false;
    }

    // Safety OS: evidenceRecords — immutable evidence for law enforcement/NCMEC.
    // Only T&S reviewers and admins may read. No client writes ever.
    match /evidenceRecords/{evidenceId} {
      allow read: if isModerator() || request.auth.token.trustSafetyReviewer == true;
      allow create, update, delete: if false;
    }

    // Safety OS: moderation log collections — server-written, moderator-readable.
    match /textModerationLogs/{docId} {
      allow read: if isModerator();
      allow create, update, delete: if false;
    }

    match /imageModerationLogs/{docId} {
      allow read: if isModerator();
      allow create, update, delete: if false;
    }

    match /videoModerationLogs/{docId} {
      allow read: if isModerator();
      allow create, update, delete: if false;
    }

