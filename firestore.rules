rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // True if the caller holds a custom claim that marks them as an admin.
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // True if the caller holds the "moderator" or "admin" custom claim.
    function isModerator() {
      return isSignedIn() &&
        (request.auth.token.moderator == true || request.auth.token.admin == true);
    }

    function hasNoPremiumSpoofFields() {
      return !request.resource.data.keys().hasAny([
        'premiumTier',
        'hasPlusAccess',
        'hasProAccess',
        'premiumEntitlement',
        'customTopicTagCount',
        'aiUsageRemaining',
        'aiUsageLimit'
      ]);
    }

    function premiumFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'premiumTier',
        'hasPlusAccess',
        'hasProAccess',
        'premiumEntitlement',
        'customTopicTagCount',
        'aiUsageRemaining',
        'aiUsageLimit'
      ]);
    }

    // True if the caller is a verified writer: email-verified account, or OAuth provider
    // (Google, Apple, Facebook) which does not require a separate email step.
    // Required before any public UGC write: posts, messages, follow edges.
    function isVerifiedWriter() {
      return isSignedIn() && (
        request.auth.token.email_verified == true ||
        request.auth.token.firebase.sign_in_provider in ['google.com', 'apple.com', 'facebook.com']
      );
    }

    function isSpaceMember(spaceId) {
      return isSignedIn() &&
        (
          exists(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid)) ||
          (
            exists(/databases/$(database)/documents/spaces/$(spaceId)) &&
            get(/databases/$(database)/documents/spaces/$(spaceId)).data.memberIds is list &&
            get(/databases/$(database)/documents/spaces/$(spaceId)).data.memberIds.hasAny([request.auth.uid])
          )
        );
    }

    // True if the caller holds an admin or owner role in the Space.
    // Reads the membership doc — only call where doc read budget allows.
    function isSpaceAdmin(spaceId) {
      return isSpaceMember(spaceId) &&
        get(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid))
          .data.get('roles', []).hasAny(['owner', 'admin']);
    }

    // True if the caller holds a moderation-capable role in the Space.
    function isSpaceModerator(spaceId) {
      return isSpaceMember(spaceId) &&
        get(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid))
          .data.get('roles', []).hasAny(['owner', 'admin', 'moderator', 'pastor', 'elder']);
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // ARCHITECTURE CONTRACT: The main /users/{uid} document must contain ONLY
    // public profile data (displayName, photoURL, bio, churchId, etc.).
    // PII (email, phone, FCM tokens, payment info) MUST live in locked
    // subcollections (/users/{uid}/usage, /users/{uid}/safety, etc.) which
    // are already owner-only below. Never add PII fields to this root document.
    // Broad read is intentional — required for profile browsing and social graph.

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) && hasNoPremiumSpoofFields();
      allow update: if isOwner(uid) && premiumFieldsUnchanged() &&
        // followersCount is a Cloud Function-only counter (set by onUserFollow/onUserUnfollow CF).
        // Self-writes to followersCount enable fake-popularity inflation — block them.
        // followingCount is legitimately incremented by the client on its own doc as part of
        // the FollowService batch write (FollowService.swift:211-214). CF migration is the
        // correct long-term fix; tracked as a caveat in PostSystemAudit.md.
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['followersCount']) &&
        // isMinor is server-derived (set by CF from ageBand); client writes are denied.
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isMinor']);
      allow delete: if isOwner(uid) || isAdmin();

      match /customTopicTags/{tagId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /usage/{usageId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /safety/{docId} {
        allow read: if isOwner(uid) || isModerator();
        allow create, update, delete: if false;

        match /trustedContacts/{contactId} {
          allow read: if isOwner(uid) || isModerator();
          allow create, update, delete: if false;
        }

        match /wellbeingSignals/{signalId} {
          allow read: if isOwner(uid) || isModerator();
          allow create, update, delete: if false;
        }

        match /feedControls/{controlId} {
          allow read: if isOwner(uid) || isModerator();
          allow create, update, delete: if false;
        }

        match /sessionBoundaries/{sessionId} {
          allow read: if isOwner(uid) || isModerator();
          allow create, update, delete: if false;
        }

        match /reports/{reportId} {
          allow read: if isOwner(uid) || isModerator();
          allow create, update, delete: if false;
        }

        match /notifications/{notificationId} {
          allow read: if isOwner(uid);
          allow create, update, delete: if false;
        }
      }

      match /churchDiscovery/{section} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;

        match /items/{itemId} {
          allow read: if isOwner(uid);
          allow create, update, delete: if false;
        }

        match /savedChurches/{churchId} {
          allow read: if isOwner(uid);
          allow create, update, delete: if false;
        }

        match /searches/{searchId} {
          allow read: if isOwner(uid);
          allow create, update, delete: if false;
        }

        match /preferences/{prefId} {
          allow read: if isOwner(uid);
          allow create, update, delete: if false;
        }

        match /interactions/{interactionId} {
          allow read: if isOwner(uid);
          allow create, update, delete: if false;
        }
      }

      // Direct notification subcollection (used by BadgeCountManager).
      match /notifications/{notificationId} {
        allow read: if isOwner(uid);
        allow create: if false;
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Notification state / badge counters (BadgeCountManager).
      match /notificationState/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && !request.resource.data.keys().hasAny(['unseenCount', 'badgeVersion', 'lastDeliveredAt']);
        allow delete: if false;
      }

      // Usage sessions (WellnessGuardianService).
      match /usageSessions/{sessionId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid);
        allow delete: if false;
      }

      // Chat memory (ChatMemoryService).
      match /chatMemory/{chatId} {
        allow read, write: if isOwner(uid);

        match /items/{itemId} {
          allow read, write: if isOwner(uid);
        }
      }

      // User preferences subcollection (ChatMemoryService, MessageSettings, etc.).
      match /preferences/{prefId} {
        allow read, write: if isOwner(uid);
      }

      // Settings subcollection (message settings, notification settings, etc.).
      match /settings/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Following / followers subcollections.
      match /following/{followingId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(uid);
        allow update: if false;
      }

      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(uid);
        allow update: if false;
      }

      // Berean user subcollections.
      match /bereanConversations/{conversationId} {
        allow read, write: if isOwner(uid);
      }

      match /bereanMemory/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /bereanSavedMessages/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /bereanContext/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /bereanActions/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Blessed Later / prayer / reflection.
      match /blessedLater/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /prayerReflections/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /unsentThoughts/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Living entries.
      match /living_entries/{entryId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      match /living_entry_reflections/{reflectionId} {
        allow read, write: if isOwner(uid);
      }

      // Saved content.
      match /savedMoments/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /savedBooks/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /studyPlans/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Media resume state.
      match /mediaResumeState/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Church smart context subcollections.
      match /church_smart_actions/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /church_fit/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /church_discovery_state/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Church assist state (ChurchVisitSessionManager).
      match /churchAssistState/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid);
        allow delete: if false;
      }

      // Church visit insights (ChurchAssistViewModel).
      match /churchVisitInsights/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Church notes subcollection (user-scoped).
      match /churchNotes/{noteId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /churchNoteFolders/{folderId} {
        allow read, write: if isOwner(uid);
      }

      // Trust / wellness / check-ins.
      match /trust/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /wellnessCheckIns/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /koraCheckIns/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /mentorshipCheckIns/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Note links.
      match /noteLinks/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Blocklist subcollection.
      match /blockedUsers/{blockedUserId} {
        allow read: if isOwner(uid) || blockedUserId == request.auth.uid;
        allow create: if isOwner(uid);
        allow delete: if isOwner(uid);
        allow update: if false;
      }

      // Creator projects.
      match /creatorProjects/{projectId} {
        allow read, write: if isOwner(uid);
      }

      // Verification requests.
      match /verificationRequests/{requestId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update, delete: if false;
      }

      // Seen posts (user-scoped).
      match /seenPosts/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Safety OS: guardian alerts — delivered by GuardianConnectionService when a
      // youth safety event occurs on a connected minor account.
      // Only the guardian (the document owner) may read their own alerts.
      // All writes are server-only (Admin SDK).
      match /guardianAlerts/{alertId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      // Safety OS: guardian-approved contacts — contacts a guardian has whitelisted
      // to message a connected minor account.
      // The minor and their guardians may read. Only server (callable) may write.
      match /guardianApprovedContacts/{contactId} {
        allow read: if isOwner(uid) || isModerator();
        allow create, update, delete: if false;
      }

      // ── Calm Control + Spiritual Rhythm OS ───────────────────────────────
      // User-owned preference subcollections. Direct client writes are safe
      // here because these are preference flags, not integrity-critical counters.

      match /privacySettings/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /feedControls/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /presence/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /notificationSettings/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /audienceLayers/{layerId} {
        allow read, write: if isOwner(uid);
      }

      match /spiritualRhythm/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Streaks: owner-read only. All writes go through Cloud Functions
      // (recordSpiritualActivity, recoverStreak) to prevent score spoofing.
      match /streaks/{streakType} {
        allow read: if isOwner(uid);
        allow write: if false; // Writes must go through Cloud Functions (recordSpiritualActivity, recoverStreak)
      }

      match /calmControl/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Universal Create drafts. Owner-readable for restore; writes go through
    // Cloud Functions so server-owned sync metadata cannot be forged.
    match /users/{uid}/drafts/{draftId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /users/{uid}/media/{mediaId} {
      allow read: if isOwner(uid);
      allow write: if false;

      match /transcriptTracks/{trackId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /captionTracks/{trackId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // ── Healthy Media — user-scoped sub-collections ───────────────────────────

    // Media progress: only the owning user can read their own progress.
    // Writes go through updateMediaProgress callable — client cannot write directly.
    match /users/{uid}/mediaProgress/{mediaId} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }

    // Media queues: user can read/delete their own queue items.
    // New items are created by saveToMediaQueue callable only.
    match /users/{uid}/mediaQueues/{queueId} {
      allow read: if isOwner(uid);
      allow create, update: if false;
      allow delete: if isOwner(uid);

      match /items/{itemId} {
        allow read: if isOwner(uid);
        allow create, update: if false;
        allow delete: if isOwner(uid);
      }
    }

    // Media sessions: only the owning user can read their own sessions.
    // Created/completed by createMediaSession + completeMediaSession callables.
    match /users/{uid}/mediaSessions/{sessionId} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }

    // Accessibility preferences: user can read and write their own preferences.
    // System fields (moderationVersion, etc.) are not present here.
    match /users/{uid}/accessibility/mediaPreferences/main {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) &&
        !request.resource.data.keys().hasAny([
          'moderationStatus', 'rankingScore', 'trustScore',
          'systemSafetyLabels', 'moderationVersion'
        ]);
    }

    match /users/{uid}/smartMessageMemory/{nodeId} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }

    match /users/{uid}/smartMessageActions/{actionId} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }

    // Continue-in-AMEN row — owned by user, written only by markEngaged callable.
    match /users/{uid}/continue/{entryId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    function contentVisibleToCaller() {
      return resource.data.ownerId == request.auth.uid ||
        (resource.data.collaborators is list && resource.data.collaborators.hasAny([request.auth.uid])) ||
        (
          resource.data.visibility == 'public' &&
          resource.data.publishState == 'published' &&
          resource.data.moderationState.status == 'approved' &&
          !('deletedAt' in resource.data)
        );
    }

    // Universal ContentNode collection. Client writes are denied; creation,
    // publishing, moderation, deletion, and AI metadata are server-authoritative.
    match /content/{contentId} {
      allow read: if isSignedIn() && contentVisibleToCaller();
      allow create, update, delete: if false;

      match /metrics/{metricId} {
        allow read: if isSignedIn() && metricId == 'aggregate';
        allow write: if false;
      }

      match /replies/{replyId} {
        allow read: if isSignedIn() &&
          (
            get(/databases/$(database)/documents/content/$(contentId)).data.ownerId == request.auth.uid ||
            (
              get(/databases/$(database)/documents/content/$(contentId)).data.visibility == 'public' &&
              get(/databases/$(database)/documents/content/$(contentId)).data.publishState == 'published' &&
              get(/databases/$(database)/documents/content/$(contentId)).data.moderationState.status == 'approved' &&
              resource.data.moderationState.status == 'approved'
            )
          );
        allow write: if false;
      }

      match /threadSummaries/{summaryId} {
        allow read: if isSignedIn() &&
          (
            get(/databases/$(database)/documents/content/$(contentId)).data.ownerId == request.auth.uid ||
            resource.data.ownerId == request.auth.uid
          );
        allow write: if false;
      }
    }

    // ── Featured carousel — admin-curated, moderation-gated ──────────────────
    // Clients may read cards that are active and have passed GUARDIAN review.
    // All writes go through setFeatured / clearFeaturedModeration callables.

    match /featured/{cardId} {
      allow read: if isSignedIn()
                  && resource.data.active == true
                  && resource.data.moderationCleared == true;
      allow write: if false;
    }

    // ── Posts / feed ─────────────────────────────────────────────────────────

    match /posts/{postId} {
      // Authors always see their own posts (incl. drafts/pending).
      // Moderators can read any post for review.
      // Public readers: post must be fully published (not moderating, pending, or removed)
      //   and not set to private_pending (media still processing).
      // Legacy docs without a 'status' field are treated as published (backward compat).
      //
      // VISIBILITY ENFORCEMENT GAP (KNOWN CAVEAT — schema migration required):
      // Post visibility (Everyone/Followers/Community Only) is stored in resource.data.visibility.
      // "Followers" visibility cannot be enforced at the rules level because /follows uses
      // auto-generated IDs (not {followerId}_{followingId}), making exists() checks infeasible.
      // Current enforcement: FeedAPIService filters by followed users; finalizePostPublish
      // callable validates visibility. Direct document reads can bypass followers-only.
      // FIX PATH: Maintain users/{authorId}/followers/{followerId} sub-collection, then add:
      //   resource.data.get('visibility','Everyone') != 'Followers' ||
      //   exists(/databases/$(database)/documents/users/$(resource.data.authorId)/followers/$(request.auth.uid))
      //
      // COVENANT GATE: Posts with a non-empty covenantId are gated content.
      // We require an active covenantSubscriptions document for the requesting user.
      // KNOWN LIMITATION: This checks "has any covenant subscription", not "subscribed to
      // this specific covenant". Full per-covenant enforcement requires restructuring
      // covenantMemberships to users/{uid}/covenantAccess/{covenantId} so exists() can
      // resolve in O(1). Until that migration runs, authors and moderators bypass the gate.
      allow read: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        isModerator() ||
        (
          resource.data.get('publishState', 'published') == 'published' &&
          !(resource.data.get('status', 'published') in ['moderating', 'publishing', 'removed', 'flagged_hidden', 'banned', 'deleted']) &&
          !(resource.data.get('publicationVisibility', 'public') == 'private_pending') &&
          // Safety OS: block content that the moderation pipeline has not approved.
          // New posts start without moderationStatus (treated as approved for backwards
          // compatibility). Posts explicitly blocked/escalated/removed are hidden.
          !(resource.data.get('moderationStatus', 'approved') in ['blocked', 'escalated', 'removed_after_publish']) &&
          (
            resource.data.get('covenantId', '') == '' ||
            exists(/databases/$(database)/documents/covenantSubscriptions/$(request.auth.uid))
          )
        )
      );
      // Client creates posts only as their own — status must be in the allowed
      // initial set. Server fields (publishedAt, moderationDecision, reportCount,
      // safetyDecision, flaggedAt, moderationStatus) must NOT be set by the client.
      // isVerifiedWriter() ensures unverified email accounts cannot publish posts.
      allow create: if isVerifiedWriter() &&
        request.resource.data.authorId == request.auth.uid &&
        !(request.resource.data.get('status', 'publishing') in ['published', 'flagged_published', 'removed', 'banned', 'deleted']) &&
        !(request.resource.data.get('publishState', '') == 'published') &&
        !request.resource.data.keys().hasAny([
          'publishedAt', 'moderationDecision', 'safetyDecision', 'flaggedAt',
          'moderationStatus', 'mediaCaptionModeration', 'captionModeration'
        ]);
      // Edits: author only. Server-owned status/decision/moderation fields are immutable by client.
      allow update: if isSignedIn() &&
        resource.data.authorId == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'authorId', 'publishedAt', 'moderationDecision', 'safetyDecision',
          'reportCount', 'flaggedAt', 'publishState', 'status', 'publicationVisibility',
          // Safety OS: moderationStatus is server-authoritative — client cannot self-approve.
          'moderationStatus', 'mediaCaptionModeration', 'captionModeration',
          // Engagement counters are server-only — Cloud Functions own these values.
          'amenCount', 'lightbulbCount', 'commentCount', 'repostCount', 'savesCount'
        ]);
      allow delete: if isSignedIn() &&
        (resource.data.authorId == request.auth.uid || isModerator());

      match /safety/{docId} {
        allow read: if isSignedIn() && docId != 'decision';
        allow create, update, delete: if false;

        match /integrityLabels/{labelId} {
          allow read: if isSignedIn();
          allow create, update, delete: if false;
        }

        match /claims/{claimId} {
          allow read: if isSignedIn();
          allow create, update, delete: if false;
        }

        match /reports/{reportId} {
          allow read: if isModerator();
          allow create, update, delete: if false;
        }
      }
    }

    // ── Healthy Immersive Media — posts/{postId}/media sub-collections ────────
    // Canonical media path: posts/{postId}/media/{mediaId}
    // Clients can read approved items. All writes are server-controlled via callables.

    match /posts/{postId}/media/{mediaId} {
      // Public viewers only see non-removed, non-hidden items.
      allow read: if isSignedIn() &&
        !(resource.data.get('status', '') in ['removed', 'hidden']) &&
        !(resource.data.get('safety', {}).get('status', '') == 'removed');
      // All writes go through callables (createMediaUploadSession, finalizeMediaUpload, etc.)
      allow create, update, delete: if false;

      // Caption tracks: draft/pending only visible to creator or admin.
      match /captionTracks/{trackId} {
        allow read: if isSignedIn() && (
          resource.data.get('status', '') == 'approved' ||
          resource.data.get('approvedByUser', false) == true ||
          get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid ||
          isAdmin()
        );
        allow create, update, delete: if false;
      }

      // Key moments: draft/pending only visible to creator or admin.
      match /keyMoments/{momentId} {
        allow read: if isSignedIn() && (
          resource.data.get('approvedByUser', false) == true ||
          resource.data.get('status', '') == 'approved' ||
          get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid ||
          isAdmin()
        );
        allow create, update, delete: if false;
      }

      // Draft metadata: creator and admin only — never public.
      match /draftMetadata/{draftId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid ||
          isAdmin()
        );
        allow create, update, delete: if false;
      }

      // Verse-linked moments: same visibility as key moments.
      match /verseLinkedMoments/{momentId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }

      // Explanations: draft until approved, then public.
      match /explanations/{explanationId} {
        allow read: if isSignedIn() && (
          resource.data.get('approvedByUser', false) == true ||
          get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid ||
          isAdmin()
        );
        allow create, update, delete: if false;
      }
    }

    // Legacy mediaMeta path — read-only bridge until migration completes.
    match /posts/{postId}/mediaMeta/{mediaId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;

      match /captionTracks/{trackId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }

      match /keyMoments/{momentId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }
    }

    // ── Media system collections — all server-write only ──────────────────────

    // Ranking signals: server-computed — no client writes ever.
    match /mediaRankingSignals/{mediaId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // Moderation queue: callable-created only, never client-written.
    match /mediaModerationQueue/{mediaId} {
      allow read: if isModerator() || isAdmin();
      allow create, update, delete: if false;
    }

    // Search index: server-maintained only.
    match /mediaSearchIndex/{mediaId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // Analytics events: append-only via callable, no client reads of others' events.
    match /mediaAnalyticsEvents/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Audit logs: server-only.
    match /mediaAuditLogs/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Rate limit windows: server-only.
    match /mediaRateLimits/{docId} {
      allow read, write: if false;
    }

    // ── Churches ─────────────────────────────────────────────────────────────

    match /churches/{churchId} {
      allow read: if isSignedIn();
      // Creator must include themselves in adminUids — prevents privilege escalation
      // and orphaned churches with no admin. Sensitive church creation should go
      // through the createChurch callable for full server-side validation.
      allow create: if isSignedIn() &&
        request.resource.data.adminUids is list &&
        request.resource.data.adminUids.hasAny([request.auth.uid]);
      allow update: if isSignedIn() && (
        resource.data.adminUids.hasAny([request.auth.uid]) || isAdmin()
      );
      allow delete: if isAdmin();

      // Hashed phone list: write only by authenticated user adding their own
      // hash; no one can read the raw list (security through opacity).
      match /memberHashedPhones/{docId} {
        allow read: if false; // server-side only
        allow create: if isSignedIn()
          && request.resource.data.keys().hasOnly(['hashedPhone', 'addedAt'])
          && request.resource.data.hashedPhone is string
          && request.resource.data.hashedPhone.size() == 64; // SHA-256 hex
        allow update, delete: if false; // immutable once written
      }

      // Group/Church Note Intelligence — aggregate insights for church members.
      // Only church members (adminUids or verified members) can read.
      // Server-only writes (context engine callables). Private notes NEVER appear here.
      match /noteInsights/{insightId} {
        allow read: if isSignedIn() && (
          resource.data.churchId == churchId &&
          (
            get(/databases/$(database)/documents/churches/$(churchId)).data.adminUids.hasAny([request.auth.uid]) ||
            exists(/databases/$(database)/documents/churches/$(churchId)/members/$(request.auth.uid))
          )
        );
        allow create, update, delete: if false;
      }
    }

    // ── Action Threads (System 8: Care Workflows) ─────────────────────────────
    // Thread metadata, steps, participants, and audit trail.
    // Participants (coordinator + supporters) can read. Only the thread owner
    // or assigned coordinator can create/update. All audit writes are server-only.

    match /posts/{postId}/actionThreads/{threadId} {
      allow read: if isSignedIn() &&
        (
          resource.data.creatorId == request.auth.uid ||
          exists(/databases/$(database)/documents/posts/$(postId)/actionThreads/$(threadId)/participants/$(request.auth.uid))
        );
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() &&
        (resource.data.creatorId == request.auth.uid || isModerator());
      allow delete: if false;

      match /steps/{stepId} {
        allow read: if isSignedIn() &&
          exists(/databases/$(database)/documents/posts/$(postId)/actionThreads/$(threadId)/participants/$(request.auth.uid));
        allow create, update: if isSignedIn() &&
          exists(/databases/$(database)/documents/posts/$(postId)/actionThreads/$(threadId)/participants/$(request.auth.uid));
        allow delete: if false;
      }

      match /participants/{uid} {
        allow read: if isSignedIn() &&
          exists(/databases/$(database)/documents/posts/$(postId)/actionThreads/$(threadId)/participants/$(request.auth.uid));
        allow create: if isSignedIn() && uid == request.auth.uid;
        allow update: if isSignedIn() && uid == request.auth.uid;
        allow delete: if false;
      }

      match /audit/{entryId} {
        allow read: if isSignedIn() &&
          (
            get(/databases/$(database)/documents/posts/$(postId)/actionThreads/$(threadId)).data.creatorId == request.auth.uid ||
            isModerator()
          );
        allow write: if false;
      }
    }

    // Per-user thread membership index — owner-readable for inbox/dashboard queries.
    // Written server-side when a thread is created or a participant is added.
    match /users/{uid}/actionThreadMemberships/{threadId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ── Berean AI conversations ───────────────────────────────────────────────
    // Each user owns their own conversation tree; no one else can read it.

    match /bereanConversations/{uid}/{conversationId} {
      allow read, write: if isOwner(uid);
    }

    match /bereanConversations/{uid}/{conversationId}/messages/{messageId} {
      allow read, write: if isOwner(uid);
    }

    // ── Moderation queue ─────────────────────────────────────────────────────
    // Any signed-in user can submit a report; only moderators can read/manage.

    match /moderationQueue/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.keys().hasAll(['reporterId', 'contentId', 'reason', 'timestamp']);
      allow read, update, delete: if isModerator();
    }

    // ── User safety records ───────────────────────────────────────────────────
    // Written by safety-gate code on the client; readable only by admins.
    // The writer must be the subject of the record (self-report) or an admin.

    match /userSafetyRecords/{uid} {
      allow read: if isAdmin();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Data export requests ──────────────────────────────────────────────────
    // A user can submit exactly one request for their own data; admins manage.

    match /dataExportRequests/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(['requestedAt', 'status'])
        && request.resource.data.status == 'pending';
      allow read: if isOwner(uid) || isAdmin();
      // Only admins can update status (e.g. mark fulfilled) or delete.
      allow update, delete: if isAdmin();
    }

    // ── Longitudinal / growth profiles ───────────────────────────────────────
    // Personal spiritual-growth data; only the owning user can read or write.

    match /longitudinalProfiles/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Communities / Covenant rooms ─────────────────────────────────────────
    // Legacy /communities (Ark) path. Client direct create is denied — community
    // creation must go through a server-authoritative callable that seeds
    // creatorId, adminUids, memberCount, moderationStatus, and safetyStatus.
    // Server-owned fields (adminUids, memberCount, postCount, rankingScore,
    // safetyStatus, moderationStatus, isOfficial, isArchived, isDeleted) are
    // never client-writable.

    function communityServerOwnedKeys() {
      return [
        'adminUids', 'memberCount', 'postCount', 'rankingScore',
        'safetyStatus', 'moderationStatus', 'isOfficial',
        'isArchived', 'isDeleted', 'creatorId', 'createdAt'
      ];
    }

    function communityUpdateAffectsServerOwnedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(communityServerOwnedKeys());
    }

    match /communities/{communityId} {
      // Read remains permitted only for non-private communities; private
      // communities require server-resolved membership and are not yet
      // exposed via client-readable rule — keep them server-mediated.
      allow read: if isSignedIn()
        && (!('visibility' in resource.data) || resource.data.visibility != 'private');
      // Direct client create is denied. Creation must go through a callable.
      allow create: if false;
      // Update is allowed only for admins/creator AND only when no
      // server-owned field is touched. Moderation status changes must
      // go through a callable.
      allow update: if isSignedIn()
        && (resource.data.adminUids.hasAny([request.auth.uid]) || isAdmin())
        && !communityUpdateAffectsServerOwnedKeys();
      allow delete: if isAdmin();

      match /posts/{postId} {
        allow read: if isSignedIn()
          // Read is denied if the parent community is private/members-only.
          // Membership-gated reads must use a callable; client direct read of
          // a private community's posts is blocked here.
          && (
            !exists(/databases/$(database)/documents/communities/$(communityId))
            || !('visibility' in get(/databases/$(database)/documents/communities/$(communityId)).data)
            || get(/databases/$(database)/documents/communities/$(communityId)).data.visibility == 'public'
          );
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() &&
          (resource.data.authorId == request.auth.uid || isModerator());
      }
    }

    // ── Amen Smart Message Intelligence ──────────────────────────────────────
    // Generated entities, summaries, semantic index rows, and knowledge graph
    // nodes are server-owned. Client writes are limited to explicit user actions
    // that require confirmation: prayer requests and study sessions.

    match /spaces/{spaceId} {
      allow read: if isSpaceMember(spaceId);
      allow create, update, delete: if false;

      match /members/{memberId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update, delete: if false;
      }

      match /smartThreads/{threadId}/messages/{messageId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update, delete: if false;
      }

      match /smartThreads/{threadId}/insights/{insightId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update, delete: if false;
      }

      match /smartThreads/{threadId}/entities/{entityId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update, delete: if false;
      }

      match /smartThreads/{threadId}/studySessions/{sessionId} {
        allow read: if isSpaceMember(spaceId);
        allow create: if isSpaceMember(spaceId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'id', 'spaceId', 'threadId', 'title', 'scriptures', 'topics',
            'notes', 'participants', 'createdBy', 'createdAt', 'updatedAt',
            'seedMessageIds'
          ])
          && request.resource.data.spaceId == spaceId
          && request.resource.data.threadId == threadId;
        allow update, delete: if false;
      }

      match /knowledgeGraph/nodes/nodes/{nodeId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update, delete: if false;
      }

      match /knowledgeGraph/edges/edges/{edgeId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update, delete: if false;
      }

      match /prayerRequests/{requestId} {
        allow read: if isSpaceMember(spaceId);
        allow create: if isSpaceMember(spaceId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'createdBy', 'body', 'visibility', 'category', 'sourceMessageId',
            'threadId', 'status', 'createdAt'
          ])
          && request.resource.data.visibility in ['private', 'selected_people', 'space']
          && request.resource.data.status == 'open';
        allow update, delete: if false;
      }

      match /semanticIndex/items/items/{itemId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update, delete: if false;
      }

      // ── Phase 0: Rooms (Channels) ─────────────────────────────────────────
      // Rooms are created via createRoom callable (admin/owner only).
      // Room metadata (name, kind, archivedAt) is updated via archiveRoom callable.
      // Direct client writes blocked — no field-level exceptions here.
      match /rooms/{roomId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update, delete: if false;

        // Messages within a room. Active members may create (field-restricted).
        // Server owns: guardianStatus, embeddingRef, aiTopics, scriptureRefs.
        // All updates/deletes go through deleteRoomPost callable.
        match /messages/{messageId} {
          allow read: if isSpaceMember(spaceId);
          allow create: if isSpaceMember(spaceId) &&
            request.resource.data.authorId == request.auth.uid &&
            request.resource.data.spaceId == spaceId &&
            request.resource.data.roomId == roomId &&
            request.resource.data.keys().hasOnly([
              'roomId', 'spaceId', 'authorId', 'body', 'mediaRefs',
              'mentionedUserIds', 'replyToId', 'createdAt'
            ]) &&
            !request.resource.data.keys().hasAny([
              'guardianStatus', 'embeddingRef', 'aiTopics', 'scriptureRefs', 'deletedAt'
            ]);
          allow update, delete: if false;
        }
      }

      // ── Phase 0: Events ───────────────────────────────────────────────────
      // Created and managed via Space events callables.
      // Members may read all approved events in their Space.
      match /events/{eventId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update, delete: if false;

        // RSVP sub-collection: owner can create/delete own RSVP.
        // Fields are restricted; server-owned fields (guardianStatus, checkInAt) blocked.
        match /rsvps/{uid} {
          allow read: if isSpaceMember(spaceId);
          allow create: if isSpaceMember(spaceId) &&
            request.auth.uid == uid &&
            request.resource.data.keys().hasOnly(['uid', 'spaceId', 'eventId', 'status', 'createdAt']) &&
            request.resource.data.status in ['going', 'maybe', 'not_going'];
          allow update: if isSpaceMember(spaceId) &&
            request.auth.uid == uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
            request.resource.data.status in ['going', 'maybe', 'not_going'];
          allow delete: if request.auth.uid == uid;
        }
      }

      // ── Phase 0: Presence ─────────────────────────────────────────────────
      // Members see the presence of other members in their Space.
      // Users may write ONLY their own presence doc (field-restricted).
      // Server-owned fields (expiresAt, computed states) are blocked.
      match /presence/{uid} {
        allow read: if isSpaceMember(spaceId);
        allow create, update: if isSpaceMember(spaceId) &&
          request.auth.uid == uid &&
          request.resource.data.keys().hasOnly(['userId', 'spaceId', 'state', 'updatedAt']) &&
          request.resource.data.userId == uid &&
          request.resource.data.spaceId == spaceId &&
          request.resource.data.state in [
            'available', 'studying', 'praying', 'in_event',
            'hosting', 'in_class', 'mentoring', 'do_not_disturb', 'offline'
          ];
        allow delete: if request.auth.uid == uid;
      }

      // ── Phase 0: Roles ───────────────────────────────────────────────────
      // Role documents are written by updateMemberRole callable (admin only).
      // Members may read their own role; admins may read all.
      match /roles/{roleId} {
        allow read: if isSpaceMember(spaceId) &&
          (resource.data.userId == request.auth.uid || isSpaceAdmin(spaceId));
        allow create, update, delete: if false;
      }

      // ── Phase 0: Space Intelligence ──────────────────────────────────────
      // AI-generated Space-level insights. Members read; server writes exclusively.
      // Never writable by client — confidence, provenance, safetyStatus are server-set.
      match /intelligence/{docId} {
        allow read: if isSpaceMember(spaceId);
        allow write: if false;
      }

      // ── Phase 0: Safety Events ───────────────────────────────────────────
      // Moderation events, abuse flags, audit trail. Admin/moderator read only.
      // All writes via server-side moderation callables.
      match /safetyEvents/{eventId} {
        allow read: if isSpaceModerator(spaceId) || isAdmin();
        allow write: if false;
      }

      // ── Phase 0: Relationship Graph ──────────────────────────────────────
      // Private collaboration/mentorship/prayer signal graph. Server-only.
      // No client reads — projection exposed through ScopedIdentityService callable.
      match /relationshipGraph/{edgeId} {
        allow read, write: if false;
      }

      // ── Phase 0: Banners ─────────────────────────────────────────────────
      // Living Banner entries for this Space. Members read; server (or admin callable) writes.
      match /banners/{bannerId} {
        allow read: if isSpaceMember(spaceId);
        allow write: if false;
      }

      // ── Phase 0: Knowledge Nodes ─────────────────────────────────────────
      // Space-level knowledge graph entries (notes, sermons, topics, scripture).
      // Members read; server writes via processSpaceKnowledgeNode callable.
      match /knowledgeNodes/{nodeId} {
        allow read: if isSpaceMember(spaceId);
        allow write: if false;
      }

      // ── Phase 0: Theology Doc ────────────────────────────────────────────
      // The Space's living "what we believe / our story" document.
      // Members read; Berean (via callable) and admins write.
      match /theologyDoc/{docId} {
        allow read: if isSpaceMember(spaceId);
        allow write: if false;
      }
    }

    // ── Phase 0: User Space Preferences ──────────────────────────────────────
    // Per-user, per-space notification and display preferences.
    // Owner reads and writes own prefs (field-restricted).
    match /users/{uid}/spacePreferences/{spaceId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) &&
        request.resource.data.keys().hasOnly([
          'spaceId', 'notificationsEnabled', 'digestEnabled',
          'digestFrequency', 'mutedUntil', 'updatedAt'
        ]);
      allow delete: if isOwner(uid);
    }

    // ── Phase 0: Private Insights ────────────────────────────────────────────
    // AI-generated private insights for the user (contribution quality, trust signals).
    // Owner reads only; server writes exclusively. NEVER expose cross-user.
    match /users/{uid}/privateInsights/{insightId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ── Covenant tiers / subscriptions ───────────────────────────────────────

    match /covenantSubscriptions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      // Writes are performed server-side (Cloud Functions) after payment
      allow write: if false;
    }

    // ── Stripe customer ↔ uid mapping (P1-1) ─────────────────────────────────
    // Written only by createCovenantCheckoutSession callable; the webhook
    // reads this to validate that subscription.metadata.userId matches the
    // Firebase uid that actually paid for this Stripe customer.

    match /stripeCustomers/{customerId} {
      allow read, write: if false;
    }

    // ── Saved Communities (Phase F) ──────────────────────────────────────────
    // Owner-isolated. Direct client writes are blocked; the setCommunitySaved
    // callable performs all writes server-side after validating visibility.

    match /users/{uid}/savedCommunities/{communityKey} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // ── Church Notes ─────────────────────────────────────────────────────────
    // Notes and their subcollections are private to the owning user.
    // Server-owned fields (processing output, AI drafts) cannot be written by clients.

    function isNoteOwner(noteId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/churchNotes/$(noteId)).data.userId == request.auth.uid;
    }

    function isNoteCollaboratorWithRole(noteId, roles) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/churchNotes/$(noteId)/collaborators/$(request.auth.uid))
        && roles.hasAny([
          get(/databases/$(database)/documents/churchNotes/$(noteId)/collaborators/$(request.auth.uid)).data.role
        ]);
    }

    // Safe user-editable fields on the top-level note document.
    function churchNoteAllowedUpdateFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['title', 'sermonTitle', 'sermonSpeaker', 'churchId', 'serviceDate',
                  'journeyId', 'tags', 'scriptureReferences', 'updatedAt',
                  'blockCount', 'hasShareableBlocks', 'pinnedBlockIds']);
    }

    match /churchNotes/{noteId} {
      allow read:   if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid
                      && request.resource.data.keys().hasAll(['userId', 'title', 'createdAt']);
      allow update: if isSignedIn()
                      && (resource.data.userId == request.auth.uid ||
                          isNoteCollaboratorWithRole(noteId, ['owner', 'editor']))
                      && churchNoteAllowedUpdateFields();
      // Clients cannot delete notes directly — soft-delete via callable.
      allow delete: if false;

      // Blocks — owner reads/writes individual blocks; no server-owned field restrictions
      // since blocks contain user-typed content only.
      match /blocks/{blockId} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
        );
        allow write: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor'])
        );
      }

      // Reflections, bridge, and linked prayers — owner read/write.
      match /reflections/{reflectionId} {
        allow read, write: if isSignedIn() && isNoteOwner(noteId);
      }
      match /bridge/{docId} {
        allow read, write: if isSignedIn() && isNoteOwner(noteId);
      }
      match /linkedPrayers/{prayerId} {
        allow read, write: if isSignedIn() && isNoteOwner(noteId);
      }

      // Processing jobs — owner can read and create the initial shell;
      // server-owned output fields (status, transcriptText, ocrText, drafts,
      // safetyStatus, moderationStatus) cannot be written by the client.
      match /processingJobs/{jobId} {
        allow read:   if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
        );
        // Client may create a job shell only through the callable (enforced by callable).
        // Direct client creates are blocked to prevent field injection.
        allow create: if false;
        // Client can cancel (set status = "canceled") only — no other fields.
        allow update: if isSignedIn() && isNoteOwner(noteId)
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['status', 'updatedAt'])
                        && request.resource.data.status == 'canceled';
        allow delete: if false;
      }

      match /collaborators/{uid} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          request.auth.uid == uid ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
        );
        allow write: if false;
      }

      match /comments/{commentId} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
        );
        allow create: if isSignedIn()
          && isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter'])
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'id', 'noteId', 'authorUid', 'authorName', 'body',
            'anchorBlockId', 'anchorRange',
            'anchorText', 'anchorStart', 'anchorEnd',
            'resolved', 'createdAt', 'updatedAt'
          ]);
        allow update: if isSignedIn()
          && resource.data.authorUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['body', 'resolved', 'updatedAt']);
        // Author may delete their own comment. Owner/editor cannot delete others' comments —
        // they should resolve or, if removal is required, perform deletion via a callable
        // that records moderation context.
        allow delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;
      }

      match /media/{mediaId} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
        );
        allow write: if false;
      }

      match /transcripts/{transcriptId} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
        );
        allow write: if false;
      }

      match /ocrResults/{ocrId} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
        );
        allow write: if false;
      }

      match /aiDrafts/{draftId} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor'])
        );
        allow write: if false;
      }

      match /studyGuides/{guideId} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
        );
        allow write: if false;
      }

      match /translations/{translationId} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
        );
        allow write: if false;
      }

      match /events/{eventId} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor'])
        );
        allow write: if false;
      }

      // Action items — created server-side via approveChurchNoteActionItems callable.
      // Clients can read (any collaborator) and toggle completion (owner/editor only).
      match /actionItems/{itemId} {
        allow read: if isSignedIn() && (
          isNoteOwner(noteId) ||
          isNoteCollaboratorWithRole(noteId, ['owner', 'editor', 'commenter', 'viewer'])
        );
        allow create: if false;
        // Only completion-related fields can be updated client-side; everything else
        // (text, sourceJobId, approvedBy, etc.) is server-owned.
        allow update: if isSignedIn()
          && (isNoteOwner(noteId) || isNoteCollaboratorWithRole(noteId, ['owner', 'editor']))
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['completed', 'completedBy', 'completedAt', 'updatedAt']);
        // Owner can delete an action item; editors cannot.
        allow delete: if isSignedIn() && isNoteOwner(noteId);
      }

      // Context Engine outputs — server-only writes (AI-generated context, themes, prompts).
      // Owner reads; no client create/update on AI fields.
      match /context/{contextId} {
        allow read: if isSignedIn() && isNoteOwner(noteId);
        allow create, update, delete: if false;
      }

      // Smart Recap — server generates; client may update editedText and isEdited only.
      match /recaps/{recapId} {
        allow read: if isSignedIn() && isNoteOwner(noteId);
        allow create: if false;
        allow update: if isSignedIn()
          && isNoteOwner(noteId)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['editedText', 'isEdited', 'updatedAt']);
        allow delete: if isSignedIn() && isNoteOwner(noteId);
      }

      // Detected themes — server-only writes; owner reads.
      match /themes/{themeId} {
        allow read: if isSignedIn() && isNoteOwner(noteId);
        allow create, update, delete: if false;
      }

      // Context Engine action suggestions — server writes drafts; client updates approval state only.
      // approvalState, editedText, approvedBy, approvedAt are the only client-editable fields.
      match /actions/{actionId} {
        allow read: if isSignedIn() && isNoteOwner(noteId);
        allow create: if false;
        allow update: if isSignedIn()
          && isNoteOwner(noteId)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['approvalState', 'editedText', 'approvedBy', 'approvedAt', 'updatedAt']);
        allow delete: if isSignedIn() && isNoteOwner(noteId);
      }

      // Provenance audit trail — server-only writes; owner reads for transparency.
      match /provenance/{provenanceId} {
        allow read: if isSignedIn() && isNoteOwner(noteId);
        allow create, update, delete: if false;
      }
    }

    // AI drafts stored under users/{uid}/churchNotes/{noteId}/aiDrafts
    // (legacy path used by createChurchNotesAIDraft callable).
    // Clients can read their own drafts but cannot write AI output fields.
    match /users/{uid}/churchNotes/{noteId}/aiDrafts/{draftId} {
      allow read:   if isOwner(uid);
      // Only callable/admin can create — client cannot write generatedText or moderationStatus.
      allow create, update, delete: if false;
    }

    // Rate limit windows — server writes only; clients never touch these.
    match /rateLimits/{uid}/windows/{windowKey} {
      allow read, write: if false;
    }

    match /comments/{commentId}/safety/{docId} {
      allow read: if isSignedIn() && docId != 'decision';
