      allow read, write: if false;
    }

    match /provenance/{docId} {
      allow read, write: if false;
    }

    match /usedOTPKs/{docId} {
      allow read, write: if false;
    }

    // ── Amen Gatherings (System 38) ──────────────────────────────────────────
    //
    // Security model:
    //   - Public/unlisted gatherings are readable by signed-in users (privacy-shaped by callable).
    //   - Private/roleGated gatherings: prefer callable-backed reads — client reads denied.
    //   - Counts are ALWAYS incremented server-side. Client cannot write counts.
    //   - Users can write ONLY their own RSVP (when allowed by gathering settings).
    //   - Host/admin operations go through callable functions exclusively.
    //   - Prayer/pastoral answers are write-only for the user; hosts read via callable.
    //   - Access pass integration: no client self-grant.

    function isGatheringHost(gatheringId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/gatherings/$(gatheringId)) &&
        get(/databases/$(database)/documents/gatherings/$(gatheringId)).data.createdByUid == request.auth.uid;
    }

    function isPublishedPublicGathering(gatheringId) {
      let g = get(/databases/$(database)/documents/gatherings/$(gatheringId)).data;
      return g.status == "published" && (g.visibility == "public" || g.visibility == "unlisted");
    }

    // Gathering documents
    match /gatherings/{gatheringId} {
      // Public/unlisted published gatherings readable by signed-in users.
      // Private/roleGated readable only by host (prefer callable for privacy shaping).
      allow read: if isSignedIn() && (
        isPublishedPublicGathering(gatheringId) ||
        isGatheringHost(gatheringId) ||
        isAdmin()
      );

      // Clients CANNOT create, update, or delete gatherings directly.
      // All mutations go through Firebase callable functions.
      allow create, update, delete: if false;

      // Questions — readable by anyone who can read the gathering, writable only by callable.
      match /questions/{questionId} {
        allow read: if isSignedIn() && (
          isPublishedPublicGathering(gatheringId) ||
          isGatheringHost(gatheringId)
        );
        allow create, update, delete: if false;
      }

      // RSVPs — privacy-critical subcollection.
      match /rsvps/{uid} {
        // Users can read their own RSVP.
        // Host can read all RSVPs. (Non-host attendee reads are shaped by callable.)
        allow read: if isSignedIn() && (
          request.auth.uid == uid ||
          isGatheringHost(gatheringId) ||
          isAdmin()
        );

        // Users can write their own RSVP ONLY when:
        //   - They are authenticated.
        //   - They are writing for themselves.
        //   - They are NOT setting server-only fields (counts, checkedInAt, answers for sensitive gatherings).
        //   - The RSVP uid matches the auth uid.
        // NOTE: In production, all RSVP writes should go through the callable for
        //       capacity enforcement and count updates. This client write path
        //       is intentionally restricted and supplementary.
        allow create, update: if isSignedIn() &&
          request.auth.uid == uid &&
          // Prevent spoofing uid
          request.resource.data.uid == request.auth.uid &&
          // Prevent client from setting checkedInAt (server-only)
          !request.resource.data.keys().hasAny(["checkedInAt"]) &&
          // Prevent client from incrementing counts (counts live on parent doc)
          !request.resource.data.keys().hasAny(["counts"]);

        allow delete: if isSignedIn() && (
          request.auth.uid == uid ||
          isGatheringHost(gatheringId)
        );
      }

      // Updates (host announcements) — host writes via callable; read by attendees.
      match /updates/{updateId} {
        allow read: if isSignedIn();
        allow create, update, delete: if false;
      }

      // Photos — use existing media pipeline rules; no duplicate upload logic.
      match /photos/{photoId} {
        allow read: if isSignedIn() && (
          isPublishedPublicGathering(gatheringId) ||
          isGatheringHost(gatheringId)
        );
        allow create, update, delete: if false;
      }

      // Comments — reuse existing moderation rules. Client cannot bypass.
      match /comments/{commentId} {
        allow read: if isSignedIn() && (
          isPublishedPublicGathering(gatheringId) ||
          isGatheringHost(gatheringId)
        );
        allow create, update, delete: if false;
      }
    }

    // ── Access Passes ─────────────────────────────────────────────────────────
    // All reads and writes go through callable Cloud Functions.
    // Direct client access is blocked at every level.

    match /accessPasses/{passId} {
      // Callable-only: no direct client reads or writes.
      allow read, write: if false;

      match /events/{eventId} {
        allow read, write: if false;
      }
    }

    // Requester can read their own pending request (to poll status); no direct writes.
    match /accessRequests/{requestId} {
      allow get: if isSignedIn() && resource.data.requesterId == request.auth.uid;
      allow list: if isSignedIn();
      allow write: if false;
    }

    // User can read their own active check-in (to show confirmation UI); no direct writes.
    match /activeCheckIns/{checkInId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow write: if false;
    }

    // Rate limit counters are managed exclusively by backend; clients have no access.
    match /rateLimits/{document=**} {
      allow read, write: if false;
    }

    // Agent traces and AI audit receipts are server-owned. They may include
    // policy metadata, model choices, and safety outcomes, so clients must not
    // read or write them directly.
    match /agentRuns/{runId} {
      allow read, write: if false;

      match /spans/{spanId} {
        allow read, write: if false;
      }
    }

    match /aiAudit/{document=**} {
      allow read, write: if false;
    }

    // Amen Integrations Platform. OAuth states, encrypted token accounts,
    // provider audit logs, idempotency records, and meeting records are managed
    // through App Check protected Cloud Functions only.
    match /amenIntegrationAccounts/{document=**} {
      allow read, write: if false;
    }

    match /amenIntegrationOAuthStates/{document=**} {
      allow read, write: if false;
    }

    match /amenIntegrationAuditLogs/{document=**} {
      allow read, write: if false;
    }

    match /amenIntegrationIdempotency/{document=**} {
      allow read, write: if false;
    }

    match /amenMeetings/{meetingId} {
      allow read, write: if false;

      match /recaps/{recapId} {
        allow read, write: if false;
      }
    }

    // ── Private resonance events — user-scoped, no cross-user access ─────────
    // Heart, pray, save, reflect and all 13 event types are stored privately.
    // No public count is ever derived from these documents — they inform
    // per-user recommendation ranking only.
    match /users/{uid}/resonanceEvents/{eventId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll([
            'eventType', 'contentId', 'contentType', 'sessionId', 'timestamp'
          ])
        && !request.resource.data.keys().hasAny([
            'publicCount', 'aggregateCount', 'visibleTo', 'sharedWith'
          ]);
      allow update, delete: if false;
    }

    // ── System 39: AMEN Integrations Platform ────────────────────────────────
    // All integration collections are server-only except integrationAccounts
    // (read-only for owner) and gatheringMeetingLinks (read joinUrl for members).
    // integrationTokens, oauthStates, rateLimits, idempotencyKeys: admin SDK only.

    // Integration accounts — owner can read own metadata; all writes are server-only.
    match /integrationAccounts/{accountId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Integration tokens — encrypted credentials; admin SDK only. No client access.
    match /integrationTokens/{tokenId} {
      allow read, write: if false;
    }

    // OAuth state tokens — CSRF/PKCE tokens; admin SDK only. No client access.
    match /oauthStates/{stateId} {
      allow read, write: if false;
    }

    // Gathering meeting links — creator can read joinUrl; all writes are server-only.
    // attendees receive joinUrl inline from the createMeetingLink callable response.
    // hostSecrets subcollection (Zoom start_url) is admin SDK only — never to any client.
    match /gatheringMeetingLinks/{linkId} {
      allow read: if isSignedIn()
        && resource.data.creatorUid == request.auth.uid;
      allow write: if false;

      match /hostSecrets/{secretId} {
        allow read, write: if false;
      }
    }

    // Gathering verified content — uploader can read their own record.
    // Writes are server-only (uploaded via signed URL + backend verification).
    match /gatheringVerifiedContent/{contentId} {
      allow read: if isSignedIn()
        && resource.data.uploadedByUid == request.auth.uid;
      allow write: if false;
    }

    // Rate limit counters — admin SDK only.
    match /rateLimits/{limitId} {
      allow read, write: if false;
    }

    // Idempotency keys — admin SDK only.
    match /idempotencyKeys/{keyId} {
      allow read, write: if false;
    }

    // Gathering reminder records — server-only write; creator can read own records.
    match /gatheringReminders/{reminderId} {
      allow read: if isSignedIn()
        && resource.data.createdByUid == request.auth.uid;
      allow write: if false;
    }

    // Integration audit logs — no client access (server-only write, admin-only read).
    match /integrationAuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Remote Config cache mirror (used by assertFeatureEnabled) — read-only, no writes.
    match /remoteConfigCache/{flagName} {
      allow read: if false;
      allow write: if false;
    }

    // ── Conversation OS Intelligence Layer ───────────────────────────────────
    //
    // Architecture contract:
    // - All AI-generated intelligence is written by server (Cloud Functions) only.
    // - Clients may READ their own space summaries and personalized summaries.
    // - Clients may NEVER write AI confidence, provenance, or generated memory.
    // - Sensitive surfaces (prayer_room, leadership_room, admin_channel) require
    //   explicit space-level opt-in (conversationOSOptIn == true on the space doc).
    // - Organization memory is admin-read-only; no client writes.
    // - Activity signals are server-only.

    // Space-level AI summaries — members can read; server writes only.
    match /spaces/{spaceId}/summaries/{summaryId} {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // Space-level topic clusters — members can read; server writes only.
    match /spaces/{spaceId}/topicClusters/{clusterId} {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // Thread-level AI insights (unresolved questions, blockers) — space member read; server writes.
    match /threads/{threadId}/insights/{insightId} {
      // Thread docs don't have membership — inherit from the parent space check done in the callable.
      // Client read is allowed (callable validated membership); writes are server-only.
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Organizational memory — admin-read only; server writes.
    // Contains aggregated org-level patterns and decisions — not for general member access.
    match /organizations/{orgId}/memory/{memoryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // User personalized summaries — owner can read and dismiss (soft delete via merge);
    // all other writes (generation, provenance) are server-only.
    match /users/{uid}/personalizedSummaries/{summaryId} {
      allow read: if isOwner(uid);
      // Allow owner to set `dismissed: true` only — no other fields.
      allow update: if isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["dismissed", "dismissedAt"]) &&
        request.resource.data.dismissed == true;
      allow create, delete: if false;
    }

    // Room activity signals — server-only (ingestion pipeline writes, no client access).
    match /rooms/{roomId}/activitySignals/{signalId} {
      allow read, write: if false;
    }

    // ── Spaces Ambient Intelligence OS ───────────────────────────────────────
    // System 42: Persistent Memory Graph, Semantic Pins, Ambient Signals,
    //            Catch-Up Intelligence, Spiritual Continuity.
    //
    // SECURITY INVARIANTS:
    //   • Intelligence fields (confidence, provenance, moderationPassed) are
    //     server-written only — no client field is accepted via rules.
    //   • SERVER_PIN_TYPES (highly_referenced, emotionally_important, unresolved,
    //     requires_follow_up, momentum_building, fading_urgency, resolved) can
    //     only be written by server processes (callable enforces this in code;
    //     rules block direct client writes to entire collection).
    //   • emotionalContextAllowed space types: family_group and support_community
    //     have no ambient signal reads — enforced at engine level, not rules level
    //     (engine returns [] before writing). Rules allow member read for
    //     dismissed=false signals to avoid leaking which spaces are blocked.
    //   • Spiritual continuity is personal — owner-only across all paths.

    // Space memory nodes — member read (dismissed=false filter client-side);
    // server writes only (persistent_memory_graph callable).
    match /spaces/{spaceId}/memory/{nodeId} {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // Space semantic pins — member read; user can create non-intelligent pins
    // via createUserPin callable; server writes intelligent pins.
    // Direct client writes to this collection are blocked — all writes go through callables.
    match /spaces/{spaceId}/pins/{pinId} {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // Ambient signals — member read; server writes and dismisses.
    // dismissAmbientSignal callable updates dismissed:true — no direct client write.
    match /spaces/{spaceId}/ambientSignals/{signalId} {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // Catch-up intelligence — member read; server writes only.
    match /spaces/{spaceId}/catchUps/{catchUpId} {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // Multi-thread branches — member read; server writes only.
    match /spaces/{spaceId}/branches/{branchId} {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // Context graph (relational intelligence) — member read; server writes only.
    match /spaces/{spaceId}/contextGraph/{nodeId} {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // Unresolved items — member read; server writes only.
    match /spaces/{spaceId}/unresolvedItems/{itemId} {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // User space memory nodes — owner-only read/dismiss; server writes.
    match /users/{uid}/spaceMemory/{nodeId} {
      allow read: if isOwner(uid);
      // Allow owner to dismiss only — server controls all other fields.
      allow update: if isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["dismissed", "dismissedAt"]) &&
        request.resource.data.dismissed == true;
      allow create, delete: if false;
    }

    // Spiritual continuity — owner-only read; server writes and merges.
    // recordSelahMoment callable updates via Admin SDK (bypasses rules).
    match /users/{uid}/spiritualContinuity/{recordId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Organizations/spaces mapping — admin read; server writes.
    match /organizations/{orgId}/spaces/{spaceId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Unified organization identity profiles. Clients may read safe public orgs.
    // Source fields, claim state, verification, safety, billing, and imports are
    // function-owned. Verified owners can edit only approved public profile fields.
    match /organizations/{orgId} {
      allow read: if isSignedIn() &&
        resource.data.visibility == "public" &&
        resource.data.safetyStatus in ["allowed", "approved", "sourceImported"];
      allow create, delete: if false;
      allow update: if isSignedIn() &&
        resource.data.ownerUid == request.auth.uid &&
        resource.data.claimStatus in ["claimed", "verified"] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "description",
          "website",
          "phone",
          "bannerConfig",
          "spaceDefaults",
          "updatedAt"
        ]);

      match /claims/{claimId} {
        allow read: if isSignedIn() &&
          (resource.data.uid == request.auth.uid || isAdmin());
        allow create, update, delete: if false;
      }

      match /suggestedEdits/{editId} {
        allow read: if isAdmin();
        allow create, update, delete: if false;
      }

      match /events/{eventId} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      match /members/{uid} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if false;
      }

      match /auditLogs/{logId} {
        allow read: if isAdmin();
        allow write: if false;
      }

      match /billing/{billingDoc} {
        allow read: if isSignedIn() &&
          (get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid || isAdmin());
        allow write: if false;
      }
    }

    match /organizationDirectoryImports/{importId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /opsRuns/{runId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /users/{uid}/organizationMemberships/{orgId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /users/{uid}/organizationClaims/{claimId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // National organization directory. Clients may search public, moderated source
    // records. Import, claim approval, official space creation, and paid checkout
    // creation are server-authoritative through Cloud Functions.
    match /amenNationalDirectory/{profileId} {
      allow read: if isSignedIn() &&
        resource.data.visibility == "public" &&
        resource.data.moderationStatus in ["approved", "sourceImported"];
      allow create, update, delete: if false;

      match /claims/{uid} {
        allow read: if isOwner(uid) || isAdmin();
        allow create, update, delete: if false;
      }

      match /suggestedEdits/{editId} {
        allow read: if isAdmin();
        allow create, update, delete: if false;
      }
    }

    match /amenDirectorySubscriptionCheckouts/{checkoutId} {
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /amenOrganizationClaimRateLimits/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    match /amenBillingWebhookEvents/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Selah Banner Rail ────────────────────────────────────────────────────
    // Architecture invariant: clients NEVER read bannerSources directly.
    // All eligibility, ranking, visibility, safety, and CTA validation run
    // server-side in the resolveBannerRail / validateAmenSpaceBannerCTA callables.
    //
    // moderationStatus + safety fields (contentRating, safeForYouth, safeForAll,
    // safetyTier) are writable ONLY via the Admin SDK (Cloud Functions).
    // A client can create a draft but must not include those fields; the
    // createBannerSource callable sets moderationStatus="pending" server-side.
    //
    // bannerDisplayPreferences/{uid} is scoped to the document owner only.
    // amenSpaces/{id}/settings/bannerDisplay (defaultBannerSize) is written
    // only by the setAmenSpaceDefaultBannerSize callable (space admin check
    // enforced in the function; rule locks out all direct client writes).

    match /bannerSources/{bannerId} {
      // Clients never read bannerSources directly — resolveBannerRail returns
      // a sanitised payload without moderationStatus or safety fields.
      allow read: if false;

      // Authors may create a draft, but must NOT supply moderation or safety fields.
      // The createBannerSource callable (Admin SDK) sets those fields server-side.
      allow create: if isVerifiedWriter() &&
        request.resource.data.createdBy == request.auth.uid &&
        !request.resource.data.keys().hasAny([
          "moderationStatus", "contentRating", "safeForYouth", "safeForAll", "safetyTier"
        ]);

      // Authors may edit their own pending drafts, but cannot touch moderation
      // or safety fields — those are Admin SDK territory.
      allow update: if isVerifiedWriter() &&
        resource.data.createdBy == request.auth.uid &&
        resource.data.moderationStatus == "pending" &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          "moderationStatus", "contentRating", "safeForYouth", "safeForAll", "safetyTier"
        ]);

      // Hard delete is disallowed; soft-delete via callable only.
      allow delete: if false;
    }

    // User's per-surface size preferences — owner read/write, no delete.
    match /bannerDisplayPreferences/{uid} {
      allow read, create, update: if isOwner(uid);
      allow delete: if false;
    }

    // amenSpaceBanners is a read-only materialised view maintained by Admin SDK.
    match /amenSpaceBanners/{bannerId} {
      allow read: if isSignedIn() &&
        resource.data.moderationStatus in ["approved", "visible"] &&
        resource.data.visibility in ["public", "authenticated"];
      allow create, update, delete: if false;
    }

    // Analytics events are written only by the logAmenSpaceBannerEvent callable.
    match /amenSpaceBannerAnalytics/{eventId} {
      allow read, write: if false;
    }

    // Legacy sub-collection path kept for backwards-compat; no client writes.
    match /users/{uid}/bannerDisplayPreferences/{surfaceId} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }

    match /users/{uid}/dismissedSpaceBanners/{bannerId} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }

    // Space banner display settings (defaultBannerSize) — written only by the
    // setAmenSpaceDefaultBannerSize callable which enforces the admin/owner check.
    match /amenSpaces/{spaceId}/settings/bannerDisplay {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Comms OS Intelligence Layer ──────────────────────────────────────────
    // System 45: All AI operations route through Cloud Functions (callable
    // enforces App Check + auth + membership). Admin SDK bypasses rules;
    // clients never write these collections directly.

    // Audit log — server writes via Admin SDK only; no client access.
    match /commsAuditLog/{logId} {
      allow read, write: if false;
    }

    // Media intelligence jobs — server-managed queue; status returned by callable.
    match /commsMediaJobs/{jobId} {
      allow read, write: if false;
    }

    // Thread summaries — server writes via callable; value returned in response.
    match /commsThreadSummaries/{summaryId} {
      allow read, write: if false;
    }

    // User comms digests — owner can read and soft-dismiss; all other writes via callable.
    match /users/{uid}/commsDigests/{digestId} {
      allow read: if isOwner(uid);
      allow update: if isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["dismissed", "dismissedAt"]) &&
        request.resource.data.dismissed == true;
      allow create, delete: if false;
    }

    // User comms feedback — server writes via callable; not exposed to client reads.
    match /users/{uid}/commsFeedback/{feedbackId} {
      allow read, write: if false;
    }

    // Comms rate-limit counters — server-managed only; no client access.
    match /users/{uid}/commsRateLimits/{operation} {
      allow read, write: if false;
    }

    // ── Creator analytics — author read; Cloud Function writes ───────────────

    match /postAnalytics/{docId} {
      // Only the post author may read their own analytics. Never client-writable.
      allow get: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow list: if isSignedIn();
      allow write: if false;
    }

    // ── Impression events — server-aggregated; no client access ───────────────
    // Raw impression events are aggregated server-side. Client reads aggregate
    // totals from postAnalytics, never raw impression documents.

    match /impressions/{docId} {
      allow read, write: if false;
    }

    // ── Media upload sessions — owner read; Cloud Function manages lifecycle ──

    match /mediaUploads/{docId} {
      // Uploader may read their own session (for progress/status).
      allow get: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
      allow list: if isSignedIn();
      allow write: if false;
    }

    // ── Top-level content reports — verified users create; moderators manage ──

    match /reports/{docId} {
      allow create: if isVerifiedWriter() &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.keys().hasAll(['reporterId', 'contentId', 'contentType', 'reason']);
      allow read, update, delete: if isModerator();
    }

    // ── Churches ──────────────────────────────────────────────────────────────

    match /churches/{churchId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedWriter() &&
        request.resource.data.founderUid == request.auth.uid &&
        request.resource.data.keys().hasAll(['name', 'founderUid']);
      allow update: if isSignedIn() && resource.data.founderUid == request.auth.uid;
      allow delete: if isAdmin();

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isOwner(memberId) &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.keys().hasAll(['churchId', 'uid', 'role', 'joinedAt']);
        allow update: if false;
        allow delete: if isOwner(memberId) || isAdmin();
      }
    }

    // ── Groups ─────────────────────────────────────────────────────────────────

    match /amenGroups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedWriter() &&
        request.resource.data.hostUid == request.auth.uid &&
        request.resource.data.keys().hasAll(['name', 'hostUid', 'churchId', 'type', 'visibility']);
      allow update: if isSignedIn() && resource.data.hostUid == request.auth.uid;
      allow delete: if isAdmin();

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isOwner(memberId) &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.keys().hasAll(['groupId', 'uid', 'role', 'joinedAt']);
        allow update: if false;
        allow delete: if isOwner(memberId) ||
          (isSignedIn() &&
           get(/databases/$(database)/documents/amenGroups/$(groupId)).data.hostUid == request.auth.uid);
      }
    }

    // ── Discipleship pairs ─────────────────────────────────────────────────────

    match /discipleships/{pairId} {
      allow read: if isSignedIn() && (
        resource.data.mentorUid == request.auth.uid ||
        resource.data.discipleUid == request.auth.uid
      );
      allow create: if isVerifiedWriter() &&
        (request.resource.data.mentorUid == request.auth.uid ||
         request.resource.data.discipleUid == request.auth.uid) &&
        request.resource.data.keys().hasAll(['mentorUid', 'discipleUid', 'status', 'createdAt']) &&
        request.resource.data.status == 'pending';
      allow update: if isSignedIn() &&
        (resource.data.mentorUid == request.auth.uid ||
         resource.data.discipleUid == request.auth.uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'endedAt']);
      allow delete: if false;
    }

    // ── Follows ────────────────────────────────────────────────────────────────

    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedWriter() &&
        request.resource.data.followerId == request.auth.uid &&
        request.resource.data.keys().hasAll(['followerId', 'followingId', 'createdAt']);
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // ── Channels ───────────────────────────────────────────────────────────────
    // SACRED INVARIANT: no Cloud Function, Berean feature, or analytics pipeline
    // may ever read or write sacredMessages or keyMaterial subcollections.

    function isChannelParticipant(channelId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/channels/$(channelId))
          .data.participantUids.hasAny([request.auth.uid]);
    }

    match /channels/{channelId} {
      allow read: if isChannelParticipant(channelId);
      allow create: if isVerifiedWriter() &&
        request.resource.data.participantUids.hasAny([request.auth.uid]) &&
        !request.resource.data.keys().hasAny(['isMinor']);
      allow update: if false;
      allow delete: if false;

      // Communal messages — Guardian Cloud Function sets isDelivered after moderation
      match /messages/{messageId} {
        allow read: if isChannelParticipant(channelId);
        allow create: if isChannelParticipant(channelId) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.isDelivered == false &&
          request.resource.data.keys().hasAll(['senderId', 'text', 'sentAt', 'isDelivered']) &&
          !request.resource.data.keys().hasAny(['guardianDecision', 'supportResourcesAttached', 'scriptureRefs']);
        allow update: if false;
        allow delete: if false;
      }

      // Sacred messages — ciphertext only; plaintext never persisted
      // CRITICAL: No Cloud Function may trigger on or read this subcollection.
      match /sacredMessages/{messageId} {
        allow read: if isChannelParticipant(channelId);
        allow create: if isChannelParticipant(channelId) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.keys().hasAll(['senderId', 'ciphertextBase64', 'nonceBase64', 'tagBase64', 'sentAt']) &&
          !request.resource.data.keys().hasAny(['plaintext', 'text', 'decryptedText']);
        allow update: if false;
        allow delete: if false;
      }

      // Key material — participants read to unwrap their copy; bootstrapped once
      // CRITICAL: No Cloud Function may trigger on or read this subcollection.
      match /keyMaterial/{docId} {
        allow read: if isChannelParticipant(channelId);
        allow create: if isChannelParticipant(channelId) &&
          request.resource.data.keys().hasAll(['wrappedKeyA', 'wrappedKeyB']);
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── Meetings ───────────────────────────────────────────────────────────────

    function isGroupMember(groupId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/amenGroups/$(groupId)/members/$(request.auth.uid));
    }

    function isGroupHost(groupId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/amenGroups/$(groupId)).data.hostUid == request.auth.uid;
    }

    match /meetings/{meetingId} {
      allow read: if isSignedIn() && isGroupMember(resource.data.groupId);
      allow create: if isVerifiedWriter() &&
        isGroupHost(request.resource.data.groupId) &&
        request.resource.data.hostUids.hasAny([request.auth.uid]) &&
        request.resource.data.keys().hasAll(['groupId', 'hostUids', 'title', 'startAt', 'status']) &&
        request.resource.data.status == 'scheduled';
      allow update: if isSignedIn() &&
        resource.data.hostUids.hasAny([request.auth.uid]) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['groupId']);
      allow delete: if isAdmin();

      match /rsvps/{uid} {
        allow read: if isGroupMember(
          get(/databases/$(database)/documents/meetings/$(meetingId)).data.groupId);
        allow create, update: if isOwner(uid) &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.keys().hasAll(['uid', 'status', 'updatedAt']);
        allow delete: if isOwner(uid);
      }
    }

    // ── Prayer requests ────────────────────────────────────────────────────────

    match /prayerRequests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.authorUid == request.auth.uid ||
        isGroupMember(resource.data.groupId)
      );
      allow create: if isVerifiedWriter() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.keys().hasAll(['authorUid', 'groupId', 'text', 'createdAt', 'status']) &&
        request.resource.data.status == 'open';
      allow update: if isSignedIn() &&
        resource.data.authorUid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'answeredAt']);
      allow delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;
    }

    // ── Moderation queue — admin SDK (Cloud Function) writes only ─────────────
    // Written by GUARDIAN on escalate verdict. No client read or write ever.

    match /moderationQueue/{docId} {
      allow read, write: if false;
    }

    // ── Progressive Trust — trust events per user (owner read, server write) ──

    match /trustEvents/{uid}/events/{eventId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /trustAuditLog/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Interaction Mode History (owner read, server write) ───────────────────

    match /users/{uid}/modeHistory/{historyId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ── Behavioral Alerts (moderator read, server write) ─────────────────────

    match /behavioralAlerts/{alertId} {
      allow read: if isAdmin() || isModerator() || isTrustSafetyReviewer();
      allow write: if false;
    }

    // ── Mentorship Connections (participants read, server write) ──────────────

    match /mentorshipConnections/{connectionId} {
      allow read: if isSignedIn() && (
        resource.data.mentorUid == request.auth.uid ||
        resource.data.menteeUid == request.auth.uid
      );
      allow write: if false;
    }

    // ── Church / Community Verification (owner read, server write) ───────────

    match /churchVerifications/{verificationId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /churches/{churchId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /verificationCodes/{code} {
        allow read, write: if false;
      }
    }

    // ── Text Rewrite Rate Limits and Logs (server-only) ──────────────────────

    match /rewriteRateLimits/{uid}/windows/{windowId} {
      allow read, write: if false;
    }

    match /textRewriteLogs/{logId} {
      allow read: if isAdmin() || isModerator();
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // ── Amen Trust + Safety OS — Extended Collections ──────────────────────
    //
    // ARCHITECTURE CONTRACT:
    //   Clients CANNOT write safety decisions, provenance, bot scores,
    //   trust profiles, audit logs, ranking safety fields, or enforcement
    //   records. All writes go through Cloud Functions with Admin SDK only.
    //   Clients read their own data; moderators/admins read all.
    // ═══════════════════════════════════════════════════════════════════════

    // ── Per-User Trust + Enforcement (users/{uid}/trust) ─────────────────

    match /users/{uid}/trust/profile {
      // User can read their own trust profile; moderators can read any.
      allow read: if isOwner(uid) || isModerator();
      // Only backend (Admin SDK) can write trust profiles.
      allow create, update, delete: if false;
    }

    match /users/{uid}/trust/devices/{deviceId} {
      allow read: if isOwner(uid) || isModerator();
      allow create, update, delete: if false;
    }

    match /users/{uid}/trust/strikes/{strikeId} {
      allow read: if isOwner(uid) || isModerator();
      // Strikes are backend-only. Clients cannot delete or modify them.
      allow create, update, delete: if false;
    }

    // ── Per-User Wellness Events ──────────────────────────────────────────

    match /users/{uid}/wellness/events/{eventId} {
      allow read: if isOwner(uid) || isModerator();
      allow create, update, delete: if false;
    }

    // ── Post Safety + Provenance + Ranking ───────────────────────────────

    match /posts/{postId}/safety/main {
      // Authors and moderators can read safety decisions.
      allow read: if isSignedIn();
      // Clients CANNOT write safety decisions.
      allow create, update, delete: if false;
    }

    match /posts/{postId}/provenance/main {
      allow read: if isSignedIn();
      // Provenance is backend-only: clients cannot fake source claims.
      allow create, update, delete: if false;
    }

    match /posts/{postId}/ranking/main {
      allow read: if isSignedIn();
      // Ranking scores are backend-only: prevents score manipulation.
      allow create, update, delete: if false;
    }

    match /posts/{postId}/reports/{reportId} {
      // Reporter or moderator can read. No client deletes.
      allow read: if isSignedIn() &&
        (resource.data.reporterUid == request.auth.uid || isModerator());
      allow create, update, delete: if false;
    }

    match /posts/{postId}/audit/{eventId} {
      allow read: if isModerator();
      allow create, update, delete: if false;
    }

    // ── Reply Preview Rotation — dynamicReplyPreviews subcollection ───────
    // Written exclusively by the rebuildReplyPreviews Cloud Function (Admin SDK).
    // Clients read only when the parent post is visible to them.

    match /posts/{postId}/dynamicReplyPreviews/{previewId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/posts/$(postId)).data.get('removed', false) == false
      );
      allow write: if false; // Cloud Functions only
    }

    // ── Comment Safety ────────────────────────────────────────────────────

    match /comments/{commentId}/safety/main {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // ── DM / Message Safety ───────────────────────────────────────────────

    match /messages/{messageId}/safety/main {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // ── Media Provenance + Safety ─────────────────────────────────────────

    match /media/{mediaId}/provenance/main {
      allow read: if isSignedIn();
      // Cannot be client-modified. Prevents fake "original" declarations.
      allow create, update, delete: if false;
    }

    match /media/{mediaId}/safety/main {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // ── Community + Church + Creator Trust ───────────────────────────────

    match /communities/{communityId}/trust/main {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /churches/{churchId}/verification/main {
      allow read: if isSignedIn();
      // Church verification is admin-only write.
      allow create, update, delete: if false;
    }

    match /creators/{creatorId}/trust/main {
      // Creator can read their own trust record; moderators read all.
      allow read: if (isSignedIn() && request.auth.uid == creatorId) || isModerator();
      allow create, update, delete: if false;
    }

    // ── Reviews + Testimonials Safety ────────────────────────────────────

    match /reviews/{reviewId}/safety/main {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /testimonials/{testimonialId}/safety/main {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // ── Platform Safety: Audit, Queues, Threat Intel ─────────────────────
    //
    // These are the most sensitive collections.
    // Clients have ZERO write access to any platformSafety subcollection.
    // Only moderators and admins can read; reporters can read their own.

    match /platformSafety/audit/events/{eventId} {
      allow read: if isModerator();
      allow create, update, delete: if false;
    }

    match /platformSafety/queues/moderation/{queueId} {
      // Reporter can read their own report; moderators read all.
      allow read: if isModerator() ||
        (isSignedIn() && resource.data.reporterUid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /platformSafety/queues/humanReview/{queueId} {
      // Appellant can read their own appeal; moderators read all.
      allow read: if isModerator() ||
        (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /platformSafety/queues/escalation/{queueId} {
      // Admin-only: escalation queue contains most sensitive cases.
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /platformSafety/threatIntel/{signalId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ── Amen Intelligence Fabric ─────────────────────────────────────────
    //
    // Client writes are limited to the signed-in user's own context snapshots
    // and feedback/audit events. Server-derived decisions, moderation outputs,
    // and reputation signals remain backend-owned.

    match /amenIntelligenceSnapshots/{snapshotId} {
      allow read: if isModerator() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid', 'contentId', 'contentType', 'surface', 'implementations',
          'humanStates', 'spiritualIntents', 'safetyTreatment', 'trustSignals',
          'feedMode', 'environment', 'shouldReduceAmplification',
          'companionPrompt', 'cards', 'metadata', 'updatedAt'
        ]);
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'implementations', 'humanStates', 'spiritualIntents', 'safetyTreatment',
          'trustSignals', 'feedMode', 'environment', 'shouldReduceAmplification',
          'companionPrompt', 'cards', 'metadata', 'updatedAt'
        ]);
      allow delete: if false;
    }

    match /amenIntelligenceAuditEvents/{eventId} {
      allow read: if isModerator() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid', 'eventType', 'contentId', 'contentType', 'surface',
          'safetyTreatment', 'policyLevel', 'requiresHumanReview',
          'notifyModeration', 'verifyFundraising', 'humanStates',
          'spiritualIntents', 'trustSignals', 'metadata', 'createdAt'
        ]);
      allow update, delete: if false;
    }

    match /amenIntelligenceDecisions/{decisionId} {
      allow read: if isModerator() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /amenIntelligenceFeedback/{feedbackId} {
      allow read: if isModerator() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /amenSafetyModeStates/{uid} {
      allow read: if isOwner(uid) || isModerator();
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid', 'source', 'snapshotId', 'sourceContentId', 'sourceContentType',
          'surface', 'safetyTreatment', 'pauseNotifications',
          'disableStrangerDMs', 'notifyModeration', 'trustedCircleEligible',
          'metadata', 'updatedAt'
        ]);
      allow delete: if isOwner(uid);
    }

    match /amenReputationSignals/{signalId} {
      allow read: if isModerator() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if false;
    }

    // ── Default deny ─────────────────────────────────────────────────────
    // Catch-all: deny everything not matched above.

    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // SMART COLLABORATION LAYER — Phase 1
    // All AI-generated sub-collections (smartContext, summary, prayerSignals,
    // pulse, smartActions) are server-account/admin writes only.
    // Clients never create or delete these documents.
    // ═══════════════════════════════════════════════════════════════════════════

    // ── Smart Collab Helpers ──────────────────────────────────────────────────
    // isSpaceMember(spaceId) already defined above — not duplicated here.

    // True if the caller is a participant in the given DM conversation.
    // Mirrors secureCallable.ts verifyMembership (dm branch): reads participantIds.
    function isConversationParticipant(conversationId) {
      return isSignedIn() &&
        request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }

    // ── DM conversation smart sub-collections ────────────────────────────────
    // conversations/{conversationId}/smartContext/main

    match /conversations/{conversationId}/smartContext/main {
      // Only a participant in the parent conversation may read.
      allow read: if isConversationParticipant(conversationId);
      // Clients NEVER write AI-generated documents. Server (Admin SDK) only.
      allow write: if false;
    }

    // conversations/{conversationId}/summary/main

    match /conversations/{conversationId}/summary/main {
      allow read: if isConversationParticipant(conversationId);
      allow write: if false;
    }

    // conversations/{conversationId}/smartActions/{actionId}
    // Clients may update status only; all other mutations are server-only.

    match /conversations/{conversationId}/smartActions/{actionId} {
      allow read: if isConversationParticipant(conversationId);
      // Server creates and deletes. Clients may never create or delete.
      allow create, delete: if false;
      // Clients may update ONLY the status field to an approved terminal value.
      // generatedBy, generatedAt, modelVersion, actionType, suggestedText,
      // sourceMessageId, and confidence are immutable by clients.
      allow update: if isConversationParticipant(conversationId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status in ['accepted', 'dismissed', 'completed'] &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'generatedBy', 'generatedAt', 'modelVersion',
          'actionType', 'suggestedText', 'sourceMessageId', 'confidence'
        ]);
    }

    // conversations/{conversationId}/prayerSignals/{signalId}
    // Privacy contract: requestorId is NEVER visible to non-requestors.
    // Firestore rules cannot mask individual fields, so the rule exposes the
    // full doc only to the requestor or to members when the signal is approved
    // and non-anonymous. Requestor may delete their own signal.

    match /conversations/{conversationId}/prayerSignals/{signalId} {
      allow read: if isConversationParticipant(conversationId) &&
        (
          // Requestor always sees their own signal in full.
          request.auth.uid == resource.data.requestorId ||
          // Other members may read only approved, non-anonymous signals.
          (
            resource.data.moderationStatus == 'approved' &&
            resource.data.isAnonymous == false
          )
        );
      // Server creates and updates (moderation status is server-managed).
      allow create, update: if false;
      // Requestor may delete their own signal.
      allow delete: if isSignedIn() && request.auth.uid == resource.data.requestorId;
    }

    // conversations/{conversationId}/presence/{userId}
    // Members read all presence docs. Users write ONLY their own.
    // expiresAt must not be set more than 31 minutes into the future.

    match /conversations/{conversationId}/presence/{userId} {
      allow read: if isConversationParticipant(conversationId);
      allow create, update: if isSignedIn() &&
        request.auth.uid == userId &&
        isConversationParticipant(conversationId) &&
        request.resource.data.expiresAt <= request.time + duration.value(31, 'm');
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // ── Channel smart sub-collections ────────────────────────────────────────
    // spaces/{spaceId}/channels/{channelId}/...

    match /spaces/{spaceId}/channels/{channelId}/smartContext/main {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    match /spaces/{spaceId}/channels/{channelId}/summary/main {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // Channel smartActions — same field-level update contract as DM actions.

    match /spaces/{spaceId}/channels/{channelId}/smartActions/{actionId} {
      allow read: if isSpaceMember(spaceId);
      allow create, delete: if false;
      allow update: if isSpaceMember(spaceId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status in ['accepted', 'dismissed', 'completed'] &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'generatedBy', 'generatedAt', 'modelVersion',
          'actionType', 'suggestedText', 'sourceMessageId', 'confidence'
        ]);
    }

    // Channel prayerSignals — same privacy contract as DM signals.

    match /spaces/{spaceId}/channels/{channelId}/prayerSignals/{signalId} {
      allow read: if isSpaceMember(spaceId) &&
        (
          request.auth.uid == resource.data.requestorId ||
          (
            resource.data.moderationStatus == 'approved' &&
            resource.data.isAnonymous == false
          )
        );
      allow create, update: if false;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.requestorId;
    }

    // Channel presence — space members read; users write only their own doc.

    match /spaces/{spaceId}/channels/{channelId}/presence/{userId} {
      allow read: if isSpaceMember(spaceId);
      allow create, update: if isSignedIn() &&
        request.auth.uid == userId &&
        isSpaceMember(spaceId) &&
        request.resource.data.expiresAt <= request.time + duration.value(31, 'm');
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Channel pulse/main — read: space members and space admins/moderators.
    // Write: server (Admin SDK) only.

    match /spaces/{spaceId}/channels/{channelId}/pulse/main {
      allow read: if isSpaceMember(spaceId);
      allow write: if false;
    }

    // ── Rate limit doc — users/{uid}/rateLimits/smartCollab ──────────────────
    // Users read and write ONLY their own rate limit doc.
    // secureCallable.ts enforces the actual rate limit via a transaction; this
    // rule permits the read/write so the callable can function under rules.

    match /users/{uid}/rateLimits/smartCollab {
      allow read, write: if isOwner(uid);
    }

    // ── Media jobs — mediaJobs/{jobId} ───────────────────────────────────────
    // Server writes only. Requesting user reads their own jobs.

    match /mediaJobs/{jobId} {
      allow read: if isSignedIn() && resource.data.requestedBy == request.auth.uid;
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════════════
    // SPACES v2 — Community, Access Policy, Entitlements (Agent A)
    // ════════════════════════════════════════════════════════════════════════════

    // ── Spaces v2 helpers ────────────────────────────────────────────────────────

    function isCommunityOwner(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role == "owner";
    }

    function isCommunityAdmin(communityId) {
      let role = get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role;
      return role == "owner" || role == "admin";
    }

    function isSpaceAdminOrOwner(spaceId) {
      let member = get(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid));
      return member.data.role == "owner" || member.data.role == "admin";
    }

    function hasActiveEntitlement(spaceId) {
      let ent = get(/databases/$(database)/documents/entitlements/$(request.auth.uid + "_" + spaceId));
      return ent.data.status == "active" || ent.data.status == "grace";
    }

    function canReadSpaceV2(spaceId) {
      let space = get(/databases/$(database)/documents/spaces/$(spaceId));
      return space.data.accessPolicy == "free"
        ? get(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid)).data.access == "granted"
        : hasActiveEntitlement(spaceId);
    }

    function canWriteSpaceV2(spaceId) {
      return canReadSpaceV2(spaceId);
    }

    // ── Spaces v2: communities subcollections ─────────────────────────────────
    // Adds members and links subcollections to the existing /communities path.
    // The top-level /communities/{communityId} rule block above (legacy Ark) is
    // preserved. These nested subcollection rules extend it for Spaces v2.

    match /communities/{communityId}/members/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isCommunityAdmin(communityId) || request.auth.uid == userId
      );
    }

    match /communities/{communityId}/links/{linkId} {
      allow read: if isSignedIn() && isCommunityAdmin(communityId);
      allow write: if false; // Cloud Function only
    }

    // ── Spaces v2: entitlements — flat top-level, one get() gate ─────────────

    match /entitlements/{entitlementId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        isSpaceAdminOrOwner(resource.data.spaceId)
      );
      allow write: if false; // Cloud Function only (webhook + grantAccess + revokeAccess)
    }

    // ── Spaces v2: spaces subcollections (threads, studies, entitlement-gated) ─
    // The top-level /spaces/{spaceId} rules above cover existing Phase 0 paths.
    // These subcollections are new in Spaces v2 and require canReadSpaceV2 gating.

    match /spaces/{spaceId}/threads/{threadId} {
      allow read: if isSignedIn() && canReadSpaceV2(spaceId);
      allow write: if isSignedIn() && canWriteSpaceV2(spaceId);

      match /messages/{messageId} {
        allow read: if isSignedIn() && canReadSpaceV2(spaceId);
        allow create: if isSignedIn() && canWriteSpaceV2(spaceId);
        allow update: if isSignedIn() && (
          request.auth.uid == resource.data.authorId || isSpaceAdminOrOwner(spaceId)
        ) && canWriteSpaceV2(spaceId);
        allow delete: if false; // soft-delete: set isDeleted=true via Cloud Function
      }
    }

    match /spaces/{spaceId}/studies/{studyId} {
      allow read: if isSignedIn() && canReadSpaceV2(spaceId);
      allow write: if isSignedIn() && isSpaceAdminOrOwner(spaceId);

      match /blocks/{blockId} {
        allow read: if isSignedIn() && canReadSpaceV2(spaceId);
        allow write: if isSignedIn() && isSpaceAdminOrOwner(spaceId);
      }
    }

    // ════════════════════════════════════════════════════════════════════════════
    // SPACES v2 — amenCommunities collection (new, does NOT replace /communities)
    // ════════════════════════════════════════════════════════════════════════════
    //
    // amenCommunities/{communityId} is the AMEN Spaces billing/branding identity.
    // It is SEPARATE from /communities (legacy Ark). Do not merge them.
    //
    // Security model:
    //   - Top-level community doc: any signed-in user may read (for discovery).
    //   - Community creation goes through callable only (server sets ownerUserId,
    //     stripeConnectAccountId, createdAt — no client spoofing).
    //   - Member subcollection: any signed-in user can read; only admin/owner can
    //     add/remove members (via callable); members can read their own record.
    //   - Link subcollection: admin/owner reads; callable-only writes.

    function isAmenCommunityMember(communityId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/amenCommunities/$(communityId)/members/$(request.auth.uid));
    }

    function isAmenCommunityAdmin(communityId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/amenCommunities/$(communityId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/amenCommunities/$(communityId)/members/$(request.auth.uid))
          .data.role in ["owner", "admin"];
    }

    function isAmenCommunityOwner(communityId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/amenCommunities/$(communityId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/amenCommunities/$(communityId)/members/$(request.auth.uid))
          .data.role == "owner";
    }

    match /amenCommunities/{communityId} {
      // Community profile readable by any signed-in user (for discovery, invite links, etc.)
      allow read: if isSignedIn();
      // Client cannot create community directly — callable sets server-owned fields.
      allow create: if false;
      // Admin/owner can update display fields only (name, handle, avatarURL).
      // stripeConnectAccountId and createdAt are server-owned and must not change client-side.
      allow update: if isSignedIn() && isAmenCommunityAdmin(communityId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'ownerUserId', 'stripeConnectAccountId', 'createdAt'
        ]);
      allow delete: if isAdmin();

      // Members subcollection
      match /members/{userId} {
        // Any signed-in member of the community can read the member list.
        allow read: if isSignedIn() && isAmenCommunityMember(communityId);
        // Members can read their own record without needing to be a member yet (join flow).
        allow get: if isSignedIn() && (userId == request.auth.uid || isAmenCommunityMember(communityId));
        // Only callable (Admin SDK) may write member records.
        allow create, update, delete: if false;
      }

      // Links subcollection — cross-community sharing relationships
      match /links/{linkId} {
        // Admin/owner can read links; regular members cannot (privacy of partnerships).
        allow read: if isSignedIn() && isAmenCommunityAdmin(communityId);
        // Callable-only writes (createCommunityLink, acceptCommunityLink, revokeCommunityLink).
        allow create, update, delete: if false;
      }
    }

    // ── Spaces v2: entitlement + member access helpers (amenCommunities-aware) ──
    //
    // These helpers use amenCommunities instead of the legacy /communities path.
    // They EXTEND (not replace) the v2 helpers defined above.

    // Check if the caller is an admin/owner of the Space's parent amenCommunity.
    function isAmenSpaceAdmin(spaceId) {
      let communityId = get(/databases/$(database)/documents/spaces/$(spaceId)).data.communityId;
      return isAmenCommunityAdmin(communityId);
    }

    // Check if caller has an active/grace entitlement for a paid space,
    // OR if the space is free and caller is a member with access = "granted".
    // Matches scenarios 1–5 in the Agent A spec.
    function canReadAmenSpaceContent(spaceId) {
      let space = get(/databases/$(database)/documents/spaces/$(spaceId));
      let policy = space.data.accessPolicy;
      let memberRef = get(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid));
      // Scenario 1: Free space — any member with access = "granted"
      // Scenarios 2–5: Paid space — check entitlement
      return policy == "free"
        ? (exists(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid)) &&
           memberRef.data.access == "granted")
        : hasActiveEntitlement(spaceId);
    }

    // Scenario 6: External member via active link.
    // Caller must have a non-empty homeCommunityId in the Space members doc,
    // and that community must have an active link with the Space's owning community.
    function isExternalMemberWithActiveLink(spaceId) {
      let memberRef = get(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid));
      let homeCommunityId = memberRef.data.homeCommunityId;
      // Empty homeCommunityId = same-community member (not external)
      let isExternal = homeCommunityId != "";
      // Owning community for the Space
      let owningCommunityId = get(/databases/$(database)/documents/spaces/$(spaceId)).data.communityId;
      // Check the home community's link to the owning community is active
      let linkId = homeCommunityId + "_" + owningCommunityId;
      let linkActive = exists(/databases/$(database)/documents/amenCommunities/$(homeCommunityId)/links/$(linkId)) &&
        get(/databases/$(database)/documents/amenCommunities/$(homeCommunityId)/links/$(linkId))
          .data.status == "active";
      return isExternal && linkActive;
    }

    // Combined reader check: regular member access OR external-via-link access
    // OR admin/owner bypass.
    function canReadSpaceContentFull(spaceId) {
      return canReadAmenSpaceContent(spaceId) ||
             isExternalMemberWithActiveLink(spaceId) ||
             isAmenSpaceAdmin(spaceId);
    }

    // ── amenCommunities-aware Spaces subcollections ──────────────────────────────
    //
    // These rules AUGMENT the existing /spaces/{spaceId} block above.
    // They explicitly handle the amenCommunities entitlement path for threads/studies.
    // The existing "canReadSpaceV2" rules remain; these add the full 7-scenario gate.

    match /spaces/{spaceId}/threads/{threadId}/messages/{messageId} {
      // Full 7-scenario read gate (scenarios 1-7 + admin bypass):
      //   1. Free Space → any member with access=granted reads
      //   2. Paid, no entitlement → deny
      //   3. Paid, active entitlement → allow
      //   4. Paid, grace entitlement → allow
      //   5. Paid, expired entitlement → deny
      //   6. External member + active link → allow
      //   7. External member + revoked link → deny (access set to "none" by revokeSpaceLinkAccess)
      //   8. Admin/owner bypass → allow
      allow read: if isSignedIn() && canReadSpaceContentFull(spaceId);
      allow create: if isSignedIn() && canReadAmenSpaceContent(spaceId) &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.status == "active";
      // Update: only author or space admin (for moderation), never hard-delete
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.authorId && canReadAmenSpaceContent(spaceId)) ||
        isAmenSpaceAdmin(spaceId)
      );
      // Hard-delete blocked globally — use status flip
      allow delete: if false;
    }

    match /spaces/{spaceId}/studies/{studyId}/blocks/{blockId} {
      allow read: if isSignedIn() && canReadSpaceContentFull(spaceId);
      allow create, update: if isSignedIn() && isAmenSpaceAdmin(spaceId);
      allow delete: if false;
    }

    // ── Scenario 9: Entitlement writes — Cloud Function / Admin SDK only ─────────
    // The entitlements collection is already defined above (lines 5656-5664).
    // This comment confirms that:
    //   - Client cannot write entitlements (allow write: if false above)
    //   - Stripe webhook Cloud Function writes via Admin SDK (bypasses rules)
    //   - grantSpaceAccess callable writes via Admin SDK (bypasses rules)

    // ─── Community Notes (public/searchable church notes) ────────────────────
    // Private notes live here too but are invisible to other users via rules.
    // Indexing to Algolia/Pinecone is gated: only public + approved notes.

    match /communityNotes/{noteId} {

      function communityNoteServerFields() {
        return ['excerpt', 'scriptureRefs', 'scriptureRefStrings', 'scriptureKeys',
                'likeCount', 'commentCount', 'saveCount', 'indexedToAlgolia',
                'indexedToPinecone', 'embeddingModel', 'searchSyncedAt',
                'moderationStatus', 'publishedAt'];
      }

      function noServerFields() {
        return !request.resource.data.keys().hasAny(communityNoteServerFields());
      }

      function isNoteAuthor() {
        return request.auth != null && resource.data.authorId == request.auth.uid;
      }

      function isPublicApproved() {
        return resource.data.visibility == 'public'
            && resource.data.moderationStatus == 'approved';
      }

      function isConfirmedFollower() {
        return exists(/databases/$(database)/documents/users/$(resource.data.authorId)/followers/$(request.auth.uid));
      }

      allow read: if request.auth != null && (
        isNoteAuthor() ||
        isPublicApproved() ||
        (resource.data.visibility == 'followers' && isConfirmedFollower())
      );

      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && noServerFields()
        && request.resource.data.title.size() <= 140
        && request.resource.data.body.size() <= 20000
        && request.resource.data.visibility in ['public', 'followers', 'private'];

      allow update: if request.auth != null
        && resource.data.authorId == request.auth.uid
        && noServerFields()
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.title.size() <= 140
        && request.resource.data.body.size() <= 20000;

      allow delete: if isNoteAuthor();

      // Likes
      match /likes/{uid} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == uid;
      }

      // Comments
      match /comments/{commentId} {
        allow read: if request.auth != null && (
          isNoteAuthor() || isPublicApproved()
        );
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text.size() <= 2000
          && !request.resource.data.keys().hasAny(['amenCount', 'moderationStatus']);
        allow update: if request.auth != null
          && resource.data.authorId == request.auth.uid
          && !request.resource.data.keys().hasAny(['amenCount', 'moderationStatus']);
        allow delete: if request.auth != null
          && resource.data.authorId == request.auth.uid;

        match /amens/{uid} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth != null && request.auth.uid == uid;
        }
      }
    }

    // Saved notes (user's private bookmarks — their copy, not shared)
    match /users/{uid}/savedNotes/{noteId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // ─── End Community Notes ─────────────────────────────────────────────────

  }
}
