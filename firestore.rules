    // ── Moderation pipeline — server-only ─────────────────────────────────────

    // Safety OS: moderationAuditLog is append-only and immutable.
    // Moderators and T&S reviewers may read for incident reconstruction.
    // Cloud Functions write via Admin SDK — client writes are blocked.
    match /moderationAuditLog/{docId} {
      allow read: if isModerator() || request.auth.token.trustSafetyReviewer == true;
      allow create, update, delete: if false;
    }

    // Legacy alias — locked
    match /moderationAuditLogs/{docId} {
      allow read, write: if false;
