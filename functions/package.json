{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "lint": "eslint index.js pushNotifications.js aiModeration.js aiChurchNotes.js",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest --passWithNoTests",
    "build:context": "node scripts/build-context.js",
    "build:berean": "cd berean && npx tsc",
    "build:sanctuary": "npx tsc -p tsconfig.sanctuary.json",
    "build:moment": "npx tsc -p tsconfig.moment.json",
    "build:church": "npx tsc -p tsconfig.church.json"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/discussion/**/*.test.ts",
      "**/src/sanctuary/**/*.test.ts",
      "**/berean/**/*.test.ts",
      "**/test/ageTier.test.js",
      "**/test/phoneAuthPii.test.js",
      "**/test/safety-rules.test.js",
      "**/test/moderation-safety.test.js",
      "**/test/rules.spec.js",
      "**/test/guardianLink.test.js"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google-cloud/language": "^6.0.0",
    "@google-cloud/speech": "^6.7.1",
    "@google-cloud/translate": "^8.0.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@google-cloud/vision": "^4.3.3",
    "@google/generative-ai": "^0.24.1",
    "firebase-admin": "^13.6.1",
    "firebase-functions": "^7.2.5",
    "form-data": "^4.0.0",
    "geofire-common": "^6.0.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.14.1",
    "stripe": "^17.0.0",
    "twilio": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.19",
    "eslint": "^8.57.1",
    "eslint-config-google": "^0.14.0",
    "firebase-functions-test": "^3.4.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "private": true
}
