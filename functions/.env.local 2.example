# Copy this file to .env.local and fill in your keys for local emulator testing.
# .env.local is gitignored — never commit it.
#
# Get a Gemini API key from: https://aistudio.google.com/app/apikey
# The same key works for both BEREAN_LLM_KEY and EMBEDDING_KEY.

BEREAN_LLM_KEY=your-gemini-api-key-here
EMBEDDING_KEY=your-gemini-api-key-here
