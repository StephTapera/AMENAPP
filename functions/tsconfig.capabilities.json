{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "src/capabilities",
    "outDir": "lib/capabilities",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node"]
  },
  "include": ["src/capabilities/**/*.ts"],
  "exclude": ["src/capabilities/**/*.test.ts"]
}
