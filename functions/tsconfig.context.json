{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "context",
    "rootDir": "context",
    "types": [
      "node"
    ]
  },
  "include": [
    "context/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "context/**/*.test.ts"
  ]
}