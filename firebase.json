{
  "database": {
    "rules": "AMENAPP/database.rules.json"
  },
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "AMENAPP/storage.rules",
    "bucket": "amen-5e359.firebasestorage.app",
    "location": "us-west1"
  },
  "functions": [
    {
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [],
      "source": "functions"
    },
    {
      "codebase": "creator",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "PATH=/usr/local/bin:$PATH npm --prefix \"$RESOURCE_DIR\" run build"
      ],
      "source": "Backend/functions"
    }
  ],
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.5"
  }
}
